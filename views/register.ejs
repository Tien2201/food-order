<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đăng ký - Đậu Hũ Thúi Nhà Họ La</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="auth-page">
  <div class="auth-card">

    <div class="text-center mb-1">
      <img src="/images/logo.jpg" alt="Logo" style="width:56px;height:56px;border-radius:50%;object-fit:cover;border:2px solid #f0ece8;display:block;margin:0 auto;">
    </div>
    <h2 class="text-center">Tạo tài khoản mới ✨</h2>
    <p class="text-center">Đăng ký để bắt đầu đặt món yêu thích</p>

    <% if (typeof error !== "undefined") { %>
      <div class="alert alert-danger" id="registerAlert" style="border-radius:10px; font-size:13px;">
        <%= error %>
      </div>
      <script>
        setTimeout(() => {
          const box = document.getElementById("registerAlert");
          if (box) box.style.display = "none";
        }, 3000);
      </script>
    <% } %>

    <form action="/register" method="POST">
      <label class="form-label-custom">Họ và tên</label>
      <input type="text" name="fullname" class="form-input-custom" placeholder="Nguyễn Văn A" required>

      <label class="form-label-custom">Email</label>
      <input type="email" name="email" class="form-input-custom" placeholder="ban@email.com" required>

      <label class="form-label-custom">Mật khẩu</label>
      <input type="password" name="password" class="form-input-custom" placeholder="Tối thiểu 6 ký tự" minlength="6" required>

      <button type="submit" class="btn-auth">Đăng ký</button>
    </form>

    <p class="text-center mt-3 mb-0" style="font-size:13px; color:#9ca3af;">
      Đã có tài khoản?
      <a href="/login" style="color:#D85A30; font-weight:600;">Đăng nhập</a>
    </p>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đăng ký - Đậu Hũ Thúi Nhà Họ La</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Noto+Serif:wght@700&display=swap" rel="stylesheet">
  <style>
    .auth-card {
      animation: authCardIn 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    }

    @keyframes authCardIn {
      from { transform: translateY(16px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    .auth-card h2 {
      font-family: 'Noto Serif', Georgia, serif;
    }

    .input-with-icon {
      position: relative;
    }

    .input-with-icon .form-input-custom {
      padding-left: 40px;
    }

    .input-with-icon .input-icon {
      position: absolute;
      left: 13px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 15px;
      color: #b0a89e;
      pointer-events: none;
    }

    .password-toggle-btn {
      position: absolute;
      right: 6px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      font-size: 18px;
      cursor: pointer;
      padding: 6px 8px;
      color: #9e9484;
      line-height: 1;
    }

    .password-toggle-btn:hover { color: #D85A30; }

    .field-error-msg {
      font-size: 11.5px;
      color: #c0392b;
      margin: -10px 0 12px;
      min-height: 14px;
      display: none;
    }

    .field-error-msg.show { display: block; }

    .form-input-custom.input-invalid {
      border-color: #e0a39c;
      background: #fdf5f3;
    }

    .form-input-custom.input-valid {
      border-color: #b9d9c8;
    }

    /* ── Thanh đo độ mạnh mật khẩu ── */
    .password-strength-wrap {
      margin: -8px 0 12px;
    }

    .password-strength-bar {
      display: flex;
      gap: 4px;
      margin-bottom: 5px;
    }

    .password-strength-bar .seg {
      flex: 1;
      height: 4px;
      border-radius: 2px;
      background: #e3d8bf;
      transition: background 0.2s;
    }

    .password-strength-label {
      font-size: 11px;
      font-weight: 600;
      color: #9e9484;
    }

    .strength-weak .seg:nth-child(1) { background: #c0392b; }
    .strength-weak .password-strength-label { color: #c0392b; }

    .strength-medium .seg:nth-child(1),
    .strength-medium .seg:nth-child(2) { background: #d99a3f; }
    .strength-medium .password-strength-label { color: #b07a2e; }

    .strength-strong .seg { background: #4caf7d; }
    .strength-strong .password-strength-label { color: #2f8a5c; }

    .auth-divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 18px 0;
      font-size: 12px;
      color: #b0a89e;
    }

    .auth-divider::before,
    .auth-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #e3d8bf;
    }

    .btn-google {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: #fff;
      border: 1px solid #e3d8bf;
      border-radius: 10px;
      padding: 11px;
      font-size: 14px;
      font-weight: 500;
      color: #3c3c3c;
      cursor: pointer;
      transition: background 0.15s, box-shadow 0.15s;
      font-family: 'Poppins', sans-serif;
      text-decoration: none;
    }

    .btn-google:hover {
      background: #fafafa;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    .btn-google svg { width: 18px; height: 18px; flex-shrink: 0; }

    .btn-auth {
      position: relative;
    }

    .btn-auth .spinner {
      display: none;
      width: 16px;
      height: 16px;
      border: 2px solid rgba(255,255,255,0.4);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
      margin-right: 8px;
    }

    .btn-auth.loading .spinner { display: inline-block; }
    .btn-auth.loading .btn-text { opacity: 0.85; }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>
</head>
<body>

<div class="auth-page">
  <div class="auth-card">

    <div class="text-center mb-1">
      <img src="/images/logo.jpg" alt="Logo" style="width:56px;height:56px;border-radius:50%;object-fit:cover;border:2px solid #e3d8bf;display:block;margin:0 auto;">
    </div>
    <h2 class="text-center">Tạo tài khoản mới ✨</h2>
    <p class="text-center">Đăng ký để bắt đầu đặt món yêu thích</p>

    <% if (typeof error !== "undefined") { %>
      <div class="alert alert-danger" id="registerAlert" style="border-radius:10px; font-size:13px;">
        <%= error %>
      </div>
      <script>
        setTimeout(() => {
          const box = document.getElementById("registerAlert");
          if (box) box.style.display = "none";
        }, 3000);
      </script>
    <% } %>

    <!-- Đăng ký bằng Google: đã kích hoạt route /auth/google ở backend (dùng chung route đăng nhập/đăng ký). -->
    <a href="/auth/google" class="btn-google" id="googleRegisterBtn">
      <svg viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
      Đăng ký với Google
    </a>

    <div class="auth-divider">hoặc</div>

    <form action="/register" method="POST" id="registerForm">
      <label class="form-label-custom">Họ và tên</label>
      <div class="input-with-icon">
        <span class="input-icon">👤</span>
        <input type="text" name="fullname" id="fullnameInput" class="form-input-custom" placeholder="Nguyễn Văn A" required>
      </div>
      <div class="field-error-msg" id="fullnameError">Vui lòng nhập họ tên</div>

      <label class="form-label-custom">Email</label>
      <div class="input-with-icon">
        <span class="input-icon">✉️</span>
        <input type="email" name="email" id="emailInput" class="form-input-custom" placeholder="ban@email.com" required>
      </div>
      <div class="field-error-msg" id="emailError">Vui lòng nhập email hợp lệ</div>

      <label class="form-label-custom">Mật khẩu</label>
      <div class="input-with-icon">
        <span class="input-icon">🔒</span>
        <input type="password" name="password" id="passwordInput" class="form-input-custom" placeholder="Tối thiểu 6 ký tự" minlength="6" required style="padding-right:42px;">
        <button type="button" class="password-toggle-btn" id="togglePassword" aria-label="Hiện/ẩn mật khẩu">👁️</button>
      </div>
      <div class="password-strength-wrap" id="strengthWrap" style="display:none;">
        <div class="password-strength-bar" id="strengthBar">
          <div class="seg"></div>
          <div class="seg"></div>
          <div class="seg"></div>
        </div>
        <div class="password-strength-label" id="strengthLabel"></div>
      </div>
      <div class="field-error-msg" id="passwordError">Mật khẩu cần tối thiểu 6 ký tự</div>

      <label class="form-label-custom">Nhập lại mật khẩu</label>
      <div class="input-with-icon">
        <span class="input-icon">🔒</span>
        <input type="password" name="confirmPassword" id="confirmPasswordInput" class="form-input-custom" placeholder="Nhập lại mật khẩu" required style="padding-right:42px;">
        <button type="button" class="password-toggle-btn" id="toggleConfirmPassword" aria-label="Hiện/ẩn mật khẩu">👁️</button>
      </div>
      <div class="field-error-msg" id="confirmPasswordError">Mật khẩu nhập lại không khớp</div>

      <button type="submit" class="btn-auth" id="registerSubmitBtn">
        <span class="spinner"></span>
        <span class="btn-text">Đăng ký</span>
      </button>
    </form>

    <p class="text-center mt-3 mb-0" style="font-size:13px; color:#9ca3af;">
      Đã có tài khoản?
      <a href="/login" style="color:#D85A30; font-weight:600;">Đăng nhập</a>
    </p>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // ── Toggle hiện/ẩn mật khẩu (cả 2 ô) ──
  function setupToggle(inputId, btnId) {
    const input = document.getElementById(inputId);
    const btn = document.getElementById(btnId);
    btn.addEventListener('click', () => {
      const isHidden = input.type === 'password';
      input.type = isHidden ? 'text' : 'password';
      btn.textContent = isHidden ? '🙈' : '👁️';
    });
  }
  setupToggle('passwordInput', 'togglePassword');
  setupToggle('confirmPasswordInput', 'toggleConfirmPassword');

  // ── Validate real-time ──
  const fullnameInput = document.getElementById('fullnameInput');
  const fullnameError = document.getElementById('fullnameError');
  const emailInput = document.getElementById('emailInput');
  const emailError = document.getElementById('emailError');
  const passwordInput = document.getElementById('passwordInput');
  const passwordError = document.getElementById('passwordError');
  const confirmPasswordInput = document.getElementById('confirmPasswordInput');
  const confirmPasswordError = document.getElementById('confirmPasswordError');

  function isValidEmail(value) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
  }

  function markField(input, errorEl, valid, touched) {
    if (!touched) return;
    input.classList.toggle('input-invalid', !valid);
    input.classList.toggle('input-valid', valid);
    errorEl.classList.toggle('show', !valid);
  }

  function validateFullname(touched) {
    const valid = fullnameInput.value.trim().length > 0;
    markField(fullnameInput, fullnameError, valid, touched);
    return valid;
  }

  function validateEmail(touched) {
    const valid = isValidEmail(emailInput.value.trim());
    markField(emailInput, emailError, valid, touched);
    return valid;
  }

  function validatePassword(touched) {
    const valid = passwordInput.value.length >= 6;
    markField(passwordInput, passwordError, valid, touched);
    return valid;
  }

  function validateConfirmPassword(touched) {
    const valid = confirmPasswordInput.value.length > 0 && confirmPasswordInput.value === passwordInput.value;
    markField(confirmPasswordInput, confirmPasswordError, valid, touched);
    return valid;
  }

  fullnameInput.addEventListener('input', () => validateFullname(true));
  fullnameInput.addEventListener('blur', () => validateFullname(true));
  emailInput.addEventListener('input', () => validateEmail(true));
  emailInput.addEventListener('blur', () => validateEmail(true));
  confirmPasswordInput.addEventListener('input', () => validateConfirmPassword(true));
  confirmPasswordInput.addEventListener('blur', () => validateConfirmPassword(true));

  // ── Thanh đo độ mạnh mật khẩu ──
  const strengthWrap = document.getElementById('strengthWrap');
  const strengthBar = document.getElementById('strengthBar');
  const strengthLabel = document.getElementById('strengthLabel');

  function getPasswordStrength(value) {
    if (value.length === 0) return null;

    let score = 0;
    if (value.length >= 6) score++;
    if (value.length >= 10) score++;
    if (/[A-Z]/.test(value) && /[a-z]/.test(value)) score++;
    if (/[0-9]/.test(value)) score++;
    if (/[^A-Za-z0-9]/.test(value)) score++;

    if (score <= 2) return 'weak';
    if (score <= 3) return 'medium';
    return 'strong';
  }

  const strengthLabels = {
    weak: 'Yếu',
    medium: 'Trung bình',
    strong: 'Mạnh'
  };

  passwordInput.addEventListener('input', () => {
    validatePassword(true);

    const value = passwordInput.value;
    if (value.length === 0) {
      strengthWrap.style.display = 'none';
      return;
    }

    strengthWrap.style.display = 'block';
    const level = getPasswordStrength(value);
    strengthBar.className = 'password-strength-bar strength-' + level;
    strengthLabel.textContent = 'Độ mạnh: ' + strengthLabels[level];

    // Mật khẩu đổi thì cần kiểm tra lại confirm password nếu đã từng nhập
    if (confirmPasswordInput.value) validateConfirmPassword(true);
  });

  passwordInput.addEventListener('blur', () => validatePassword(true));

  // ── Loading state + validate toàn form khi submit ──
  const registerForm = document.getElementById('registerForm');
  const registerSubmitBtn = document.getElementById('registerSubmitBtn');

  registerForm.addEventListener('submit', (e) => {
    const fullnameOk = validateFullname(true);
    const emailOk = validateEmail(true);
    const passwordOk = validatePassword(true);
    const confirmOk = validateConfirmPassword(true);

    if (!fullnameOk || !emailOk || !passwordOk || !confirmOk) {
      e.preventDefault();
      return;
    }

    registerSubmitBtn.classList.add('loading');
    registerSubmitBtn.disabled = true;
  });

</script>
</body>
</html>

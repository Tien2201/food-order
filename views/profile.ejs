<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Thông tin cá nhân</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.png">
</head>
<body>

<%- include("partials/header", { user: user }) %>

<div class="container py-5">
  <div class="card p-4 profile-card">
    <h2 class="mb-4">Thông tin cá nhân</h2>

    <form action="/profile" method="POST">
      <label>Họ tên</label>
      <input name="fullname" class="form-control mb-3" value="<%= user.fullname %>" required>

      <label>Email</label>
      <input class="form-control mb-3" value="<%= user.email %>" disabled>

      <label>Số điện thoại</label>
      <input name="phone" class="form-control mb-3" value="<%= user.phone || '' %>">

      <label>Địa chỉ</label>
      <input name="address" class="form-control mb-3" value="<%= user.address || '' %>">

      <button class="btn btn-main w-100">
        Cập nhật thông tin
      </button>
    </form>
  </div>
</div>

<%- include("partials/footer") %>

</body>
</html>
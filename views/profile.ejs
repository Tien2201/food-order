<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Thông tin cá nhân - Đậu Hủ Thúi Nhà Họ La</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Noto+Serif:wght@700&display=swap" rel="stylesheet">
</head>

<body>

  <%- include("partials/header", { user: user }) %>

  <div class="container py-5" style="max-width:640px;">

    <% if (error) { %>
      <div class="alert alert-danger" id="profileAlert" style="border-radius:10px; font-size:13px;"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success" id="profileAlert" style="border-radius:10px; font-size:13px;"><%= success %></div>
    <% } %>

    <!-- ── Card avatar + tên ── -->
    <div class="profile-hero-card">
      <form action="/profile/avatar" method="POST" enctype="multipart/form-data" id="avatarForm">
        <div class="profile-avatar-wrap">
          <% if (user.avatar && user.avatar !== "/images/default-avatar.png") { %>
            <img src="<%= user.avatar %>" class="profile-avatar-img" alt="Avatar">
          <% } else { %>
            <div class="profile-avatar-fallback"><%= (user.fullname || '?').charAt(0).toUpperCase() %></div>
          <% } %>
          <label for="avatarInput" class="profile-avatar-edit-btn" title="Đổi ảnh đại diện">📷</label>
          <input type="file" name="avatar" id="avatarInput" accept="image/jpeg,image/jpg,image/png,image/webp" hidden>
        </div>
      </form>

      <h2 class="profile-name"><%= user.fullname %></h2>
      <p class="profile-email"><%= user.email %></p>
      <% if (user.username) { %>
        <span class="profile-username-badge">🆔 <%= user.username %></span>
      <% } %>
    </div>

    <!-- ── Form thông tin cá nhân ── -->
    <div class="profile-section-card">
      <div class="profile-section-title">Thông tin cá nhân</div>

      <form action="/profile" method="POST">
        <label class="form-label-custom">Họ tên</label>
        <input name="fullname" class="form-input-custom" value="<%= user.fullname %>" required>

        <label class="form-label-custom">Số điện thoại</label>
        <input name="phone" class="form-input-custom" value="<%= user.phone || '' %>" placeholder="VD: 0901234567">

        <label class="form-label-custom">Địa chỉ</label>
        <input name="address" class="form-input-custom" value="<%= user.address || '' %>" placeholder="Địa chỉ nhận hàng">

        <button class="btn-auth mt-2">💾 Cập nhật thông tin</button>
      </form>
    </div>

    <!-- ── Form đổi mật khẩu (chỉ hiện nếu tài khoản có password, không phải Google) ── -->
    <% if (user.password) { %>
      <div class="profile-section-card">
        <div class="profile-section-title">Đổi mật khẩu</div>

        <form action="/profile/password" method="POST" id="changePasswordForm">
          <label class="form-label-custom">Mật khẩu hiện tại</label>
          <div class="input-with-icon">
            <span class="input-icon">🔒</span>
            <input type="password" name="currentPassword" class="form-input-custom" placeholder="••••••••" required style="padding-left:40px;">
          </div>

          <label class="form-label-custom">Mật khẩu mới</label>
          <div class="input-with-icon">
            <span class="input-icon">🔒</span>
            <input type="password" name="newPassword" id="newPasswordInput" class="form-input-custom" placeholder="Tối thiểu 6 ký tự" minlength="6" required style="padding-left:40px;">
          </div>

          <label class="form-label-custom">Nhập lại mật khẩu mới</label>
          <div class="input-with-icon">
            <span class="input-icon">🔒</span>
            <input type="password" name="confirmNewPassword" id="confirmNewPasswordInput" class="form-input-custom" placeholder="Nhập lại mật khẩu mới" required style="padding-left:40px;">
          </div>
          <div class="field-error-msg" id="confirmNewPasswordError">Mật khẩu nhập lại không khớp</div>

          <button class="btn-auth mt-2">🔑 Đổi mật khẩu</button>
        </form>
      </div>
    <% } else { %>
      <div class="profile-section-card">
        <div class="profile-section-title">Đổi mật khẩu</div>
        <p style="font-size:13px; color:#9e9484; margin-bottom:0;">
          Tài khoản này đăng nhập bằng Google, không thể đổi mật khẩu ở đây.
        </p>
      </div>
    <% } %>

  </div>

  <%- include("partials/footer") %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Tự ẩn thông báo error/success sau 4 giây
    setTimeout(() => {
      const box = document.getElementById('profileAlert');
      if (box) box.style.display = 'none';
    }, 4000);

    // Bấm vào icon camera -> mở chọn ảnh -> tự submit ngay khi chọn xong
    const avatarInput = document.getElementById('avatarInput');
    const avatarForm = document.getElementById('avatarForm');
    if (avatarInput) {
      avatarInput.addEventListener('change', () => {
        if (avatarInput.files.length > 0) {
          avatarForm.submit();
        }
      });
    }

    // Validate nhập lại mật khẩu mới khớp nhau, real-time
    const newPasswordInput = document.getElementById('newPasswordInput');
    const confirmNewPasswordInput = document.getElementById('confirmNewPasswordInput');
    const confirmNewPasswordError = document.getElementById('confirmNewPasswordError');
    const changePasswordForm = document.getElementById('changePasswordForm');

    function validateConfirmNewPassword() {
      const valid = confirmNewPasswordInput.value.length > 0 && confirmNewPasswordInput.value === newPasswordInput.value;
      confirmNewPasswordInput.classList.toggle('input-invalid', !valid);
      confirmNewPasswordInput.classList.toggle('input-valid', valid);
      if (confirmNewPasswordError) confirmNewPasswordError.classList.toggle('show', !valid);
      return valid;
    }

    if (confirmNewPasswordInput) {
      confirmNewPasswordInput.addEventListener('input', validateConfirmNewPassword);
      newPasswordInput.addEventListener('input', () => {
        if (confirmNewPasswordInput.value) validateConfirmNewPassword();
      });

      changePasswordForm.addEventListener('submit', (e) => {
        if (!validateConfirmNewPassword()) {
          e.preventDefault();
        }
      });
    }
  </script>
</body>

</html>

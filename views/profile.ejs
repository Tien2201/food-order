<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Thông tin cá nhân</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.png">
</head>

<body>

  <%- include("partials/header", { user: user }) %>

    <div class="container py-5">

      <div class="profile-card">

        <div class="text-center mb-4">

          <img src="/images/default-avatar.png" class="profile-avatar">

          <h2 class="mt-3">
            <%= user.fullname %>
          </h2>

          <p class="text-muted">
            <%= user.email %>
          </p>

        </div>

        <form action="/profile" method="POST">

          <label>Họ tên</label>
          <input name="fullname" class="form-control mb-3" value="<%= user.fullname %>" required>

          <label>Số điện thoại</label>
          <input name="phone" class="form-control mb-3" value="<%= user.phone || '' %>">

          <label>Địa chỉ</label>
          <input name="address" class="form-control mb-3" value="<%= user.address || '' %>">

          <button class="btn btn-main w-100">
            Cập nhật thông tin
          </button>

        </form>

      </div>

    </div>
    
    </div>

    <%- include("partials/footer") %>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
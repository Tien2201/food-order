<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Food Order</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>

<body>

  <%- include("partials/header", { user: user }) %>

    <div class="container py-5">
      <h1 class="page-title mb-4">
        Menu hôm nay
      </h1>

      <h2 class="mb-4">
        🍜 Đồ ăn
      </h2>

      <div class="row g-4">
        <% foods.forEach(food=> { %>

          <!-- giữ nguyên card hiện tại -->

          <% }) %>
      </div>

      <hr class="my-5">

      <h2 class="mb-4">
        🥤 Đồ uống
      </h2>

      <div class="row g-4">
        <% drinks.forEach(food=> { %>

          <div class="col-md-4">
            <div class="card h-100">

              <img src="<%= food.image %>" class="food-img" alt="<%= food.name %>">

              <div class="card-body">

                <h4>
                  <%= food.name %>
                </h4>

                <p class="text-muted">
                  <%= food.description %>
                </p>

                <p class="price">
                  <%= food.price.toLocaleString() %> VNĐ
                </p>

                <form action="/cart/add/<%= food._id %>" method="POST">

                  <input type="number" name="quantity" value="1" min="1" class="form-control mb-2">

                  <input type="text" name="note" class="form-control mb-3" placeholder="Ghi chú">

                  <button class="btn btn-main w-100">
                    Thêm vào giỏ
                  </button>

                </form>

              </div>

            </div>
          </div>

          <% }) %>
      </div>
      <div class="col-md-4">
        <div class="card h-100">
          <img src="<%= food.image %>" class="food-img" alt="<%= food.name %>">

          <div class="card-body">
            <h4>
              <%= food.name %>
            </h4>
            <p class="text-muted">
              <%= food.description %>
            </p>
            <p class="price">
              <%= food.price.toLocaleString() %> VNĐ
            </p>

            <form action="/cart/add/<%= food._id %>" method="POST">
              <input type="number" name="quantity" value="1" min="1" class="form-control mb-2">
              <input type="text" name="note" class="form-control mb-3" placeholder="Ghi chú: không ớt, ít hành...">
              <button class="btn btn-main w-100">Thêm vào giỏ</button>
            </form>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    </div>
    <script>
      async function checkCustomerNotification() {
        const res = await fetch("/notifications");
        const data = await res.json();

        document.getElementById("customerBell").innerText = data.count;

        if (data.count > 0) {
          alert("Đơn hàng của bạn đã được nhân viên xác nhận. Hãy kiểm tra mã thanh toán!");
        }
      }

      setInterval(checkCustomerNotification, 5000);
      checkCustomerNotification();
    </script>
    <%- include("partials/footer") %>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
<script src="/js/main.js"></script>
<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Menu - Đậu Hủ Thúi Nhà Họ La</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

  <%- include("partials/header", { user: user }) %>

  <!-- Hero -->
  <div class="menu-hero">
    <div class="container">
      <h1>Menu hôm nay 🍜</h1>
      <p>Khám phá các món ăn đặc trưng của chúng tôi</p>

      <% if (featuredFoods && featuredFoods.length > 0) { %>
        <div class="featured-slideshow" id="featuredSlideshow">
          <% featuredFoods.forEach((food, i) => { %>
            <div class="featured-slide <%= i === 0 ? 'active' : '' %>">
              <img src="<%= food.image %>" class="featured-slide-bg" alt="<%= food.name %>" onerror="this.src='/images/background.jpg'">
              <div class="featured-slide-overlay"></div>
              <div class="featured-slide-content">
                <span class="featured-badge"><%= food.badge %></span>
                <h2><%= food.name %></h2>
                <div class="featured-desc"><%= food.description || '' %></div>
                <div class="featured-price"><%= food.price.toLocaleString('vi-VN') %> VNĐ</div>
                <% if (food.ratingCount > 0) { %>
                  <div class="featured-rating">⭐ <%= food.avgRating %> (<%= food.ratingCount %> đánh giá)</div>
                <% } %>
              </div>
            </div>
          <% }) %>

          <% if (featuredFoods.length > 1) { %>
            <div class="slideshow-arrows">
              <button class="slideshow-arrow-btn" id="slidePrevBtn" aria-label="Trước">‹</button>
              <button class="slideshow-arrow-btn" id="slideNextBtn" aria-label="Sau">›</button>
            </div>
            <div class="slideshow-dots">
              <% featuredFoods.forEach((food, i) => { %>
                <button class="slideshow-dot <%= i === 0 ? 'active' : '' %>" data-i="<%= i %>" aria-label="Slide <%= i+1 %>"></button>
              <% }) %>
            </div>
          <% } %>
        </div>
      <% } %>

      <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input
          type="text"
          class="search-input"
          id="searchInput"
          placeholder="Tìm món ăn..."
          autocomplete="off"
        >
      </div>
    </div>
  </div>

  <!-- Filter tabs -->
  <div class="filter-bar">
    <div class="container">
      <div class="filter-tabs">
        <button class="filter-tab active" data-filter="all">Tất cả</button>
        <button class="filter-tab" data-filter="food">🍜 Đồ ăn</button>
        <button class="filter-tab" data-filter="drink">🥤 Đồ uống</button>
      </div>
    </div>
  </div>

  <!-- Menu content -->
  <div class="container py-5">

    <!-- Đồ ăn section -->
    <div id="section-food" class="mb-5">
      <div class="section-label">Đồ ăn</div>
      <div class="row g-4" id="grid-food">
        <% foods.forEach(food => { %>
          <div class="col-md-4 col-sm-6 food-item" data-type="food" data-name="<%= food.name.toLowerCase() %>">
            <div class="food-card">
              <img src="<%= food.image %>" class="food-img" alt="<%= food.name %>">
              <div class="card-body">
                <div class="food-name"><%= food.name %></div>
                <% if (food.description) { %>
                  <div class="food-desc"><%= food.description %></div>
                <% } %>
                <div class="food-price"><%= food.price.toLocaleString('vi-VN') %> VNĐ</div>
                <form action="/cart/add/<%= food._id %>" method="POST">
                  <div class="qty-control">
                    <button type="button" class="qty-btn" onclick="changeQty(this, -1)">−</button>
                    <input type="number" name="quantity" class="qty-value" value="1" min="1" readonly>
                    <button type="button" class="qty-btn" onclick="changeQty(this, 1)">+</button>
                  </div>
                  <input type="text" name="note" class="note-input" placeholder="Ghi chú (không bắt buộc)">
                  <button type="submit" class="btn-add-cart">
                    🛒 Thêm vào giỏ
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <div id="empty-food" class="empty-state" style="display:none">
        <div class="empty-icon">🍽️</div>
        <p>Không tìm thấy món ăn phù hợp</p>
      </div>
    </div>

    <hr style="border-color: #f0ece8; margin-bottom: 40px;">

    <!-- Đồ uống section -->
    <div id="section-drink">
      <div class="section-label">Đồ uống</div>
      <div class="row g-4" id="grid-drink">
        <% drinks.forEach(food => { %>
          <div class="col-md-4 col-sm-6 food-item" data-type="drink" data-name="<%= food.name.toLowerCase() %>">
            <div class="food-card">
              <img src="<%= food.image %>" class="food-img" alt="<%= food.name %>">
              <div class="card-body">
                <div class="food-name"><%= food.name %></div>
                <% if (food.description) { %>
                  <div class="food-desc"><%= food.description %></div>
                <% } %>
                <div class="food-price"><%= food.price.toLocaleString('vi-VN') %> VNĐ</div>
                <form action="/cart/add/<%= food._id %>" method="POST">
                  <div class="qty-control">
                    <button type="button" class="qty-btn" onclick="changeQty(this, -1)">−</button>
                    <input type="number" name="quantity" class="qty-value" value="1" min="1" readonly>
                    <button type="button" class="qty-btn" onclick="changeQty(this, 1)">+</button>
                  </div>
                  <input type="text" name="note" class="note-input" placeholder="Ghi chú (không bắt buộc)">
                  <button type="submit" class="btn-add-cart">
                    🛒 Thêm vào giỏ
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <div id="empty-drink" class="empty-state" style="display:none">
        <div class="empty-icon">🥤</div>
        <p>Không tìm thấy đồ uống phù hợp</p>
      </div>
    </div>

  </div>

  <%- include("partials/footer") %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>

  <script>
    // ── Quantity control ──
    function changeQty(btn, delta) {
      const input = btn.parentElement.querySelector('.qty-value');
      const current = parseInt(input.value) || 1;
      const next = Math.max(1, current + delta);
      input.value = next;
    }

    // ── Filter tabs ──
    const filterTabs = document.querySelectorAll('.filter-tab');
    const sectionFood = document.getElementById('section-food');
    const sectionDrink = document.getElementById('section-drink');

    filterTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        filterTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const filter = tab.dataset.filter;
        if (filter === 'all') {
          sectionFood.style.display = '';
          sectionDrink.style.display = '';
        } else if (filter === 'food') {
          sectionFood.style.display = '';
          sectionDrink.style.display = 'none';
        } else {
          sectionFood.style.display = 'none';
          sectionDrink.style.display = '';
        }
        applySearch();
      });
    });

    // ── Search ──
    const searchInput = document.getElementById('searchInput');

    function applySearch() {
      const query = searchInput.value.trim().toLowerCase();
      const activeFilter = document.querySelector('.filter-tab.active').dataset.filter;

      ['food', 'drink'].forEach(type => {
        const section = document.getElementById('section-' + type);
        if (section.style.display === 'none') return;

        const items = section.querySelectorAll('.food-item');
        let visibleCount = 0;

        items.forEach(item => {
          const name = item.dataset.name || '';
          const match = !query || name.includes(query);
          item.classList.toggle('hidden', !match);
          if (match) visibleCount++;
        });

        const emptyEl = document.getElementById('empty-' + type);
        emptyEl.style.display = visibleCount === 0 ? '' : 'none';
      });
    }

    searchInput.addEventListener('input', applySearch);

    // ── Customer notification ──
    async function checkCustomerNotification() {
      try {
        const res = await fetch("/notifications");
        const data = await res.json();
        const bell = document.getElementById("customerBell");
        if (bell) bell.innerText = data.count;
      } catch (e) {}
    }

    setInterval(checkCustomerNotification, 5000);
    checkCustomerNotification();

    // ── Featured slideshow ──
    (function() {
      const wrap = document.getElementById('featuredSlideshow');
      if (!wrap) return;

      const slides = wrap.querySelectorAll('.featured-slide');
      const dots = wrap.querySelectorAll('.slideshow-dot');
      const prevBtn = document.getElementById('slidePrevBtn');
      const nextBtn = document.getElementById('slideNextBtn');
      let current = 0;
      let timer;

      function show(i) {
        slides.forEach((s, idx) => s.classList.toggle('active', idx === i));
        dots.forEach((d, idx) => d.classList.toggle('active', idx === i));
        current = i;
      }

      function next() { show((current + 1) % slides.length); }
      function prev() { show((current - 1 + slides.length) % slides.length); }

      function restart() {
        clearInterval(timer);
        if (slides.length > 1) timer = setInterval(next, 4000);
      }

      if (nextBtn) nextBtn.addEventListener('click', () => { next(); restart(); });
      if (prevBtn) prevBtn.addEventListener('click', () => { prev(); restart(); });
      dots.forEach(d => d.addEventListener('click', () => { show(parseInt(d.dataset.i)); restart(); }));

      restart();
    })();
  </script>

</body>
</html>

<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Menu - Đậu Hủ Thúi Nhà Họ La</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

  <%- include("partials/header", { user: user }) %>

  <!-- Hero -->
  <div class="menu-hero">
    <div class="container">
      <h1>Menu hôm nay 🍜</h1>
      <p>Khám phá các món ăn đặc trưng của chúng tôi</p>

      <% if (featuredFoods && featuredFoods.length > 0) { %>
        <div class="featured-slideshow" id="featuredSlideshow">
          <% featuredFoods.forEach((food, i) => { %>
            <div class="featured-slide <%= i === 0 ? 'active' : '' %>">
              <img src="<%= food.image %>" class="featured-slide-bg" alt="<%= food.name %>" onerror="this.src='/images/background.jpg'">
              <div class="featured-slide-overlay"></div>
              <div class="featured-slide-content">
                <span class="featured-badge"><%= food.badge %></span>
                <h2><%= food.name %></h2>
                <div class="featured-desc"><%= food.description || '' %></div>
                <div class="featured-price"><%= food.price.toLocaleString('vi-VN') %> VNĐ</div>
                <% if (food.ratingCount > 0) { %>
                  <div class="featured-rating">⭐ <%= food.avgRating %> (<%= food.ratingCount %> đánh giá)</div>
                <% } %>
              </div>
            </div>
          <% }) %>

          <% if (featuredFoods.length > 1) { %>
            <div class="slideshow-arrows">
              <button class="slideshow-arrow-btn" id="slidePrevBtn" aria-label="Trước">‹</button>
              <button class="slideshow-arrow-btn" id="slideNextBtn" aria-label="Sau">›</button>
            </div>
            <div class="slideshow-dots">
              <% featuredFoods.forEach((food, i) => { %>
                <button class="slideshow-dot <%= i === 0 ? 'active' : '' %>" data-i="<%= i %>" aria-label="Slide <%= i+1 %>"></button>
              <% }) %>
            </div>
          <% } %>
        </div>
      <% } %>

      <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input
          type="text"
          class="search-input"
          id="searchInput"
          placeholder="Tìm món ăn..."
          autocomplete="off"
        >
      </div>
    </div>
  </div>

  <!-- Filter tabs -->
  <div class="filter-bar">
    <div class="container">
      <div class="filter-tabs">
        <button class="filter-tab active" data-filter="all">Tất cả</button>
        <button class="filter-tab" data-filter="food">🍜 Đồ ăn</button>
        <button class="filter-tab" data-filter="drink">🥤 Đồ uống</button>
      </div>
    </div>
  </div>

  <!-- Menu content -->
  <div class="container py-5">

    <!-- Đồ ăn section -->
    <div id="section-food" class="mb-5">
      <div class="section-label">Đồ ăn</div>
      <div class="row g-4" id="grid-food">
        <% foods.forEach(food => { %>
          <div class="col-lg-3 col-md-4 col-sm-6 food-item" data-type="food" data-name="<%= food.name.toLowerCase() %>">
            <div class="food-card"
                 onclick="openFoodModal(this)"
                 data-id="<%= food._id %>"
                 data-name="<%= food.name %>"
                 data-price="<%= food.price %>"
                 data-image="<%= food.image %>"
                 data-category="<%= food.category %>"
                 data-soup-type="<%= food.soupType %>"
                 data-ingredients='<%- JSON.stringify(food.ingredients || []) %>'>
              <img src="<%= food.image %>" class="food-img" alt="<%= food.name %>">
              <div class="card-body">
                <div class="food-name"><%= food.name %></div>
                <div class="food-tags">
                  <% if (food.spiceLevel === 'spicy') { %>
                    <span class="food-tag food-tag-spicy"><span class="food-tag-icon">🌶️</span>Cay</span>
                  <% } %>
                  <% if (food.soupType === 'soup') { %>
                    <span class="food-tag food-tag-soup"><span class="food-tag-icon">🍜</span>Soup</span>
                  <% } else { %>
                    <span class="food-tag food-tag-dry"><span class="food-tag-icon">🍲</span>Khô</span>
                  <% } %>
                </div>
                <% if (food.description) { %>
                  <div class="food-desc"><%= food.description %></div>
                <% } %>
                <div class="food-price"><%= food.price.toLocaleString('vi-VN') %> VNĐ</div>
                <button type="button" class="btn-add-cart" onclick="event.stopPropagation(); openFoodModal(this.closest('.food-card'))">
                  🛒 Thêm vào giỏ
                </button>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <div id="empty-food" class="empty-state" style="display:none">
        <div class="empty-icon">🍽️</div>
        <p>Không tìm thấy món ăn phù hợp</p>
      </div>
    </div>

    <hr style="border-color: #f0ece8; margin-bottom: 40px;">

    <!-- Đồ uống section -->
    <div id="section-drink">
      <div class="section-label">Đồ uống</div>
      <div class="row g-4" id="grid-drink">
        <% drinks.forEach(food => { %>
          <div class="col-lg-3 col-md-4 col-sm-6 food-item" data-type="drink" data-name="<%= food.name.toLowerCase() %>">
            <div class="food-card"
                 onclick="openFoodModal(this)"
                 data-id="<%= food._id %>"
                 data-name="<%= food.name %>"
                 data-price="<%= food.price %>"
                 data-image="<%= food.image %>"
                 data-category="<%= food.category %>"
                 data-soup-type="<%= food.soupType %>"
                 data-ingredients='<%- JSON.stringify(food.ingredients || []) %>'>
              <img src="<%= food.image %>" class="food-img" alt="<%= food.name %>">
              <div class="card-body">
                <div class="food-name"><%= food.name %></div>
                <div class="food-tags">
                  <% if (food.spiceLevel === 'spicy') { %>
                    <span class="food-tag food-tag-spicy"><span class="food-tag-icon">🌶️</span>Cay</span>
                  <% } %>
                  <% if (food.soupType === 'soup') { %>
                    <span class="food-tag food-tag-soup"><span class="food-tag-icon">🍜</span>Soup</span>
                  <% } else { %>
                    <span class="food-tag food-tag-dry"><span class="food-tag-icon">🍲</span>Khô</span>
                  <% } %>
                </div>
                <% if (food.description) { %>
                  <div class="food-desc"><%= food.description %></div>
                <% } %>
                <div class="food-price"><%= food.price.toLocaleString('vi-VN') %> VNĐ</div>
                <button type="button" class="btn-add-cart" onclick="event.stopPropagation(); openFoodModal(this.closest('.food-card'))">
                  🛒 Thêm vào giỏ
                </button>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <div id="empty-drink" class="empty-state" style="display:none">
        <div class="empty-icon">🥤</div>
        <p>Không tìm thấy đồ uống phù hợp</p>
      </div>
    </div>

  </div>

  <!-- Modal chọn tùy chỉnh món -->
  <div class="food-modal-overlay" id="foodModalOverlay" onclick="if(event.target===this) closeFoodModal()">
    <div class="food-modal">
      <button type="button" class="food-modal-close" onclick="closeFoodModal()">✕</button>

      <div class="food-modal-header">
        <img id="modalFoodImg" src="" alt="">
        <div>
          <div class="food-modal-name" id="modalFoodName"></div>
          <div class="food-modal-price" id="modalFoodPrice"></div>
        </div>
      </div>

      <div class="food-modal-body">

        <!-- Soup chung/riêng: chỉ hiện khi món có soupType = soup -->
        <div id="modalSoupGroup" class="modal-option-group" style="display:none">
          <div class="modal-option-label">🍜 Soup</div>
          <div class="modal-option-choices">
            <label class="modal-chip">
              <input type="radio" name="soupChoice" value="Soup chung" checked>
              <span>Soup chung</span>
            </label>
            <label class="modal-chip">
              <input type="radio" name="soupChoice" value="Soup riêng">
              <span>Soup riêng</span>
            </label>
          </div>
        </div>

        <!-- Gia vị/thành phần: render động theo danh sách ingredients của từng món -->
        <div id="modalIngredientGroup" class="modal-option-group" style="display:none">
          <div class="modal-option-label">🧂 Gia vị</div>
          <div class="modal-option-choices" id="modalIngredientChoices"></div>
        </div>

        <!-- Đá chung/riêng: chỉ hiện cho đồ uống -->
        <div id="modalIceGroup" class="modal-option-group" style="display:none">
          <div class="modal-option-label">🧊 Đá</div>
          <div class="modal-option-choices">
            <label class="modal-chip">
              <input type="radio" name="iceChoice" value="Đá chung" checked>
              <span>Đá chung</span>
            </label>
            <label class="modal-chip">
              <input type="radio" name="iceChoice" value="Đá riêng">
              <span>Đá riêng</span>
            </label>
          </div>
        </div>

        <div class="modal-option-group">
          <div class="modal-option-label">🔢 Số lượng</div>
          <div class="qty-control">
            <button type="button" class="qty-btn" onclick="changeModalQty(-1)">−</button>
            <input type="number" id="modalQty" class="qty-value" value="1" min="1" readonly>
            <button type="button" class="qty-btn" onclick="changeModalQty(1)">+</button>
          </div>
        </div>

        <div class="modal-option-group">
          <div class="modal-option-label">📝 Ghi chú thêm</div>
          <input type="text" id="modalNote" class="note-input" placeholder="Ghi chú khác (không bắt buộc)">
        </div>

      </div>

      <div class="food-modal-footer">
        <button type="button" class="btn-add-cart" id="modalAddBtn" onclick="confirmAddToCart()">
          🛒 Thêm vào giỏ
        </button>
      </div>
    </div>
  </div>

  <!-- Icon món bay vào giỏ (hiệu ứng) -->
  <img id="flyingImg" class="flying-img" src="" alt="">

  <%- include("partials/footer") %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>

  <script>
    // ── Modal chọn tùy chỉnh món ──
    let currentFood = null; // { id, name, price, image, category, soupType, ingredients }

    function openFoodModal(cardEl) {
      let ingredients = [];
      try {
        ingredients = JSON.parse(cardEl.dataset.ingredients || '[]');
      } catch (e) {
        ingredients = [];
      }

      currentFood = {
        id: cardEl.dataset.id,
        name: cardEl.dataset.name,
        price: cardEl.dataset.price,
        image: cardEl.dataset.image,
        category: cardEl.dataset.category,
        soupType: cardEl.dataset.soupType,
        ingredients: ingredients
      };

      document.getElementById('modalFoodImg').src = currentFood.image;
      document.getElementById('modalFoodName').textContent = currentFood.name;
      document.getElementById('modalFoodPrice').textContent =
        Number(currentFood.price).toLocaleString('vi-VN') + ' VNĐ';

      // Hiện đúng nhóm tùy chọn theo dữ liệu riêng của món này
      const hasSoup = currentFood.soupType === 'soup';
      const isDrink = currentFood.category === 'drink';
      const hasIngredients = currentFood.ingredients.length > 0;

      document.getElementById('modalSoupGroup').style.display = hasSoup ? '' : 'none';
      document.getElementById('modalIceGroup').style.display = isDrink ? '' : 'none';

      // Render động các chip "Không [gia vị]" theo danh sách ingredients của món này
      const choicesEl = document.getElementById('modalIngredientChoices');
      choicesEl.innerHTML = '';
      currentFood.ingredients.forEach((ing, i) => {
        const label = document.createElement('label');
        label.className = 'modal-chip';
        label.innerHTML = `
          <input type="checkbox" name="ingredientOption" value="Không ${ing}">
          <span>Không ${ing}</span>
        `;
        choicesEl.appendChild(label);
      });
      document.getElementById('modalIngredientGroup').style.display = hasIngredients ? '' : 'none';

      // Reset form về mặc định
      document.getElementById('modalQty').value = 1;
      document.getElementById('modalNote').value = '';
      document.querySelectorAll('#foodModalOverlay input[type="checkbox"]').forEach(cb => cb.checked = false);
      const defaultSoup = document.querySelector('#foodModalOverlay input[name="soupChoice"][value="Soup chung"]');
      if (defaultSoup) defaultSoup.checked = true;
      const defaultIce = document.querySelector('#foodModalOverlay input[name="iceChoice"][value="Đá chung"]');
      if (defaultIce) defaultIce.checked = true;

      document.getElementById('foodModalOverlay').classList.add('show');
      document.body.style.overflow = 'hidden';
    }

    function closeFoodModal() {
      document.getElementById('foodModalOverlay').classList.remove('show');
      document.body.style.overflow = '';
      currentFood = null;
    }

    function changeModalQty(delta) {
      const input = document.getElementById('modalQty');
      const next = Math.max(1, (parseInt(input.value) || 1) + delta);
      input.value = next;
    }

    // ── Gom các lựa chọn trong modal thành 1 chuỗi ghi chú ──
    function buildNoteFromModal() {
      const parts = [];

      if (currentFood.soupType === 'soup') {
        const soupChoice = document.querySelector('#foodModalOverlay input[name="soupChoice"]:checked');
        if (soupChoice) parts.push(soupChoice.value);
      }

      document.querySelectorAll('#foodModalOverlay input[name="ingredientOption"]:checked').forEach(cb => {
        parts.push(cb.value);
      });

      if (currentFood.category === 'drink') {
        const iceChoice = document.querySelector('#foodModalOverlay input[name="iceChoice"]:checked');
        if (iceChoice) parts.push(iceChoice.value);
      }

      const extra = document.getElementById('modalNote').value.trim();
      if (extra) parts.push(extra);

      return parts.join(', ');
    }

    // ── Hiệu ứng ảnh bay vào icon giỏ hàng ──
    function flyToCart(imgSrc, startEl) {
      const cartBtn = document.querySelector('.btn-cart');
      if (!cartBtn) return;

      const flyImg = document.getElementById('flyingImg');
      const startRect = startEl.getBoundingClientRect();
      const endRect = cartBtn.getBoundingClientRect();

      flyImg.src = imgSrc;
      flyImg.style.display = 'block';
      flyImg.style.left = startRect.left + startRect.width / 2 - 28 + 'px';
      flyImg.style.top = startRect.top + startRect.height / 2 - 28 + 'px';
      flyImg.style.width = '56px';
      flyImg.style.height = '56px';
      flyImg.style.opacity = '1';
      flyImg.style.transform = 'scale(1)';

      requestAnimationFrame(() => {
        flyImg.style.transition = 'all 0.6s cubic-bezier(0.55, 0, 1, 0.45)';
        flyImg.style.left = endRect.left + endRect.width / 2 - 10 + 'px';
        flyImg.style.top = endRect.top + endRect.height / 2 - 10 + 'px';
        flyImg.style.width = '20px';
        flyImg.style.height = '20px';
        flyImg.style.opacity = '0.3';
      });

      setTimeout(() => {
        flyImg.style.display = 'none';
        flyImg.style.transition = 'none';
        cartBtn.classList.add('cart-bump');
        setTimeout(() => cartBtn.classList.remove('cart-bump'), 300);
      }, 600);
    }

    function updateCartBadge(count) {
      const cartBtn = document.querySelector('.btn-cart');
      if (!cartBtn) return;
      let badge = cartBtn.querySelector('.cart-badge');
      if (!badge) {
        badge = document.createElement('span');
        badge.className = 'cart-badge';
        cartBtn.appendChild(badge);
      }
      badge.textContent = count;
    }

    // ── Xác nhận thêm vào giỏ từ modal (AJAX, không reload trang) ──
    async function confirmAddToCart() {
      if (!currentFood) return;

      const btn = document.getElementById('modalAddBtn');
      btn.disabled = true;

      const quantity = document.getElementById('modalQty').value;
      const note = buildNoteFromModal();
      const imgSrc = currentFood.image;

      // Tìm card gốc trên trang để làm điểm bắt đầu hiệu ứng bay
      const sourceCard = document.querySelector(`.food-card[data-id="${currentFood.id}"]`);
      const sourceImg = sourceCard ? sourceCard.querySelector('.food-img') : null;

      try {
        const res = await fetch(`/cart/add/${currentFood.id}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: new URLSearchParams({ quantity, note })
        });

        const data = await res.json();

        if (data.success) {
          closeFoodModal();
          if (sourceImg) flyToCart(imgSrc, sourceImg);
          updateCartBadge(data.cartCount);
        } else {
          alert(data.message || 'Có lỗi xảy ra, vui lòng thử lại.');
        }
      } catch (err) {
        console.error(err);
        alert('Không thể thêm vào giỏ, vui lòng kiểm tra kết nối.');
      } finally {
        btn.disabled = false;
      }
    }

    // ── Filter tabs ──
    const filterTabs = document.querySelectorAll('.filter-tab');
    const sectionFood = document.getElementById('section-food');
    const sectionDrink = document.getElementById('section-drink');

    filterTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        filterTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const filter = tab.dataset.filter;
        if (filter === 'all') {
          sectionFood.style.display = '';
          sectionDrink.style.display = '';
        } else if (filter === 'food') {
          sectionFood.style.display = '';
          sectionDrink.style.display = 'none';
        } else {
          sectionFood.style.display = 'none';
          sectionDrink.style.display = '';
        }
        applySearch();
      });
    });

    // ── Search ──
    const searchInput = document.getElementById('searchInput');

    function applySearch() {
      const query = searchInput.value.trim().toLowerCase();
      const activeFilter = document.querySelector('.filter-tab.active').dataset.filter;

      ['food', 'drink'].forEach(type => {
        const section = document.getElementById('section-' + type);
        if (section.style.display === 'none') return;

        const items = section.querySelectorAll('.food-item');
        let visibleCount = 0;

        items.forEach(item => {
          const name = item.dataset.name || '';
          const match = !query || name.includes(query);
          item.classList.toggle('hidden', !match);
          if (match) visibleCount++;
        });

        const emptyEl = document.getElementById('empty-' + type);
        emptyEl.style.display = visibleCount === 0 ? '' : 'none';
      });
    }

    searchInput.addEventListener('input', applySearch);

    // ── Featured slideshow ──
    (function() {
      const wrap = document.getElementById('featuredSlideshow');
      if (!wrap) return;

      const slides = wrap.querySelectorAll('.featured-slide');
      const dots = wrap.querySelectorAll('.slideshow-dot');
      const prevBtn = document.getElementById('slidePrevBtn');
      const nextBtn = document.getElementById('slideNextBtn');
      let current = 0;
      let timer;

      function show(i) {
        slides.forEach((s, idx) => s.classList.toggle('active', idx === i));
        dots.forEach((d, idx) => d.classList.toggle('active', idx === i));
        current = i;
      }

      function next() { show((current + 1) % slides.length); }
      function prev() { show((current - 1 + slides.length) % slides.length); }

      function restart() {
        clearInterval(timer);
        if (slides.length > 1) timer = setInterval(next, 4000);
      }

      if (nextBtn) nextBtn.addEventListener('click', () => { next(); restart(); });
      if (prevBtn) prevBtn.addEventListener('click', () => { prev(); restart(); });
      dots.forEach(d => d.addEventListener('click', () => { show(parseInt(d.dataset.i)); restart(); }));

      restart();
    })();
  </script>

</body>
</html>

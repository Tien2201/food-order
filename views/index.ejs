<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Menu - Đậu Hũ Thúi Nhà Họ La</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      background: #faf9f7;
      font-family: 'Poppins', sans-serif;
    }

    /* ── Hero banner ── */
    .menu-hero {
      background: linear-gradient(135deg, #1a1a1a 0%, #2d1a0e 100%);
      padding: 48px 0 36px;
      margin-bottom: 0;
    }

    .menu-hero h1 {
      font-size: 28px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 6px;
    }

    .menu-hero p {
      color: #b0a89e;
      font-size: 14px;
      margin-bottom: 20px;
    }

    /* ── Search bar ── */
    .search-wrap {
      position: relative;
      max-width: 480px;
    }

    .search-wrap .search-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: #aaa;
      font-size: 16px;
      pointer-events: none;
    }

    .search-input {
      width: 100%;
      padding: 11px 14px 11px 42px;
      border: none;
      border-radius: 12px;
      font-size: 14px;
      background: rgba(255,255,255,0.1);
      color: #fff;
      outline: none;
      transition: background 0.2s;
    }

    .search-input::placeholder { color: #888; }
    .search-input:focus { background: rgba(255,255,255,0.15); }

    /* ── Filter tabs ── */
    .filter-bar {
      background: #fff;
      border-bottom: 1px solid #f0ece8;
      padding: 0 0;
      position: sticky;
      top: 66px;
      z-index: 100;
    }

    .filter-tabs {
      display: flex;
      gap: 4px;
      padding: 12px 0;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .filter-tabs::-webkit-scrollbar { display: none; }

    .filter-tab {
      flex-shrink: 0;
      padding: 7px 18px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 500;
      border: 1px solid #e8e2dc;
      background: transparent;
      color: #666;
      cursor: pointer;
      transition: all 0.15s;
      white-space: nowrap;
    }

    .filter-tab:hover { border-color: #D85A30; color: #D85A30; }

    .filter-tab.active {
      background: #D85A30;
      border-color: #D85A30;
      color: #fff;
    }

    /* ── Section titles ── */
    .section-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #D85A30;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #f0ece8;
    }

    .section-title {
      font-size: 20px;
      font-weight: 700;
      color: #1a1a1a;
      margin-bottom: 4px;
    }

    /* ── Food cards ── */
    .food-card {
      background: #fff;
      border-radius: 16px;
      border: 1px solid #f0ece8;
      overflow: hidden;
      transition: transform 0.15s, box-shadow 0.15s;
      height: 100%;
    }

    .food-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    }

    .food-card .food-img {
      width: 100%;
      height: 180px;
      object-fit: cover;
      display: block;
    }

    .food-card .card-body {
      padding: 16px;
    }

    .food-card .food-name {
      font-size: 15px;
      font-weight: 600;
      color: #1a1a1a;
      margin-bottom: 4px;
    }

    .food-card .food-desc {
      font-size: 12px;
      color: #9e9e9e;
      margin-bottom: 10px;
      line-height: 1.5;
      min-height: 36px;
    }

    .food-card .food-price {
      font-size: 16px;
      font-weight: 700;
      color: #D85A30;
      margin-bottom: 14px;
    }

    /* ── Quantity control ── */
    .qty-control {
      display: flex;
      align-items: center;
      border: 1px solid #e8e2dc;
      border-radius: 10px;
      overflow: hidden;
      width: fit-content;
      margin-bottom: 10px;
    }

    .qty-btn {
      width: 34px;
      height: 34px;
      border: none;
      background: #f9f6f3;
      color: #333;
      font-size: 18px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.1s;
      line-height: 1;
    }

    .qty-btn:hover { background: #f0ece8; }

    .qty-value {
      width: 38px;
      text-align: center;
      font-size: 14px;
      font-weight: 600;
      color: #1a1a1a;
      border: none;
      background: #fff;
      pointer-events: none;
    }

    /* ── Note input ── */
    .note-input {
      width: 100%;
      padding: 8px 12px;
      font-size: 12px;
      border: 1px solid #e8e2dc;
      border-radius: 10px;
      background: #faf9f7;
      color: #555;
      margin-bottom: 10px;
      outline: none;
      transition: border-color 0.15s;
    }

    .note-input:focus { border-color: #D85A30; }

    /* ── Add to cart button ── */
    .btn-add-cart {
      width: 100%;
      background: #1a1a1a;
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 10px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
    }

    .btn-add-cart:hover { background: #D85A30; }

    /* ── Empty state ── */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: #aaa;
    }

    .empty-state .empty-icon { font-size: 48px; margin-bottom: 12px; }
    .empty-state p { font-size: 14px; }

    /* ── Hidden for filter ── */
    .food-item.hidden { display: none !important; }
  </style>
</head>

<body>

  <%- include("partials/header", { user: user }) %>

  <!-- Hero -->
  <div class="menu-hero">
    <div class="container">
      <h1>Menu hôm nay 🍜</h1>
      <p>Khám phá các món ăn đặc trưng của chúng tôi</p>
      <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input
          type="text"
          class="search-input"
          id="searchInput"
          placeholder="Tìm món ăn..."
          autocomplete="off"
        >
      </div>
    </div>
  </div>

  <!-- Filter tabs -->
  <div class="filter-bar">
    <div class="container">
      <div class="filter-tabs">
        <button class="filter-tab active" data-filter="all">Tất cả</button>
        <button class="filter-tab" data-filter="food">🍜 Đồ ăn</button>
        <button class="filter-tab" data-filter="drink">🥤 Đồ uống</button>
      </div>
    </div>
  </div>

  <!-- Menu content -->
  <div class="container py-5">

    <!-- Đồ ăn section -->
    <div id="section-food" class="mb-5">
      <div class="section-label">Đồ ăn</div>
      <div class="row g-4" id="grid-food">
        <% foods.forEach(food => { %>
          <div class="col-md-4 col-sm-6 food-item" data-type="food" data-name="<%= food.name.toLowerCase() %>">
            <div class="food-card">
              <img src="<%= food.image %>" class="food-img" alt="<%= food.name %>">
              <div class="card-body">
                <div class="food-name"><%= food.name %></div>
                <div class="food-desc"><%= food.description || '' %></div>
                <div class="food-price"><%= food.price.toLocaleString('vi-VN') %> VNĐ</div>
                <form action="/cart/add/<%= food._id %>" method="POST">
                  <div class="qty-control">
                    <button type="button" class="qty-btn" onclick="changeQty(this, -1)">−</button>
                    <input type="number" name="quantity" class="qty-value" value="1" min="1" readonly>
                    <button type="button" class="qty-btn" onclick="changeQty(this, 1)">+</button>
                  </div>
                  <input type="text" name="note" class="note-input" placeholder="Ghi chú (không bắt buộc)">
                  <button type="submit" class="btn-add-cart">
                    🛒 Thêm vào giỏ
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <div id="empty-food" class="empty-state" style="display:none">
        <div class="empty-icon">🍽️</div>
        <p>Không tìm thấy món ăn phù hợp</p>
      </div>
    </div>

    <hr style="border-color: #f0ece8; margin-bottom: 40px;">

    <!-- Đồ uống section -->
    <div id="section-drink">
      <div class="section-label">Đồ uống</div>
      <div class="row g-4" id="grid-drink">
        <% drinks.forEach(food => { %>
          <div class="col-md-4 col-sm-6 food-item" data-type="drink" data-name="<%= food.name.toLowerCase() %>">
            <div class="food-card">
              <img src="<%= food.image %>" class="food-img" alt="<%= food.name %>">
              <div class="card-body">
                <div class="food-name"><%= food.name %></div>
                <div class="food-desc"><%= food.description || '' %></div>
                <div class="food-price"><%= food.price.toLocaleString('vi-VN') %> VNĐ</div>
                <form action="/cart/add/<%= food._id %>" method="POST">
                  <div class="qty-control">
                    <button type="button" class="qty-btn" onclick="changeQty(this, -1)">−</button>
                    <input type="number" name="quantity" class="qty-value" value="1" min="1" readonly>
                    <button type="button" class="qty-btn" onclick="changeQty(this, 1)">+</button>
                  </div>
                  <input type="text" name="note" class="note-input" placeholder="Ghi chú (không bắt buộc)">
                  <button type="submit" class="btn-add-cart">
                    🛒 Thêm vào giỏ
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <div id="empty-drink" class="empty-state" style="display:none">
        <div class="empty-icon">🥤</div>
        <p>Không tìm thấy đồ uống phù hợp</p>
      </div>
    </div>

  </div>

  <%- include("partials/footer") %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>

  <script>
    // ── Quantity control ──
    function changeQty(btn, delta) {
      const input = btn.parentElement.querySelector('.qty-value');
      const current = parseInt(input.value) || 1;
      const next = Math.max(1, current + delta);
      input.value = next;
    }

    // ── Filter tabs ──
    const filterTabs = document.querySelectorAll('.filter-tab');
    const sectionFood = document.getElementById('section-food');
    const sectionDrink = document.getElementById('section-drink');

    filterTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        filterTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const filter = tab.dataset.filter;
        if (filter === 'all') {
          sectionFood.style.display = '';
          sectionDrink.style.display = '';
        } else if (filter === 'food') {
          sectionFood.style.display = '';
          sectionDrink.style.display = 'none';
        } else {
          sectionFood.style.display = 'none';
          sectionDrink.style.display = '';
        }
        applySearch();
      });
    });

    // ── Search ──
    const searchInput = document.getElementById('searchInput');

    function applySearch() {
      const query = searchInput.value.trim().toLowerCase();
      const activeFilter = document.querySelector('.filter-tab.active').dataset.filter;

      ['food', 'drink'].forEach(type => {
        const section = document.getElementById('section-' + type);
        if (section.style.display === 'none') return;

        const items = section.querySelectorAll('.food-item');
        let visibleCount = 0;

        items.forEach(item => {
          const name = item.dataset.name || '';
          const match = !query || name.includes(query);
          item.classList.toggle('hidden', !match);
          if (match) visibleCount++;
        });

        const emptyEl = document.getElementById('empty-' + type);
        emptyEl.style.display = visibleCount === 0 ? '' : 'none';
      });
    }

    searchInput.addEventListener('input', applySearch);

    // ── Customer notification ──
    async function checkCustomerNotification() {
      try {
        const res = await fetch("/notifications");
        const data = await res.json();
        const bell = document.getElementById("customerBell");
        if (bell) bell.innerText = data.count;
      } catch (e) {}
    }

    setInterval(checkCustomerNotification, 5000);
    checkCustomerNotification();
  </script>

</body>
</html>

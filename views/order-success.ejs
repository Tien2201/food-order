<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đặt món thành công - Đậu Hũ Thúi Nhà Họ La</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Noto+Serif:wght@700&display=swap" rel="stylesheet">
  <style>
    #statusTitle {
      font-family: 'Noto Serif', Georgia, serif;
      font-weight: 700;
    }
  </style>
</head>
<body>

<div class="auth-page" style="min-height:100vh; align-items:flex-start; padding:40px 16px;">
  <div class="auth-card" style="max-width:520px; margin-top:20px;">

    <div class="text-center mb-3" id="statusIcon" style="font-size:56px;">🎉</div>

    <h2 class="text-center" id="statusTitle">Đặt món thành công!</h2>
    <p class="text-center" id="statusDesc">Đơn hàng của bạn đang chờ nhân viên xác nhận.</p>

    <div style="background:#f7f1e3; border-radius:12px; padding:16px; margin:20px 0; font-size:13px; border:1px solid #e3d8bf;">
      <div class="d-flex justify-content-between mb-2">
        <span style="color:#9e9484;">Mã đơn</span>
        <span style="font-family:monospace; color:#1a1410;"><%= order._id %></span>
      </div>
      <div class="d-flex justify-content-between">
        <span style="color:#9e9484;">Tổng tiền</span>
        <strong style="color:#D85A30;"><%= order.totalPrice.toLocaleString('vi-VN') %> VNĐ</strong>
      </div>
    </div>

    <!-- Trạng thái: pending - chờ xác nhận -->
    <div id="state-pending" class="status-box" style="background:#fdf2ee; border:1px solid #f3ddd2; border-radius:12px; padding:16px; text-align:center;">
      <div style="font-size:13px; color:#9a4a1f;">⏳ Đang chờ nhân viên xác nhận đơn hàng...</div>
    </div>

    <!-- Trạng thái: confirmed - hiện QR để khách thanh toán -->
    <div id="state-confirmed" class="status-box" style="display:none;">
      <div style="background:#fdf2ee; border:1px solid #f3ddd2; border-radius:12px; padding:16px; text-align:center; margin-bottom:16px;">
        <div style="font-size:13px; color:#9a4a1f; font-weight:600;">✅ Đơn đã được xác nhận! Vui lòng thanh toán theo mã QR bên dưới.</div>
      </div>

      <% if (qrImage) { %>
        <img src="<%= qrImage %>" alt="QR thanh toán" style="width:100%; max-width:260px; display:block; margin:0 auto 16px; border-radius:12px; border:1px solid #e3d8bf;">
      <% } else { %>
        <div class="empty-state" style="margin-bottom:16px;">
          <p style="font-size:13px;">Quán chưa cập nhật mã QR. Vui lòng liên hệ trực tiếp để thanh toán.</p>
        </div>
      <% } %>

      <form action="/order-payment-proof/<%= order._id %>" method="POST" enctype="multipart/form-data">
        <label class="form-label-custom">Ảnh chứng minh đã chuyển khoản</label>
        <input type="file" name="paymentProof" class="form-input-custom" accept="image/*" required>
        <button type="submit" class="btn-auth mt-2">📤 Gửi ảnh chuyển khoản</button>
      </form>
    </div>

    <!-- Trạng thái: payment_submitted - đã gửi ảnh, chờ xác minh -->
    <div id="state-payment_submitted" class="status-box" style="display:none; background:#fdf2ee; border:1px solid #f3ddd2; border-radius:12px; padding:16px; text-align:center;">
      <div style="font-size:13px; color:#9a4a1f;">📤 Đã gửi ảnh chuyển khoản. Đang chờ nhân viên xác minh...</div>
    </div>

    <!-- Trạng thái: preparing - đang làm món -->
    <div id="state-preparing" class="status-box" style="display:none; background:#f7f1e3; border:1px solid #ddd0b8; border-radius:12px; padding:16px; text-align:center;">
      <div style="font-size:13px; color:#5c4a2a; font-weight:600;">👨‍🍳 Thanh toán đã xác nhận! Quán đang chuẩn bị món cho bạn.</div>
    </div>

    <!-- Trạng thái: delivering - nhân viên đã làm xong, đang giao tới khách -->
    <div id="state-delivering" class="status-box" style="display:none; background:#fdf2ee; border:1px solid #f3ddd2; border-radius:12px; padding:16px; text-align:center;">
      <div style="font-size:13px; color:#9a4a1f; font-weight:600;">🛵 Món ăn đã làm xong và đang được giao đến bạn!</div>
    </div>

    <!-- Trạng thái: delivered / completed - hoàn tất thật, khách đã nhận hàng -->
    <div id="state-delivered" class="status-box" style="display:none; background:#eef6f0; border:1px solid #cfe8d8; border-radius:12px; padding:16px; text-align:center;">
      <div style="font-size:13px; color:#246e48; font-weight:600;">✅ Đơn hàng đã hoàn tất. Cảm ơn bạn đã đặt món!</div>
    </div>

    <a href="/" class="btn-go-back mt-3" style="display:block; text-align:center;">← Quay lại menu</a>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const orderId = "<%= order._id %>";
  const initialStatus = "<%= order.status %>";

  const icons = {
    pending: "⏳",
    confirmed: "💳",
    payment_submitted: "📤",
    preparing: "👨‍🍳",
    delivering: "🛵",
    delivered: "✅",
    completed: "✅",
    cancelled: "❌"
  };

  const titles = {
    pending: "Đặt món thành công!",
    confirmed: "Đơn đã được xác nhận",
    payment_submitted: "Đã gửi ảnh thanh toán",
    preparing: "Đang chuẩn bị món",
    delivering: "Đang giao hàng",
    delivered: "Hoàn tất",
    completed: "Hoàn tất",
    cancelled: "Đơn đã bị hủy"
  };

  const descs = {
    pending: "Đơn hàng của bạn đang chờ nhân viên xác nhận.",
    confirmed: "Vui lòng quét mã QR và gửi ảnh chuyển khoản.",
    payment_submitted: "Đang chờ nhân viên xác minh thanh toán.",
    preparing: "Quán đang chuẩn bị món ăn cho bạn.",
    delivering: "Món ăn đang được giao đến bạn.",
    delivered: "Cảm ơn bạn đã đặt món!",
    completed: "Cảm ơn bạn đã đặt món!",
    cancelled: "Đơn hàng đã bị hủy."
  };

  function renderStatus(status) {
    document.querySelectorAll('.status-box').forEach(el => el.style.display = 'none');

    // "completed" là trạng thái cũ trước khi có "delivered" — đơn cũ trong DB
    // (nếu có) vẫn cần hiển thị đúng là đã hoàn tất, dùng chung khối HTML này.
    const normalizedStatus = status === 'completed' ? 'delivered' : status;

    const box = document.getElementById('state-' + normalizedStatus);
    if (box) box.style.display = '';

    document.getElementById('statusIcon').textContent = icons[status] || '✅';
    document.getElementById('statusTitle').textContent = titles[status] || 'Đặt món thành công!';
    document.getElementById('statusDesc').textContent = descs[status] || '';
  }

  renderStatus(initialStatus);

  // Polling tự động - không cần F5 để thấy trạng thái mới nhất
  let currentStatus = initialStatus;

  async function checkOrderStatus() {
    try {
      const res = await fetch('/order-status/' + orderId);
      const data = await res.json();

      if (data.status && data.status !== currentStatus) {
        currentStatus = data.status;
        renderStatus(currentStatus);
      }

      // Dừng polling khi đơn đã hoàn tất hoặc bị hủy
      if (currentStatus === 'delivered' || currentStatus === 'completed' || currentStatus === 'cancelled') {
        clearInterval(pollTimer);
      }
    } catch (e) {}
  }

  const pollTimer = setInterval(checkOrderStatus, 4000);
</script>

</body>
</html>

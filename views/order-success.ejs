<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đặt món thành công</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-dark px-4">
  <a class="navbar-brand fw-bold" href="/">🍜 Food Order</a>
</nav>

<div class="container py-5">
  <div class="card p-5 mx-auto text-center" style="max-width: 650px;">
    <div class="mb-3" style="font-size: 64px;">✅</div>

    <h1 class="page-title mb-3">Đặt món thành công</h1>

    <p class="text-muted">
      Cảm ơn bạn đã đặt món. Đơn hàng đang chờ nhân viên xác nhận.
    </p>

    <div class="bg-light rounded p-4 text-start my-4">
      <p><strong>Mã đơn:</strong> <%= order._id %></p>
      <p><strong>Trạng thái:</strong> <%= order.status %></p>
      <p><strong>Tổng tiền:</strong> <span class="price"><%= order.totalPrice.toLocaleString() %> VNĐ</span></p>
    </div>

    <% if (order.paymentCode) { %>
      <div class="alert alert-success">
        <h4>Mã thanh toán</h4>
        <h2><%= order.paymentCode %></h2>
        <p class="mb-0">Vui lòng dùng mã này khi thanh toán.</p>
      </div>
    <% } else { %>
      <div class="alert alert-warning">
        Đang chờ nhân viên xác nhận đơn...
      </div>
    <% } %>

    <a href="/" class="btn btn-main mt-3">
      Quay lại menu
    </a>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
<script src="/js/main.js"></script>
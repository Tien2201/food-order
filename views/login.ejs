<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đăng nhập - Đậu Hủ Thúi Nhà Họ La</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Noto+Serif:wght@700&display=swap" rel="stylesheet">
  <style>
    .auth-card {
      animation: authCardIn 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    }

    @keyframes authCardIn {
      from { transform: translateY(16px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    .auth-card h2 {
      font-family: 'Noto Serif', Georgia, serif;
    }

    /* ── Input có icon + toggle mật khẩu ── */
    .input-with-icon {
      position: relative;
    }

    .input-with-icon .form-input-custom {
      padding-left: 40px;
    }

    .input-with-icon .input-icon {
      position: absolute;
      left: 13px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 15px;
      color: #b0a89e;
      pointer-events: none;
    }

    .password-toggle-btn {
      position: absolute;
      right: 6px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      font-size: 18px;
      cursor: pointer;
      padding: 6px 8px;
      color: #9e9484;
      line-height: 1;
    }

    .password-toggle-btn:hover { color: #D85A30; }

    /* ── Validate message dưới mỗi input ── */
    .field-error-msg {
      font-size: 10.5px;
      color: #c0392b;
      margin: 0 0 2px;
      height: 10px;
      visibility: hidden;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .field-error-msg.show { visibility: visible; }

    .form-input-custom.input-invalid {
      border-color: #e0a39c;
      background: #fdf5f3;
    }

    .form-input-custom.input-valid {
      border-color: #b9d9c8;
    }

    /* ── Divider "hoặc" ── */
    .auth-divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 10px 0;
      font-size: 12px;
      color: #b0a89e;
    }

    .auth-divider::before,
    .auth-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #e3d8bf;
    }

    /* ── Nút đăng nhập Google ── */
    .btn-google {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: #fff;
      border: 1px solid #e3d8bf;
      border-radius: 10px;
      padding: 9px;
      font-size: 13.5px;
      font-weight: 500;
      color: #3c3c3c;
      cursor: pointer;
      transition: background 0.15s, box-shadow 0.15s;
      font-family: 'Poppins', sans-serif;
      text-decoration: none;
    }

    .btn-google:hover {
      background: #fafafa;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    .btn-google svg { width: 18px; height: 18px; flex-shrink: 0; }

    /* ── Nút submit có loading state ── */
    .btn-auth {
      position: relative;
    }

    .btn-auth .spinner {
      display: none;
      width: 16px;
      height: 16px;
      border: 2px solid rgba(255,255,255,0.4);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
      margin-right: 8px;
    }

    .btn-auth.loading .spinner { display: inline-block; }
    .btn-auth.loading .btn-text { opacity: 0.85; }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>
</head>
<body>

<div class="auth-page">
  <div class="auth-card">

    <div class="text-center mb-1">
      <img src="/images/logo.jpg" alt="Logo" style="width:42px;height:42px;border-radius:50%;object-fit:cover;border:2px solid #e3d8bf;display:block;margin:0 auto;">
    </div>
    <h2 class="text-center">Chào mừng trở lại 👋</h2>
    <p class="text-center">Đăng nhập để tiếp tục đặt món</p>

    <% if (typeof error !== "undefined") { %>
      <div class="alert alert-danger" id="loginAlert" style="border-radius:10px; font-size:13px;">
        <%= error %>
      </div>
      <script>
        setTimeout(() => {
          const box = document.getElementById("loginAlert");
          if (box) box.style.display = "none";
        }, 3000);
      </script>
    <% } %>

    <!-- Đăng nhập Google: đã kích hoạt route /auth/google ở backend. -->
    <a href="/auth/google" class="btn-google" id="googleLoginBtn">
      <svg viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
      Đăng nhập với Google
    </a>

    <div class="auth-divider">hoặc</div>

    <form action="/login" method="POST" id="loginForm">
      <label class="form-label-custom">Tên đăng nhập hoặc Email</label>
      <div class="input-with-icon">
        <span class="input-icon">👤</span>
        <input type="text" name="loginId" id="loginIdInput" class="form-input-custom" placeholder="Tên đăng nhập hoặc email" required>
      </div>
      <div class="field-error-msg" id="loginIdError">Vui lòng nhập tên đăng nhập hoặc email</div>

      <label class="form-label-custom">Mật khẩu</label>
      <div class="input-with-icon">
        <span class="input-icon">🔒</span>
        <input type="password" name="password" id="passwordInput" class="form-input-custom" placeholder="••••••••" required style="padding-right:42px;">
        <button type="button" class="password-toggle-btn" id="togglePassword" aria-label="Hiện/ẩn mật khẩu">👁️</button>
      </div>
      <div class="field-error-msg" id="passwordError">Vui lòng nhập mật khẩu</div>

      <button type="submit" class="btn-auth" id="loginSubmitBtn">
        <span class="spinner"></span>
        <span class="btn-text">Đăng nhập</span>
      </button>
    </form>

    <p class="text-center auth-bottom-link mb-0">
      Chưa có tài khoản?
      <a href="/register">Đăng ký ngay</a>
    </p>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // ── Toggle hiện/ẩn mật khẩu ──
  const passwordInput = document.getElementById('passwordInput');
  const toggleBtn = document.getElementById('togglePassword');

  toggleBtn.addEventListener('click', () => {
    const isHidden = passwordInput.type === 'password';
    passwordInput.type = isHidden ? 'text' : 'password';
    toggleBtn.textContent = isHidden ? '🙈' : '👁️';
  });

  // ── Validate real-time khi gõ ──
  const loginIdInput = document.getElementById('loginIdInput');
  const loginIdError = document.getElementById('loginIdError');
  const passwordError = document.getElementById('passwordError');

  function validateLoginId() {
    const value = loginIdInput.value.trim();
    const valid = value.length > 0;
    loginIdInput.classList.toggle('input-invalid', !valid && loginIdInput.dataset.touched === 'true');
    loginIdInput.classList.toggle('input-valid', valid);
    loginIdError.classList.toggle('show', !valid && loginIdInput.dataset.touched === 'true');
    return valid;
  }

  function validatePassword() {
    const value = passwordInput.value;
    const valid = value.length > 0;
    passwordInput.classList.toggle('input-invalid', !valid && passwordInput.dataset.touched === 'true');
    passwordError.classList.toggle('show', !valid && passwordInput.dataset.touched === 'true');
    return valid;
  }

  loginIdInput.addEventListener('input', () => {
    loginIdInput.dataset.touched = 'true';
    validateLoginId();
  });
  loginIdInput.addEventListener('blur', () => {
    loginIdInput.dataset.touched = 'true';
    validateLoginId();
  });
  passwordInput.addEventListener('input', () => {
    passwordInput.dataset.touched = 'true';
    validatePassword();
  });

  // ── Loading state khi submit ──
  const loginForm = document.getElementById('loginForm');
  const loginSubmitBtn = document.getElementById('loginSubmitBtn');

  loginForm.addEventListener('submit', (e) => {
    const emailOk = validateLoginId();
    passwordInput.dataset.touched = 'true';
    const passwordOk = validatePassword();

    if (!emailOk || !passwordOk) {
      e.preventDefault();
      return;
    }

    loginSubmitBtn.classList.add('loading');
    loginSubmitBtn.disabled = true;
  });
</script>
</body>
</html>

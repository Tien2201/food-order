<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Đăng nhập</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <div class="auth-page">
        <div class="auth-card">
            <h2 class="text-center mb-2">🍜 Food Order</h2>
            <p class="text-center text-muted mb-4">Đăng nhập để tiếp tục đặt món</p>
            <% if (typeof error !=="undefined" ) { %>
                <div class="alert alert-danger" id="loginAlert">
                    <%= error %>
                </div>

                <script>
                    setTimeout(() => {
                        const alertBox = document.getElementById("loginAlert");
                        if (alertBox) {
                            alertBox.style.display = "none";
                        }
                    }, 1000);
                </script>
                <% } %>
                    <form action="/login" method="POST">
                        <input type="email" name="email" class="form-control mb-3" placeholder="Email" required>

                        <input type="password" name="password" class="form-control mb-3" placeholder="Mật khẩu"
                            required>

                        <button class="btn btn-main w-100">
                            Đăng nhập
                        </button>
                    </form>

                    <p class="text-center mt-3 mb-0">
                        Chưa có tài khoản?
                        <a href="/register">Đăng ký ngay</a>
                    </p>
        </div>
    </div>

</body>

</html>
<script src="/js/main.js"></script>
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tra cứu đơn hàng - Đậu Hũ Thúi Nhà Họ La</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<%- include("partials/header", { user: user }) %>

<div class="cart-hero">
  <div class="container">
    <h1>🔍 Tra cứu đơn hàng</h1>
    <p>Nhập số điện thoại đã dùng khi đặt món để xem lại đơn hàng của bạn</p>
  </div>
</div>

<div class="container py-5">

  <!-- Form tra cứu -->
  <div class="summary-card" style="max-width:480px; margin: 0 auto 32px;">
    <form action="/track-order" method="POST">
      <label class="form-label-custom">Số điện thoại</label>
      <input
        name="phone"
        class="form-input-custom"
        type="tel"
        placeholder="VD: 0901 234 567"
        value="<%= phone %>"
        required
        autofocus
      >
      <button type="submit" class="btn-order">🔍 Tra cứu</button>
    </form>
  </div>

  <% if (orders !== null) { %>

    <% if (orders.length === 0) { %>
      <div class="empty-cart-card">
        <div style="font-size:56px; margin-bottom:16px;">📭</div>
        <h3 style="font-size:20px; font-weight:600; color:#1a1a1a; margin-bottom:8px;">Không tìm thấy đơn hàng nào</h3>
        <p style="color:#9ca3af; font-size:14px;">Kiểm tra lại số điện thoại bạn đã dùng khi đặt món.</p>
      </div>
    <% } else { %>

      <div class="cart-section-title">Kết quả tra cứu (<%= orders.length %> đơn)</div>

      <% orders.forEach(order => { %>
        <div class="cart-item-card" style="flex-direction:column; align-items:stretch; gap:12px;">

          <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
              <div style="font-size:13px; color:#9ca3af;">Mã đơn: <span style="font-family:monospace"><%= order._id %></span></div>
              <div style="font-size:13px; color:#9ca3af;">Ngày đặt: <%= order.createdAt.toLocaleDateString('vi-VN') %></div>
              <div style="font-size:13px; color:#9ca3af;">Người nhận: <%= order.customerName %> — <%= order.address %></div>
            </div>
            <div>
              <% if (order.paymentCode) { %>
                <span class="badge-confirmed">✅ <%= order.status %></span>
              <% } else { %>
                <span class="badge-pending">⏳ <%= order.status %></span>
              <% } %>
            </div>
          </div>

          <div style="border-top:1px solid #f0ece8; padding-top:12px;">
            <% order.items.forEach(item => { %>
              <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                <div>
                  <span style="font-weight:600; color:#1a1a1a;"><%= item.name %></span>
                  <span style="color:#9ca3af; font-size:12px;"> x<%= item.quantity %></span>
                  <% if (item.note) { %>
                    <div style="font-size:12px; color:#9ca3af;">📝 <%= item.note %></div>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>

          <div class="d-flex justify-content-between align-items-center">
            <a href="/order-status/<%= order._id %>" style="font-size:13px; color:#D85A30; font-weight:600; text-decoration:none;">
              📍 Xem trạng thái chi tiết →
            </a>
            <div style="text-align:right; font-weight:700; color:#D85A30; font-size:15px;">
              Tổng: <%= order.totalPrice.toLocaleString('vi-VN') %> VNĐ
            </div>
          </div>

        </div>
      <% }) %>

    <% } %>

  <% } %>

</div>

<%- include("partials/footer") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý Thảo luận</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="d-flex">

<div class="admin-overlay" id="adminOverlay" onclick="closeSidebar()"></div>

  <%- include("partials/sidebar", { user, activePage: "discussions" }) %>

  <!-- MAIN CONTENT -->
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-2">
        <button class="admin-hamburger" onclick="openSidebar()">☰</button>
        <div>
          <div class="admin-topbar-title">💬 Quản lý Thảo luận</div>
          <div class="admin-topbar-sub">Duyệt bài feedback của khách trước khi hiện công khai</div>
        </div>
      </div>
    </div>

    <div class="admin-content">

      <%
        const pendingPosts = posts.filter(p => p.status === 'pending');
        const reviewedPosts = posts.filter(p => p.status !== 'pending');
      %>

      <div class="stats-row">
        <div class="stat-pill">
          <strong><%= pendingPosts.length %></strong>
          Chờ duyệt
        </div>
        <div class="stat-pill">
          <strong><%= posts.filter(p => p.status === 'approved').length %></strong>
          Đã duyệt
        </div>
        <div class="stat-pill">
          <strong><%= posts.filter(p => p.status === 'rejected').length %></strong>
          Đã từ chối
        </div>
      </div>

      <% if (pendingPosts.length > 0) { %>
        <div class="section-label" style="margin-top:24px;">Chờ duyệt</div>
        <% pendingPosts.forEach(post => { %>
          <div class="discussion-admin-card">
            <div class="discussion-admin-header">
              <strong><%= post.user ? post.user.fullname : 'Khách' %></strong>
              <span style="color:#9ca3af; font-size:12px;"><%= post.user ? post.user.email : '' %> · <%= new Date(post.createdAt).toLocaleString('vi-VN') %></span>
            </div>
            <div class="discussion-admin-content"><%= post.content %></div>
            <% if (post.images && post.images.length > 0) { %>
              <div class="discussion-admin-images">
                <% post.images.forEach(img => { %>
                  <img src="<%= img %>" alt="Ảnh">
                <% }) %>
              </div>
            <% } %>
            <div class="discussion-admin-actions">
              <form action="/admin/discussions/approve/<%= post._id %>" method="POST" style="display:inline;">
                <button type="submit" class="btn-confirm" style="background:#2f8a5c;">✅ Duyệt</button>
              </form>
              <form action="/admin/discussions/reject/<%= post._id %>" method="POST" style="display:inline;">
                <button type="submit" class="btn-confirm" style="background:#c0392b;">❌ Từ chối</button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } %>

      <div class="section-label" style="margin-top:24px;">Đã xử lý</div>
      <% if (reviewedPosts.length === 0) { %>
        <div class="empty-state"><p>Chưa có bài nào được xử lý.</p></div>
      <% } else { %>
        <% reviewedPosts.forEach(post => { %>
          <div class="discussion-admin-card">
            <div class="discussion-admin-header">
              <strong><%= post.user ? post.user.fullname : 'Khách' %></strong>
              <span class="<%= post.status === 'approved' ? 'badge-confirmed' : 'badge-pending' %>">
                <%= post.status === 'approved' ? '✅ Đã duyệt' : '❌ Đã từ chối' %>
              </span>
            </div>
            <div class="discussion-admin-content"><%= post.content %></div>
            <% if (post.images && post.images.length > 0) { %>
              <div class="discussion-admin-images">
                <% post.images.forEach(img => { %>
                  <img src="<%= img %>" alt="Ảnh">
                <% }) %>
              </div>
            <% } %>
            <div class="discussion-admin-actions">
              <form action="/admin/discussions/delete/<%= post._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Xóa vĩnh viễn bài đăng này?');">
                <button type="submit" class="btn-delete-order">🗑️ Xóa</button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } %>

    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function openSidebar() {
    document.getElementById('adminSidebar').classList.add('open');
    document.getElementById('adminOverlay').classList.add('show');
  }
  function closeSidebar() {
    document.getElementById('adminSidebar').classList.remove('open');
    document.getElementById('adminOverlay').classList.remove('show');
  }
</script>
</body>
</html>

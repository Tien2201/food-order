<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý đơn hàng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

  <div class="d-flex">

    <div class="admin-overlay" id="adminOverlay" onclick="closeSidebar()"></div>

    <!-- SIDEBAR -->
    <div class="admin-sidebar" id="adminSidebar">
      <div class="sidebar-brand">
        <div class="sidebar-brand-icon">🍜</div>
        <div>
          <div class="sidebar-brand-text">Food Order</div>
          <div class="sidebar-brand-sub">Admin Panel</div>
        </div>
      </div>

      <div class="sidebar-section-label">Tổng quan</div>
      <a href="/admin/dashboard" class="sidebar-link ">
        <span class="icon">📊</span> Dashboard
      </a>
      <a href="/admin/statistics" class="sidebar-link ">
        <span class="icon">📈</span> Thống kê
      </a>

      <div class="sidebar-section-label">Quản lý</div>

      <a href="/admin/foods" class="sidebar-link ">
        <span class="icon">🍽️</span> Món ăn
      </a>
      <a href="/admin/orders" class="sidebar-link active">
        <span class="icon">📋</span> Đơn hàng
      </a>
      <a href="/admin/users" class="sidebar-link ">
        <span class="icon">👥</span> Tài khoản
      </a>
      <a href="/admin/settings/qr"
        class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'settings-qr' ? 'active' : '' %>">
        <span class="icon">💳</span> QR thanh toán
      </a>
      <div class="sidebar-footer">
        <div class="sidebar-user">
          <div class="sidebar-avatar">
            <%= user ? user.fullname.charAt(0).toUpperCase() : 'A' %>
          </div>
          <div>
            <div class="sidebar-user-name">
              <%= user ? user.fullname : 'Admin' %>
            </div>
            <div class="sidebar-user-role">Administrator</div>
          </div>
        </div>
        <a href="/logout" class="btn-logout-sidebar">
          <span class="icon">🚪</span> Đăng xuất
        </a>
      </div>
    </div>

    <div class="admin-main">
      <div class="admin-topbar">
        <div class="d-flex align-items-center gap-2">
          <button class="admin-hamburger" onclick="openSidebar()">☰</button>
          <div>
            <div class="admin-topbar-title">📋 Quản lý đơn hàng</div>
            <div class="admin-topbar-sub">Danh sách tất cả đơn hàng của khách</div>
          </div>
        </div>
      </div>

      <div class="admin-content">

        <!-- Stats pills -->
        <div class="stats-row">
          <div class="stat-pill">
            <strong>
              <%= orders.length %>
            </strong>
            Tổng đơn
          </div>
          <div class="stat-pill">
            <strong>
              <%= orders.filter(o=> !o.paymentCode).length %>
            </strong>
            Chờ xác nhận
          </div>
          <div class="stat-pill">
            <strong>
              <%= orders.filter(o=> o.paymentCode).length %>
            </strong>
            Đã xác nhận
          </div>
          <div class="stat-pill">
            <strong>
              <%= orders.reduce((s,o)=> s + o.totalPrice, 0).toLocaleString('vi-VN') %> VNĐ
            </strong>
            Tổng doanh thu
          </div>
        </div>

        <!-- Filter -->
        <div class="filter-bar">
          <button class="filter-btn active" onclick="filterOrders('all', this)">Tất cả</button>
          <button class="filter-btn" onclick="filterOrders('pending', this)">⏳ Chờ xác nhận</button>
          <button class="filter-btn" onclick="filterOrders('confirmed', this)">✅ Đã xác nhận</button>
        </div>

        <!-- Table -->
        <% if (orders.length===0) { %>
          <div class="empty-state">
            <div style="font-size:48px; margin-bottom:12px;">📋</div>
            <p>Chưa có đơn hàng nào.</p>
          </div>
          <% } else { %>
            <div class="table-card">
              <table>
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Khách hàng</th>
                    <th>SĐT</th>
                    <th>Địa chỉ</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Mã thanh toán</th>
                    <th>Thao tác</th>
                  </tr>
                </thead>
                <tbody id="orderTable">
                  <% orders.forEach((order, i)=> { %>
                    <tr data-status="<%= order.paymentCode ? 'confirmed' : 'pending' %>">
                      <td style="color:#9ca3af">
                        <%= i + 1 %>
                      </td>
                      <td><span class="customer-name">
                          <%= order.customerName %>
                        </span></td>
                      <td>
                        <%= order.phone %>
                      </td>
                      <td style="max-width:160px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                        <%= order.address || '—' %>
                      </td>
                      <td><span class="total-price">
                          <%= order.totalPrice.toLocaleString('vi-VN') %> VNĐ
                        </span></td>
                      <td>
                        <% if (order.paymentCode) { %>
                          <span class="badge-confirmed">✅ Đã xác nhận</span>
                          <% } else { %>
                            <span class="badge-pending">⏳ Đơn mới</span>
                            <% } %>
                      </td>
                      <td><span class="payment-code">
                          <%= order.paymentCode || '—' %>
                        </span></td>
                      <td><a href="/admin/orders/edit/<%= order._id %>" class="btn-detail">Chi tiết</a></td>
                    </tr>
                    <% }) %>
                </tbody>
              </table>
            </div>
            <% } %>

      </div>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function openSidebar() {
      document.getElementById('adminSidebar').classList.add('open');
      document.getElementById('adminOverlay').classList.add('show');
    }
    function closeSidebar() {
      document.getElementById('adminSidebar').classList.remove('open');
      document.getElementById('adminOverlay').classList.remove('show');
    }
  </script>
</body>

</html>
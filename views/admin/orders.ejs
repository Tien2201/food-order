<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Admin - Đơn hàng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="d-flex">
  <div class="admin-sidebar p-4" style="width:260px;">
    <h3 class="text-white mb-4">Admin</h3>
    <a href="/admin/dashboard">Dashboard</a>
    <a href="/admin/foods">Quản lý món ăn</a>
    <a href="/admin/orders">Quản lý đơn hàng</a>
    <a href="/admin/users">Quản lý tài khoản</a>
    <a href="/logout">Đăng xuất</a>
  </div>

  <div class="flex-grow-1 p-5">
    <h1 class="page-title mb-4">Quản lý đơn hàng</h1>

    <% if (orders.length === 0) { %>
      <div class="alert alert-info">Chưa có đơn hàng nào.</div>
    <% } %>

    <% orders.forEach(order => { %>
      <div class="card p-4 mb-4">
        <div class="d-flex justify-content-between">
          <div>
            <h4><%= order.customerName %></h4>
            <p class="text-muted mb-1">SĐT: <%= order.phone %></p>
            <p class="text-muted">Địa chỉ: <%= order.address %></p>
          </div>

          <div>
            <% if (order.paymentCode) { %>
              <span class="badge bg-success">Đã xác nhận</span>
            <% } else { %>
              <span class="badge bg-warning text-dark">Chờ xác nhận</span>
            <% } %>
          </div>
        </div>

        <hr>

        <h5>Món đã đặt</h5>

        <% order.items.forEach(item => { %>
          <div class="bg-light rounded p-2 mb-2">
            <strong><%= item.name %></strong>
            |
            SL: <%= item.quantity %>
            |
            Ghi chú: <%= item.note || "Không có" %>
          </div>
        <% }) %>

        <hr>

        <p><strong>Trạng thái:</strong> <%= order.status %></p>
        <p><strong>Mã thanh toán:</strong> <%= order.paymentCode || "Chưa có" %></p>

        <% if (order.confirmedBy) { %>
          <p><strong>Nhân viên xác nhận:</strong> <%= order.confirmedBy.fullname %></p>
        <% } %>

        <h4 class="price">
          Tổng: <%= order.totalPrice.toLocaleString() %> VNĐ
        </h4>
      </div>
    <% }) %>
  </div>
</div>

</body>
</html>
<script src="/js/main.js"></script>
<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý món ăn</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

  <div class="d-flex">

    <div class="admin-overlay" id="adminOverlay" onclick="closeSidebar()"></div>

    <!-- SIDEBAR -->
    <div class="admin-sidebar" id="adminSidebar">
      <div class="sidebar-brand">
        <div class="sidebar-brand-icon">🍜</div>
        <div>
          <div class="sidebar-brand-text">Food Order</div>
          <div class="sidebar-brand-sub">Admin Panel</div>
        </div>
      </div>

      <div class="sidebar-section-label">Tổng quan</div>
      <a href="/admin/dashboard" class="sidebar-link">
        <span class="icon">📊</span> Dashboard
      </a>
      <a href="/admin/statistics" class="sidebar-link">
        <span class="icon">📈</span> Thống kê
      </a>

      <div class="sidebar-section-label">Quản lý</div>

      <a href="/admin/foods" class="sidebar-link active">
        <span class="icon">🍽️</span> Món ăn
      </a>
      <a href="/admin/orders" class="sidebar-link">
        <span class="icon">📋</span> Đơn hàng
      </a>
      <a href="/admin/users" class="sidebar-link">
        <span class="icon">👥</span> Tài khoản
      </a>
      <a href="/admin/settings/qr"
        class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'settings-qr' ? 'active' : '' %>">
        <span class="icon">💳</span> QR thanh toán
      </a>
      <div class="sidebar-footer">
        <div class="sidebar-user">
          <div class="sidebar-avatar">
            <%= user ? user.fullname.charAt(0).toUpperCase() : 'A' %>
          </div>
          <div>
            <div class="sidebar-user-name">
              <%= user ? user.fullname : 'Admin' %>
            </div>
            <div class="sidebar-user-role">Administrator</div>
          </div>
        </div>
        <a href="/logout" class="btn-logout-sidebar">
          <span class="icon">🚪</span> Đăng xuất
        </a>
      </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="admin-main">
      <div class="admin-topbar">
        <div class="d-flex align-items-center gap-2">
          <button class="admin-hamburger" onclick="openSidebar()">☰</button>
          <div>
            <div class="admin-topbar-title">🍽️ Quản lý món ăn</div>
            <div class="admin-topbar-sub">Thêm, sửa, xóa món trong thực đơn</div>
          </div>
        </div>
        <span class="food-count-badge">
          <%= foods.length %> món
        </span>
      </div>

      <div class="admin-content">

        <!-- Form thêm món -->
        <div class="form-card">
          <div class="form-card-title">➕ Thêm món mới</div>
          <form action="/admin/foods/add" method="POST" enctype="multipart/form-data">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label-custom">Tên món</label>
                <input type="text" name="name" class="form-input-custom" placeholder="VD: Mắm cá chua" required>
              </div>
              <div class="col-md-6">
                <label class="form-label-custom">Giá (VNĐ)</label>
                <input type="number" name="price" class="form-input-custom" placeholder="VD: 42000" required>
              </div>
              <div class="col-md-6">
                <label class="form-label-custom">Mô tả</label>
                <input type="text" name="description" class="form-input-custom" placeholder="Mô tả ngắn về món ăn">
              </div>
              <div class="col-md-3">
                <label class="form-label-custom">Danh mục</label>
                <select name="category" class="form-input-custom" required>
                  <option value="food">🍜 Đồ ăn</option>
                  <option value="drink">🥤 Đồ uống</option>
                </select>
              </div>
              <div class="col-md-3">
                <label class="form-label-custom">Độ cay</label>
                <select name="spiceLevel" class="form-input-custom" required>
                  <option value="non-spicy">🟢 Không cay</option>
                  <option value="spicy">🌶️ Cay</option>
                </select>
              </div>
              <div class="col-md-3">
                <label class="form-label-custom">Loại nước</label>
                <select name="soupType" class="form-input-custom" required>
                  <option value="dry">🍲 Khô</option>
                  <option value="soup">🍜 Soup</option>
                </select>
              </div>
              <div class="col-md-3">
                <label class="form-label-custom">Hình ảnh</label>
                <input type="file" name="image" class="form-input-custom" accept="image/*" required>
              </div>
              <div class="col-12">
                <label class="form-label-custom">Gia vị / Thành phần (khách có thể chọn "Không [gia vị]")</label>
                <div class="ingredient-input-row">
                  <input type="text" id="ingredientInput" class="form-input-custom" placeholder="VD: Hành, Tỏi phi... rồi bấm Add">
                  <button type="button" class="btn-add-ingredient" onclick="addIngredient('ingredientInput', 'ingredientList')">+ Add gia vị</button>
                </div>
                <div class="ingredient-tag-list" id="ingredientList" data-tags="[]"></div>
                <div class="option-group-hint">Lưu ý: Tùy chọn "Soup chung/riêng" tự hiện khi Loại nước = Soup, không cần thêm ở đây.</div>
              </div>
              <div class="col-12">
                <button type="submit" class="btn-add">➕ Thêm món</button>
              </div>
            </div>
          </form>
        </div>

        <!-- Danh sách món -->
        <div class="section-label">Danh sách món ăn</div>

        <% if (foods.length===0) { %>
          <div class="empty-state">
            <div style="font-size:48px; margin-bottom:12px;">🍽️</div>
            <p>Chưa có món ăn nào. Hãy thêm món mới!</p>
          </div>
          <% } else { %>
            <div class="row g-3">
              <% foods.forEach(food=> { %>
                <div class="col-xl-3 col-md-4 col-sm-6">
                  <div class="food-card">
                    <img src="<%= food.image %>" alt="<%= food.name %>"
                      style="width:100%;height:160px;object-fit:cover;" onerror="this.src='/images/background.jpg'">
                    <div class="food-card-body">
                      <div class="food-card-name">
                        <%= food.name %>
                      </div>
                      <div class="food-card-desc">
                        <%= food.description || 'Chưa có mô tả' %>
                      </div>
                      <div class="food-card-price">
                        <%= food.price.toLocaleString('vi-VN') %> VNĐ
                      </div>
                      <% if (food.category==='drink' ) { %>
                        <span class="badge-drink">🥤 Đồ uống</span>
                        <% } else { %>
                          <span class="badge-food">🍜 Đồ ăn</span>
                          <% } %>
                            <div class="food-actions">
                              <a href="/admin/foods/edit/<%= food._id %>" class="btn-edit">✏️ Sửa</a>
                              <form action="/admin/foods/delete/<%= food._id %>" method="POST"
                                onsubmit="return confirm('Xóa món này?')" style="flex:1">
                                <button type="submit" class="btn-delete" style="width:100%">🗑 Xóa</button>
                              </form>
                            </div>
                    </div>
                  </div>
                </div>
                <% }) %>
            </div>
            <% } %>

      </div>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function openSidebar() {
      document.getElementById('adminSidebar').classList.add('open');
      document.getElementById('adminOverlay').classList.add('show');
    }
    function closeSidebar() {
      document.getElementById('adminSidebar').classList.remove('open');
      document.getElementById('adminOverlay').classList.remove('show');
    }

    // ── Tag input gia vị: thêm / xóa / đồng bộ hidden input để submit ──
    function renderIngredientTags(listId) {
      const listEl = document.getElementById(listId);
      const tags = JSON.parse(listEl.dataset.tags || '[]');

      listEl.innerHTML = '';
      tags.forEach((tag, i) => {
        const chip = document.createElement('span');
        chip.className = 'ingredient-tag';
        chip.innerHTML = `${tag} <button type="button" onclick="removeIngredient('${listId}', ${i})">&times;</button>
          <input type="hidden" name="ingredients" value="${tag.replace(/"/g, '&quot;')}">`;
        listEl.appendChild(chip);
      });
    }

    function addIngredient(inputId, listId) {
      const input = document.getElementById(inputId);
      const value = input.value.trim();
      if (!value) return;

      const listEl = document.getElementById(listId);
      const tags = JSON.parse(listEl.dataset.tags || '[]');

      if (!tags.includes(value)) {
        tags.push(value);
        listEl.dataset.tags = JSON.stringify(tags);
        renderIngredientTags(listId);
      }
      input.value = '';
      input.focus();
    }

    function removeIngredient(listId, index) {
      const listEl = document.getElementById(listId);
      const tags = JSON.parse(listEl.dataset.tags || '[]');
      tags.splice(index, 1);
      listEl.dataset.tags = JSON.stringify(tags);
      renderIngredientTags(listId);
    }

    // Cho phép bấm Enter để add gia vị thay vì phải bấm nút
    document.getElementById('ingredientInput')?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        addIngredient('ingredientInput', 'ingredientList');
      }
    });
  </script>
</body>

</html>
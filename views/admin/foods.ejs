<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Quản lý món ăn</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <div class="d-flex">
        <div class="admin-sidebar p-4" style="width:260px;">
            <h3 class="text-white mb-4">Admin</h3>
            <a href="/admin/dashboard">Dashboard</a>
            <a href="/admin/foods">Quản lý món ăn</a>
            <a href="/admin/orders">Quản lý đơn hàng</a>
            <a href="/admin/users">Quản lý tài khoản</a>
            <a href="/logout">Đăng xuất</a>
        </div>

        <div class="flex-grow-1 p-5">
            <h1 class="page-title mb-4">Quản lý món ăn</h1>

            <div class="card p-4 mb-4">
                <h4>Thêm món mới</h4>

                <form action="/admin/foods/add" method="POST" enctype="multipart/form-data">
                    <div class="col-md-6">
                        <input type="text" name="name" class="form-control" placeholder="Tên món" required>
                    </div>

                    <div class="col-md-6">
                        <input type="number" name="price" class="form-control" placeholder="Giá" required>
                    </div>

                    <div class="col-md-6">
                        <input type="text" name="description" class="form-control" placeholder="Mô tả">
                    </div>

                    <div class="col-md-6">
                        <input type="file" name="image" class="form-control" accept="image/*" required>
                    </div>

                    <div class="col-12">
                        <button class="btn btn-main">Thêm món</button>
                    </div>
                </form>
            </div>

            <div class="row g-4">
                <% foods.forEach(food=> { %>
                    <div class="col-md-4">
                        <div class="card h-100">
                            <img src="<%= food.image %>" class="food-img" alt="<%= food.name %>">

                            <div class="card-body">
                                <h4>
                                    <%= food.name %>
                                </h4>
                                <p class="text-muted">
                                    <%= food.description %>
                                </p>
                                <p class="price">
                                    <%= food.price.toLocaleString() %> VNĐ
                                </p>

                                <a href="/admin/foods/edit/<%= food._id %>" class="btn btn-warning w-100 mb-2">
                                    Sửa món
                                </a>

                                <form action="/admin/foods/delete/<%= food._id %>" method="POST"
                                    onsubmit="return confirm('Bạn có chắc muốn xóa món này?')">
                                    <button class="btn btn-danger w-100">Xóa món</button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>
    </div>

</body>

</html>
<script src="/js/main.js"></script>
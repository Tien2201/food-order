<% if (foodStats.length === 0) { %>
  <div class="empty-state">
    <div style="font-size:40px; margin-bottom:8px;">📊</div>
    <p>Chưa có dữ liệu bán hàng trong khoảng thời gian này.</p>
  </div>
<% } else { %>
  <div class="table-card">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Tên món</th>
          <th>Số lượng bán</th>
          <th>Doanh thu</th>
        </tr>
      </thead>
      <tbody>
        <% foodStats.forEach((item, index) => { %>
          <tr>
            <td><%= index + 1 %></td>
            <td><strong style="color:#111827"><%= item._id %></strong></td>
            <td><%= item.totalQuantity %></td>
            <td style="color:#D85A30; font-weight:700;"><%= item.totalMoney.toLocaleString('vi-VN') %> VNĐ</td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <title>Admin - Tài khoản</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

  <div class="d-flex">
    <div class="admin-sidebar p-4" style="width:260px;">
      <h3 class="text-white mb-4">Admin</h3>
      <a href="/admin/dashboard">Dashboard</a>
      <a href="/admin/foods">Quản lý món ăn</a>
      <a href="/admin/orders">Quản lý đơn hàng</a>
      <a href="/admin/users">Quản lý tài khoản</a>
      <a href="/admin/statistics">Thống kê</a>
      <a href="/logout">Đăng xuất</a>
    </div>

    <div class="flex-grow-1 p-5">
      <h1 class="page-title mb-4">Quản lý tài khoản</h1>

      <div class="card p-4">
        <table class="table table-hover align-middle">
          <thead>
            <tr>
              <th>Họ tên</th>
              <th>Email</th>
              <th>Quyền hiện tại</th>
              <th>Đổi quyền</th>
              <th>Ngày tạo</th>
              <th>Đổi mật khẩu</th>
            </tr>
          </thead>

          <tbody>
            <% users.forEach(user=> { %>
              <tr>
                <td>
                  <%= user.fullname %>
                </td>
                <td>
                  <%= user.email %>
                </td>
                <td>
                  <form action="/admin/users/password/request/<%= user._id %>" method="POST" class="d-flex gap-2">
                    <input type="password" name="password" class="form-control" placeholder="Mật khẩu mới" required>

                    <button class="btn btn-warning">
                      Đổi
                    </button>

                  </form>
                </td>
                <td>
                  <% if (user.role==="admin" ) { %>
                    <span class="badge bg-danger">Admin</span>
                    <% } else if (user.role==="staff" ) { %>
                      <span class="badge bg-primary">Nhân viên</span>
                      <% } else { %>
                        <span class="badge bg-secondary">Khách hàng</span>
                        <% } %>
                </td>

                <td>
                  <form action="/admin/users/role/<%= user._id %>" method="POST" class="d-flex gap-2">
                    <select name="role" class="form-select">
                      <option value="customer" <%=user.role==="customer" ? "selected" : "" %>>Khách hàng</option>
                      <option value="staff" <%=user.role==="staff" ? "selected" : "" %>>Nhân viên</option>
                      <option value="admin" <%=user.role==="admin" ? "selected" : "" %>>Admin</option>
                    </select>

                    <button class="btn btn-main">
                      Lưu
                    </button>
                  </form>
                </td>

                <td>
                  <%= user.createdAt ? user.createdAt.toLocaleString() : "" %>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</body>

</html>
<script src="/js/main.js"></script>
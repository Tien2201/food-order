<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý tài khoản</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="d-flex">

<div class="admin-overlay" id="adminOverlay" onclick="closeSidebar()"></div>

  <!-- SIDEBAR -->
  <div class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-brand">
      <div class="sidebar-brand-icon">🍜</div>
      <div>
        <div class="sidebar-brand-text">Food Order</div>
        <div class="sidebar-brand-sub">Admin Panel</div>
      </div>
    </div>

    <div class="sidebar-section-label">Tổng quan</div>
    <a href="/admin/dashboard" class="sidebar-link ">
      <span class="icon">📊</span> Dashboard
    </a>
    <a href="/admin/statistics" class="sidebar-link ">
      <span class="icon">📈</span> Thống kê
    </a>

    <div class="sidebar-section-label">Quản lý</div>
    <a href="/admin/foods" class="sidebar-link ">
      <span class="icon">🍽️</span> Món ăn
    </a>
    <a href="/admin/orders" class="sidebar-link ">
      <span class="icon">📋</span> Đơn hàng
    </a>
    <a href="/admin/users" class="sidebar-link active">
      <span class="icon">👥</span> Tài khoản
    </a>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="sidebar-avatar">
          <%= user ? user.fullname.charAt(0).toUpperCase() : 'A' %>
        </div>
        <div>
          <div class="sidebar-user-name"><%= user ? user.fullname : 'Admin' %></div>
          <div class="sidebar-user-role">Administrator</div>
        </div>
      </div>
      <a href="/logout" class="btn-logout-sidebar">
        <span class="icon">🚪</span> Đăng xuất
      </a>
    </div>
  </div>

<div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-2">
        <button class="admin-hamburger" onclick="openSidebar()">☰</button>
        <div>
        <div class="admin-topbar-title">👥 Quản lý tài khoản</div>
        <div class="admin-topbar-sub">Phân quyền và quản lý người dùng</div>
      </div>
      </div>
      <span class="user-count-badge"><%= users.length %> tài khoản</span>
    </div>

    <div class="admin-content">
      <div class="table-card">
        <table>
          <thead>
            <tr>
              <th>Người dùng</th>
              <th>Quyền hiện tại</th>
              <th>Ngày tạo</th>
              <th>Đổi quyền</th>
              <th>Đổi mật khẩu</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(u => { %>
              <tr>
                <td>
                  <div class="d-flex align-items-center">
                    <div class="user-avatar"><%= u.fullname.charAt(0).toUpperCase() %></div>
                    <div>
                      <div class="user-name"><%= u.fullname %></div>
                      <div class="user-email"><%= u.email %></div>
                    </div>
                  </div>
                </td>
                <td>
                  <% if (u.role === 'admin') { %>
                    <span class="badge-admin">👑 Admin</span>
                  <% } else if (u.role === 'staff') { %>
                    <span class="badge-staff">🧑‍💼 Nhân viên</span>
                  <% } else { %>
                    <span class="badge-customer">👤 Khách hàng</span>
                  <% } %>
                </td>
                <td style="color:#9ca3af; font-size:12px">
                  <%= u.createdAt ? u.createdAt.toLocaleDateString('vi-VN') : '—' %>
                </td>
                <td>
                  <form action="/admin/users/role/<%= u._id %>" method="POST" class="d-flex gap-2 align-items-center">
                    <select name="role" class="form-select-custom">
                      <option value="customer" <%= u.role === 'customer' ? 'selected' : '' %>>Khách hàng</option>
                      <option value="staff" <%= u.role === 'staff' ? 'selected' : '' %>>Nhân viên</option>
                      <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                    </select>
                    <button type="submit" class="btn-sm-save">Lưu</button>
                  </form>
                </td>
                <td>
                  <form action="/admin/users/password/request/<%= u._id %>" method="POST" class="d-flex gap-2 align-items-center">
                    <input type="password" name="password" class="form-input-pw" placeholder="Mật khẩu mới" required>
                    <button type="submit" class="btn-sm-pw">Đổi</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function openSidebar() {
    document.getElementById('adminSidebar').classList.add('open');
    document.getElementById('adminOverlay').classList.add('show');
  }
  function closeSidebar() {
    document.getElementById('adminSidebar').classList.remove('open');
    document.getElementById('adminOverlay').classList.remove('show');
  }
</script>
</body>
</html>
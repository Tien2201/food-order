<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sửa món ăn</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="d-flex">

  <!-- SIDEBAR -->
  <div class="admin-sidebar">
    <div class="sidebar-brand">
      <div class="sidebar-brand-icon">🍜</div>
      <div>
        <div class="sidebar-brand-text">Food Order</div>
        <div class="sidebar-brand-sub">Admin Panel</div>
      </div>
    </div>

    <div class="sidebar-section-label">Tổng quan</div>
    <a href="/admin/dashboard" class="sidebar-link ">
      <span class="icon">📊</span> Dashboard
    </a>
    <a href="/admin/statistics" class="sidebar-link ">
      <span class="icon">📈</span> Thống kê
    </a>

    <div class="sidebar-section-label">Quản lý</div>
    <a href="/admin/foods" class="sidebar-link active">
      <span class="icon">🍽️</span> Món ăn
    </a>
    <a href="/admin/orders" class="sidebar-link ">
      <span class="icon">📋</span> Đơn hàng
    </a>
    <a href="/admin/users" class="sidebar-link ">
      <span class="icon">👥</span> Tài khoản
    </a>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="sidebar-avatar">
          <%= user ? user.fullname.charAt(0).toUpperCase() : 'A' %>
        </div>
        <div>
          <div class="sidebar-user-name"><%= user ? user.fullname : 'Admin' %></div>
          <div class="sidebar-user-role">Administrator</div>
        </div>
      </div>
      <a href="/logout" class="btn-logout-sidebar">
        <span class="icon">🚪</span> Đăng xuất
      </a>
    </div>
  </div>

<div class="admin-main">
    <div class="admin-topbar">
      <div>
        <div class="admin-topbar-title">✏️ Sửa món ăn</div>
        <div class="admin-topbar-sub"><%= food.name %></div>
      </div>
      <a href="/admin/foods" class="btn-cancel">← Quay lại</a>
    </div>

    <div class="admin-content">
      <div class="edit-card">
        <div class="edit-card-title">Thông tin món ăn</div>

        <form action="/admin/foods/edit/<%= food._id %>" method="POST" enctype="multipart/form-data">

          <label class="form-label-custom">Tên món</label>
          <input name="name" class="form-input-custom" value="<%= food.name %>" required>

          <label class="form-label-custom">Giá (VNĐ)</label>
          <input name="price" type="number" class="form-input-custom" value="<%= food.price %>" required>

          <label class="form-label-custom">Mô tả</label>
          <input name="description" class="form-input-custom" value="<%= food.description %>">

          <label class="form-label-custom">Danh mục</label>
          <select name="category" class="form-input-custom">
            <option value="food" <%= food.category === 'food' ? 'selected' : '' %>>🍜 Đồ ăn</option>
            <option value="drink" <%= food.category === 'drink' ? 'selected' : '' %>>🥤 Đồ uống</option>
          </select>

          <label class="form-label-custom">Độ cay</label>
          <select name="spiceLevel" class="form-input-custom">
            <option value="non-spicy" <%= (food.spiceLevel || 'non-spicy') === 'non-spicy' ? 'selected' : '' %>>🟢 Không cay</option>
            <option value="spicy" <%= food.spiceLevel === 'spicy' ? 'selected' : '' %>>🌶️ Cay</option>
          </select>

          <label class="form-label-custom">Loại nước</label>
          <select name="soupType" class="form-input-custom">
            <option value="dry" <%= (food.soupType || 'dry') === 'dry' ? 'selected' : '' %>>🍲 Khô</option>
            <option value="soup" <%= food.soupType === 'soup' ? 'selected' : '' %>>🍜 Soup</option>
          </select>

          <label class="form-label-custom">Trạng thái</label>
          <select name="status" class="form-input-custom">
            <option value="true" <%= food.status ? 'selected' : '' %>>✅ Đang bán</option>
            <option value="false" <%= !food.status ? 'selected' : '' %>>⛔ Ngừng bán</option>
          </select>

          <label class="form-label-custom">Nhóm tùy chọn hiện khi khách thêm vào giỏ</label>
          <div class="option-group-checks">
            <label class="option-check-chip">
              <input type="checkbox" name="optionGroups" value="spice" <%= (food.optionGroups || []).includes('spice') ? 'checked' : '' %>>
              <span>🌶️ Cay / Không cay (ớt)</span>
            </label>
            <label class="option-check-chip">
              <input type="checkbox" name="optionGroups" value="cheese" <%= (food.optionGroups || []).includes('cheese') ? 'checked' : '' %>>
              <span>🧀 Muối Đài Loan / Rau quế</span>
            </label>
            <label class="option-check-chip">
              <input type="checkbox" name="optionGroups" value="beefFloss" <%= (food.optionGroups || []).includes('beefFloss') ? 'checked' : '' %>>
              <span>🐟 Khô cá bào</span>
            </label>
          </div>
          <div class="option-group-hint">Lưu ý: Tùy chọn "Soup chung/riêng" tự hiện khi Loại nước = Soup, không cần tick ở đây.</div>

          <label class="form-label-custom">Ảnh hiện tại</label>
          <img src="<%= food.image %>" class="current-img" alt="<%= food.name %>" onerror="this.src='/images/background.jpg'">
          <span class="img-label">Tải ảnh mới (để trống nếu không đổi)</span>
          <input type="file" name="image" class="form-input-custom" accept="image/*">

          <div class="d-flex gap-2 mt-2">
            <button type="submit" class="btn-save">💾 Cập nhật</button>
            <a href="/admin/foods" class="btn-cancel">Hủy</a>
          </div>

        </form>
      </div>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
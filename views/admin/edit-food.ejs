<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Sửa món ăn</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <div class="container py-5">
        <div class="card p-4">
            <h1 class="page-title mb-4">Sửa món ăn</h1>

            <form action="/admin/foods/edit/<%= food._id %>" method="POST" enctype="multipart/form-data">
                <input name="name" class="form-control mb-3" value="<%= food.name %>" required>

                <input name="price" type="number" class="form-control mb-3" value="<%= food.price %>" required>

                <input name="description" class="form-control mb-3" value="<%= food.description %>">

                <img src="<%= food.image %>" width="200" class="mb-3">s

                <input type="file" name="image" class="form-control mb-3">

                <select name="status" class="form-control mb-3">
                    <option value="true" <%=food.status ? "selected" : "" %>>Đang bán</option>
                    <option value="false" <%=!food.status ? "selected" : "" %>>Ngừng bán</option>
                </select>

                <button class="btn btn-main">Cập nhật</button>
                <a href="/admin/foods" class="btn btn-secondary">Hủy</a>
            </form>
        </div>
    </div>

</body>

</html>
<script src="/js/main.js"></script>
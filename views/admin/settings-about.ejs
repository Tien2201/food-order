<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ảnh trang Giới thiệu</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="d-flex">

<div class="admin-overlay" id="adminOverlay" onclick="closeSidebar()"></div>

  <%- include("partials/sidebar", { user, activePage: "settings-about" }) %>

  <!-- MAIN CONTENT -->
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-2">
        <button class="admin-hamburger" onclick="openSidebar()">☰</button>
        <div>
          <div class="admin-topbar-title">🖼️ Ảnh trang Giới thiệu</div>
          <div class="admin-topbar-sub">Quản lý ảnh hiển thị ở trang "Giới thiệu" (About) cho khách xem</div>
        </div>
      </div>
    </div>

    <div class="admin-content">

      <%
        const slots = [
          { key: "story", field: "aboutStoryImage", label: "Ảnh câu chuyện thương hiệu (ảnh lớn)" },
          { key: "gallery1", field: "aboutGalleryImage1", label: "Ảnh gallery món ăn #1" },
          { key: "gallery2", field: "aboutGalleryImage2", label: "Ảnh gallery món ăn #2" },
          { key: "gallery3", field: "aboutGalleryImage3", label: "Ảnh gallery món ăn #3" }
        ];
      %>

      <div class="row g-4">
        <% slots.forEach(slot => { %>
          <div class="col-md-6">
            <div class="form-card">
              <div class="form-card-title"><%= slot.label %></div>

              <% if (setting[slot.field]) { %>
                <img src="<%= setting[slot.field] %>" alt="<%= slot.label %>"
                     style="width:100%; max-width:320px; aspect-ratio:4/3; object-fit:cover; border-radius:12px; border:1px solid #f0ece8; display:block; margin:0 auto 16px;">
              <% } else { %>
                <div class="empty-state" style="margin-bottom:16px; padding:24px 16px;">
                  <div style="font-size:32px; margin-bottom:6px;">📷</div>
                  <p style="font-size:13px;">Chưa có ảnh. Hãy tải ảnh lên.</p>
                </div>
              <% } %>

              <form action="/admin/settings/about/<%= slot.key %>" method="POST" enctype="multipart/form-data">
                <label class="form-label-custom">Tải ảnh mới (JPEG, JPG, PNG hoặc WEBP)</label>
                <input type="file" name="aboutImage" class="form-input-custom" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" required>
                <button type="submit" class="btn-save mt-2">💾 Lưu ảnh</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>

    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function openSidebar() {
    document.getElementById('adminSidebar').classList.add('open');
    document.getElementById('adminOverlay').classList.add('show');
  }
  function closeSidebar() {
    document.getElementById('adminSidebar').classList.remove('open');
    document.getElementById('adminOverlay').classList.remove('show');
  }
</script>
</body>
</html>

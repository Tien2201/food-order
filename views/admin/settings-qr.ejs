<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cấu hình QR thanh toán</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="d-flex">

<div class="admin-overlay" id="adminOverlay" onclick="closeSidebar()"></div>

  <!-- SIDEBAR -->
  <div class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-brand">
      <div class="sidebar-brand-icon">🍜</div>
      <div>
        <div class="sidebar-brand-text">Food Order</div>
        <div class="sidebar-brand-sub">Admin Panel</div>
      </div>
    </div>

    <div class="sidebar-section-label">Tổng quan</div>
    <a href="/admin/dashboard" class="sidebar-link">
      <span class="icon">📊</span> Dashboard
    </a>
    <a href="/admin/statistics" class="sidebar-link">
      <span class="icon">📈</span> Thống kê
    </a>

    <div class="sidebar-section-label">Quản lý</div>
    <a href="/admin/foods" class="sidebar-link">
      <span class="icon">🍽️</span> Món ăn
    </a>
    <a href="/admin/orders" class="sidebar-link">
      <span class="icon">📋</span> Đơn hàng
    </a>
    <a href="/admin/users" class="sidebar-link">
      <span class="icon">👥</span> Tài khoản
    </a>
    <a href="/admin/settings/qr" class="sidebar-link active">
      <span class="icon">💳</span> QR thanh toán
    </a>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="sidebar-avatar">
          <%= user ? user.fullname.charAt(0).toUpperCase() : 'A' %>
        </div>
        <div>
          <div class="sidebar-user-name"><%= user ? user.fullname : 'Admin' %></div>
          <div class="sidebar-user-role">Administrator</div>
        </div>
      </div>
      <a href="/logout" class="btn-logout-sidebar">
        <span class="icon">🚪</span> Đăng xuất
      </a>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-2">
        <button class="admin-hamburger" onclick="openSidebar()">☰</button>
        <div>
          <div class="admin-topbar-title">💳 QR thanh toán</div>
          <div class="admin-topbar-sub">Ảnh QR này sẽ hiện cho khách sau khi đơn được xác nhận</div>
        </div>
      </div>
    </div>

    <div class="admin-content">

      <div class="form-card" style="max-width:480px;">
        <div class="form-card-title">Ảnh QR hiện tại</div>

        <% if (setting.paymentQrImage) { %>
          <img src="<%= setting.paymentQrImage %>" alt="QR thanh toán"
               style="width:100%; max-width:280px; border-radius:12px; border:1px solid #f0ece8; display:block; margin:0 auto 20px;">
        <% } else { %>
          <div class="empty-state" style="margin-bottom:20px;">
            <div style="font-size:40px; margin-bottom:8px;">💳</div>
            <p>Chưa có ảnh QR nào. Hãy tải lên ảnh QR thanh toán của quán.</p>
          </div>
        <% } %>

        <form action="/admin/settings/qr" method="POST" enctype="multipart/form-data">
          <label class="form-label-custom">Tải ảnh QR mới (sẽ thay ảnh cũ)</label>
          <input type="file" name="qrImage" class="form-input-custom" accept="image/*" required>

          <div class="d-flex gap-2 mt-2">
            <button type="submit" class="btn-save">💾 Lưu ảnh QR</button>
          </div>
        </form>
      </div>

    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function openSidebar() {
    document.getElementById('adminSidebar').classList.add('open');
    document.getElementById('adminOverlay').classList.add('show');
  }
  function closeSidebar() {
    document.getElementById('adminSidebar').classList.remove('open');
    document.getElementById('adminOverlay').classList.remove('show');
  }
</script>
</body>
</html>

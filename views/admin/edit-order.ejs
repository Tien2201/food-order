<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Sửa đơn hàng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="container py-5">
  <div class="card p-4">
    <h1 class="page-title mb-4">Sửa đơn hàng</h1>

    <form action="/admin/orders/edit/<%= order._id %>" method="POST">
      <input name="customerName" class="form-control mb-3" value="<%= order.customerName %>" required>

      <input name="phone" class="form-control mb-3" value="<%= order.phone %>" required>

      <input name="address" class="form-control mb-3" value="<%= order.address %>" required>

      <input name="paymentCode" class="form-control mb-3" value="<%= order.paymentCode %>" placeholder="Mã thanh toán">

      <select name="status" class="form-control mb-3">
        <option <%= order.status === "Chờ nhân viên xác nhận" ? "selected" : "" %>>
          Chờ nhân viên xác nhận
        </option>

        <option <%= order.status === "Đã xác nhận" ? "selected" : "" %>>
          Đã xác nhận
        </option>

        <option <%= order.status === "Đang làm món" ? "selected" : "" %>>
          Đang làm món
        </option>

        <option <%= order.status === "Đang giao hàng" ? "selected" : "" %>>
          Đang giao hàng
        </option>

        <option <%= order.status === "Hoàn thành" ? "selected" : "" %>>
          Hoàn thành
        </option>

        <option <%= order.status === "Đã hủy" ? "selected" : "" %>>
          Đã hủy
        </option>
      </select>

      <button class="btn btn-main">Cập nhật đơn</button>
      <a href="/admin/orders" class="btn btn-secondary">Hủy</a>
    </form>
  </div>
</div>

</body>
</html>
<script src="/js/main.js"></script>
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chi tiết đơn hàng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="d-flex">

<div class="admin-overlay" id="adminOverlay" onclick="closeSidebar()"></div>

  <!-- SIDEBAR -->
  <div class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-brand">
      <div class="sidebar-brand-icon">🍜</div>
      <div>
        <div class="sidebar-brand-text">Food Order</div>
        <div class="sidebar-brand-sub">Admin Panel</div>
      </div>
    </div>

    <div class="sidebar-section-label">Tổng quan</div>
    <a href="/admin/dashboard" class="sidebar-link ">
      <span class="icon">📊</span> Dashboard
    </a>
    <a href="/admin/statistics" class="sidebar-link ">
      <span class="icon">📈</span> Thống kê
    </a>

    <div class="sidebar-section-label">Quản lý</div>
    <a href="/admin/foods" class="sidebar-link ">
      <span class="icon">🍽️</span> Món ăn
    </a>
    <a href="/admin/orders" class="sidebar-link active">
      <span class="icon">📋</span> Đơn hàng
    </a>
    <a href="/admin/users" class="sidebar-link ">
      <span class="icon">👥</span> Tài khoản
    </a>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="sidebar-avatar">
          <%= user ? user.fullname.charAt(0).toUpperCase() : 'A' %>
        </div>
        <div>
          <div class="sidebar-user-name"><%= user ? user.fullname : 'Admin' %></div>
          <div class="sidebar-user-role">Administrator</div>
        </div>
      </div>
      <a href="/logout" class="btn-logout-sidebar">
        <span class="icon">🚪</span> Đăng xuất
      </a>
    </div>
  </div>

<div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-2">
        <button class="admin-hamburger" onclick="openSidebar()">☰</button>
        <div>
        <div class="admin-topbar-title">📋 Chi tiết đơn hàng</div>
        <div class="admin-topbar-sub">Khách: <%= order.customerName %></div>
      </div>
      <a href="/admin/orders" style="font-size:13px; color:#D85A30; font-weight:600; text-decoration:none;">← Quay lại</a>
    </div>

    <div class="admin-content">
      <div class="detail-grid">

        <!-- Thông tin đơn + món -->
        <div>
          <div class="info-card mb-4">
            <div class="card-title">👤 Thông tin khách hàng</div>
            <div class="info-row">
              <span class="label">Tên khách</span>
              <span class="value"><%= order.customerName %></span>
            </div>
            <div class="info-row">
              <span class="label">SĐT</span>
              <span class="value"><%= order.phone %></span>
            </div>
            <div class="info-row">
              <span class="label">Địa chỉ</span>
              <span class="value"><%= order.address || '—' %></span>
            </div>
            <div class="info-row">
              <span class="label">Mã thanh toán</span>
              <span class="value" style="font-family:monospace; color:#D85A30"><%= order.paymentCode || 'Chưa có' %></span>
            </div>
            <% if (order.confirmedBy) { %>
            <div class="info-row">
              <span class="label">Nhân viên xác nhận</span>
              <span class="value"><%= order.confirmedBy.fullname %></span>
            </div>
            <% } %>
          </div>

          <div class="info-card">
            <div class="card-title">🍽️ Món đã đặt</div>
            <% order.items.forEach(item => { %>
              <div class="item-row">
                <div>
                  <div class="item-name"><%= item.name %></div>
                  <% if (item.note) { %>
                    <div class="item-note">📝 <%= item.note %></div>
                  <% } %>
                  <div class="item-qty">x<%= item.quantity %></div>
                </div>
                <div class="item-price"><%= (item.price * item.quantity).toLocaleString('vi-VN') %> VNĐ</div>
              </div>
            <% }) %>
            <div class="total-row">
              <span>Tổng cộng</span>
              <strong><%= order.totalPrice.toLocaleString('vi-VN') %> VNĐ</strong>
            </div>
          </div>
        </div>

        <!-- Form cập nhật -->
        <div>
          <div class="action-card-box">
            <div class="card-title">⚙️ Cập nhật đơn hàng</div>

            <% 
              const statusColors = {
                'Chờ nhân viên xác nhận': 'background:#fef3c7; color:#92400e',
                'Đã xác nhận': 'background:#d1fae5; color:#065f46',
                'Đang làm món': 'background:#dbeafe; color:#1e40af',
                'Đang giao hàng': 'background:#f3e8ff; color:#6b21a8',
                'Hoàn thành': 'background:#d1fae5; color:#065f46',
                'Đã hủy': 'background:#fee2e2; color:#991b1b',
              };
              const currentColor = statusColors[order.status] || 'background:#f3f4f6; color:#374151';
            %>
            <span class="badge-status" style=<"<%= currentColor %>"><%= order.status %></span>

            <form action="/admin/orders/edit/<%= order._id %>" method="POST">

              <label class="form-label-custom">Tên khách hàng</label>
              <input name="customerName" class="form-input-custom" value="<%= order.customerName %>" required>

              <label class="form-label-custom">Số điện thoại</label>
              <input name="phone" class="form-input-custom" value="<%= order.phone %>" required>

              <label class="form-label-custom">Địa chỉ</label>
              <input name="address" class="form-input-custom" value="<%= order.address %>">

              <label class="form-label-custom">Mã thanh toán</label>
              <input name="paymentCode" class="form-input-custom" value="<%= order.paymentCode %>" placeholder="Nhập mã thanh toán...">

              <label class="form-label-custom">Trạng thái đơn</label>
              <select name="status" class="form-input-custom">
                <% ['Chờ nhân viên xác nhận','Đã xác nhận','Đang làm món','Đang giao hàng','Hoàn thành','Đã hủy'].forEach(s => { %>
                  <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s %></option>
                <% }) %>
              </select>

              <button type="submit" class="btn-save">💾 Cập nhật đơn hàng</button>
              <a href="/admin/orders" class="btn-cancel">Hủy thay đổi</a>
            </form>
          </div>
        </div>

      </div>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function openSidebar() {
    document.getElementById('adminSidebar').classList.add('open');
    document.getElementById('adminOverlay').classList.add('show');
  }
  function closeSidebar() {
    document.getElementById('adminSidebar').classList.remove('open');
    document.getElementById('adminOverlay').classList.remove('show');
  }
</script>
</body>
</html>
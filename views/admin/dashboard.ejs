<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="d-flex">
  <div class="admin-sidebar p-4" style="width:260px;">
    <h3 class="text-white mb-4">Admin</h3>
    <a href="/admin/dashboard">Dashboard</a>
    <a href="/admin/foods">Quản lý món ăn</a>
    <a href="/admin/orders">Quản lý đơn hàng</a>
    <a href="/admin/users">Quản lý tài khoản</a>
    <a href="/logout">Đăng xuất</a>
  </div>

  <div class="flex-grow-1 p-5">
    <h1 class="page-title">Xin chào, <%= user.fullname %></h1>
    <p class="text-muted">Trang quản trị hệ thống đặt món</p>

    <div class="row g-4 mt-3">
      <div class="col-md-4">
        <div class="card stat-card p-4">
          <h5>Món ăn</h5>
          <h2><%= foodCount %></h2>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card stat-card p-4">
          <h5>Đơn hàng</h5>
          <h2><%= orderCount %></h2>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card stat-card p-4">
          <h5>Tài khoản</h5>
          <h2><%= userCount %></h2>
        </div>
      </div>
    </div>
  </div>
</div>

</body>
</html>
<script src="/js/main.js"></script>
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Poppins', sans-serif; background: #f9fafb; margin: 0; }

    /* Stat cards */
    .stat-card {
      background: #fff;
      border-radius: 16px;
      border: 1px solid #f0ece8;
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 16px;
      transition: box-shadow 0.15s;
    }

    .stat-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.07); }

    .stat-icon {
      width: 52px;
      height: 52px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      flex-shrink: 0;
    }

    .stat-icon.orange { background: #fff3ee; }
    .stat-icon.blue   { background: #eff6ff; }
    .stat-icon.green  { background: #f0fdf4; }
    .stat-icon.purple { background: #f5f3ff; }

    .stat-label {
      font-size: 12px;
      color: #9ca3af;
      font-weight: 500;
      margin-bottom: 4px;
    }

    .stat-value {
      font-size: 28px;
      font-weight: 700;
      color: #111827;
      line-height: 1;
    }

    .stat-sub {
      font-size: 12px;
      color: #6b7280;
      margin-top: 4px;
    }

    /* Chart card */
    .chart-card {
      background: #fff;
      border-radius: 16px;
      border: 1px solid #f0ece8;
      padding: 24px;
    }

    .chart-card-title {
      font-size: 15px;
      font-weight: 700;
      color: #111827;
      margin-bottom: 4px;
    }

    .chart-card-sub {
      font-size: 12px;
      color: #9ca3af;
      margin-bottom: 20px;
    }

    /* Recent orders table */
    .table-card {
      background: #fff;
      border-radius: 16px;
      border: 1px solid #f0ece8;
      overflow: hidden;
    }

    .table-card-header {
      padding: 18px 24px;
      border-bottom: 1px solid #f0ece8;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .table-card-title {
      font-size: 15px;
      font-weight: 700;
      color: #111827;
    }

    .table-card table {
      width: 100%;
      border-collapse: collapse;
    }

    .table-card th {
      font-size: 11px;
      font-weight: 600;
      color: #9ca3af;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 12px 24px;
      border-bottom: 1px solid #f9fafb;
      background: #f9fafb;
    }

    .table-card td {
      padding: 14px 24px;
      font-size: 13px;
      color: #374151;
      border-bottom: 1px solid #f9fafb;
    }

    .table-card tr:last-child td { border-bottom: none; }

    .badge-pending  { background: #fef3c7; color: #92400e; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .badge-confirmed { background: #d1fae5; color: #065f46; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }

    .btn-view {
      font-size: 12px;
      color: #D85A30;
      text-decoration: none;
      font-weight: 600;
    }

    .btn-view:hover { text-decoration: underline; }

    /* Quick actions */
    .action-card {
      background: #fff;
      border-radius: 16px;
      border: 1px solid #f0ece8;
      padding: 20px;
      text-decoration: none;
      display: block;
      transition: box-shadow 0.15s, transform 0.15s;
    }

    .action-card:hover {
      box-shadow: 0 8px 24px rgba(0,0,0,0.07);
      transform: translateY(-2px);
    }

    .action-icon { font-size: 28px; margin-bottom: 10px; }
    .action-title { font-size: 14px; font-weight: 600; color: #111827; }
    .action-sub { font-size: 12px; color: #9ca3af; margin-top: 2px; }

    .topbar-date { font-size: 13px; color: #9ca3af; }
  </style>
</head>
<body>

<div class="d-flex">
  <%- include("partials/sidebar", { user, activePage: "dashboard" }) %>

  <div class="admin-main">

    <!-- Topbar -->
    <div class="admin-topbar">
      <div>
        <div class="admin-topbar-title">Xin chào, <%= user.fullname %> 👋</div>
        <div class="admin-topbar-sub">Trang quản trị hệ thống đặt món</div>
      </div>
      <div class="topbar-date" id="currentDate"></div>
    </div>

    <div class="admin-content">

      <!-- Stat cards -->
      <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon orange">🍽️</div>
            <div>
              <div class="stat-label">Món ăn</div>
              <div class="stat-value"><%= foodCount %></div>
              <div class="stat-sub">Đang phục vụ</div>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon blue">📋</div>
            <div>
              <div class="stat-label">Đơn hàng</div>
              <div class="stat-value"><%= orderCount %></div>
              <div class="stat-sub">Tổng tất cả</div>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon green">👥</div>
            <div>
              <div class="stat-label">Tài khoản</div>
              <div class="stat-value"><%= userCount %></div>
              <div class="stat-sub">Đã đăng ký</div>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon purple">💰</div>
            <div>
              <div class="stat-label">Doanh thu</div>
              <div class="stat-value"><%= typeof totalRevenue !== 'undefined' ? (totalRevenue/1000).toFixed(0) + 'K' : '—' %></div>
              <div class="stat-sub">VNĐ tổng cộng</div>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-3 mb-4">

        <!-- Chart -->
        <div class="col-lg-8">
          <div class="chart-card">
            <div class="chart-card-title">📈 Đơn hàng gần đây</div>
            <div class="chart-card-sub">7 ngày gần nhất</div>
            <canvas id="orderChart" height="100"></canvas>
          </div>
        </div>

        <!-- Quick actions -->
        <div class="col-lg-4">
          <div class="chart-card" style="height: 100%;">
            <div class="chart-card-title">⚡ Thao tác nhanh</div>
            <div class="chart-card-sub">Truy cập nhanh các chức năng</div>
            <div class="d-flex flex-column gap-2">
              <a href="/admin/foods" class="action-card">
                <div class="action-icon">🍽️</div>
                <div class="action-title">Thêm món mới</div>
                <div class="action-sub">Quản lý thực đơn</div>
              </a>
              <a href="/admin/orders" class="action-card">
                <div class="action-icon">📋</div>
                <div class="action-title">Xem đơn hàng</div>
                <div class="action-sub">Kiểm tra & cập nhật</div>
              </a>
              <a href="/admin/statistics" class="action-card">
                <div class="action-icon">📊</div>
                <div class="action-title">Thống kê doanh thu</div>
                <div class="action-sub">Báo cáo chi tiết</div>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent orders table -->
      <div class="table-card">
        <div class="table-card-header">
          <div class="table-card-title">🕐 Đơn hàng mới nhất</div>
          <a href="/admin/orders" style="font-size:13px; color:#D85A30; font-weight:600; text-decoration:none;">Xem tất cả →</a>
        </div>
        <table>
          <thead>
            <tr>
              <th>Khách hàng</th>
              <th>SĐT</th>
              <th>Tổng tiền</th>
              <th>Trạng thái</th>
              <th>Thao tác</th>
            </tr>
          </thead>
          <tbody>
            <% if (typeof recentOrders !== 'undefined') { %>
              <% recentOrders.forEach(order => { %>
                <tr>
                  <td><strong><%= order.customerName %></strong></td>
                  <td><%= order.phone %></td>
                  <td style="color:#D85A30; font-weight:600;"><%= order.totalPrice.toLocaleString('vi-VN') %> VNĐ</td>
                  <td>
                    <% if (order.paymentCode) { %>
                      <span class="badge-confirmed">Đã xác nhận</span>
                    <% } else { %>
                      <span class="badge-pending">Đơn mới</span>
                    <% } %>
                  </td>
                  <td><a href="/admin/orders/edit/<%= order._id %>" class="btn-view">Chi tiết →</a></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="5" style="text-align:center; color:#9ca3af; padding:32px;">Chưa có đơn hàng nào</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
  // Hiện ngày giờ
  const d = new Date();
  document.getElementById('currentDate').textContent =
    d.toLocaleDateString('vi-VN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

  // Chart đơn hàng 7 ngày
  const labels = [];
  const today = new Date();
  for (let i = 6; i >= 0; i--) {
    const d = new Date(today);
    d.setDate(today.getDate() - i);
    labels.push(d.toLocaleDateString('vi-VN', { month: 'numeric', day: 'numeric' }));
  }

  const orderData = <%- typeof ordersByDay !== 'undefined' ? JSON.stringify(ordersByDay) : '[0,0,0,0,0,0,0]' %>;

  new Chart(document.getElementById('orderChart'), {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        label: 'Số đơn',
        data: orderData,
        backgroundColor: '#D85A30',
        borderRadius: 8,
        borderSkipped: false,
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: false }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: { stepSize: 1, font: { size: 11 } },
          grid: { color: '#f3f4f6' }
        },
        x: {
          ticks: { font: { size: 11 } },
          grid: { display: false }
        }
      }
    }
  });
</script>

</body>
</html>

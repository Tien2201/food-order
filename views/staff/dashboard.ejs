<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Staff Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="staff-header">
  <a href="/staff/dashboard" class="staff-brand">
    <div class="staff-brand-icon">👨‍🍳</div>
    <span>Staff Order</span>
  </a>
  <div class="d-flex align-items-center">
    <a href="/staff/dashboard" class="staff-nav-link active">Dashboard</a>
    <a href="/staff/orders" class="staff-nav-link">Đơn hàng</a>
    <button class="btn-bell" onclick="checkStaffNotification()">
      🔔
      <span id="staffBell" class="bell-badge">0</span>
    </button>
    <a href="/logout" class="btn-staff-logout ms-2">🚪 Đăng xuất</a>
  </div>
</div>

<div class="staff-content">

  <div class="welcome-banner">
    <h1>Xin chào, <%= user.fullname %> 👋</h1>
    <p>Chúc bạn một ca làm việc hiệu quả!</p>
  </div>

  <!-- Stat cards -->
  <div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
      <div class="stat-card">
        <div class="stat-icon blue">📋</div>
        <div>
          <div class="stat-label">Tổng đơn</div>
          <div class="stat-value"><%= totalOrders %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="stat-card">
        <div class="stat-icon orange">⏳</div>
        <div>
          <div class="stat-label">Chờ xác nhận</div>
          <div class="stat-value"><%= pendingOrders %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="stat-card">
        <div class="stat-icon green">✅</div>
        <div>
          <div class="stat-label">Đã xác nhận</div>
          <div class="stat-value"><%= confirmedOrders %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="stat-card">
        <div class="stat-icon purple">🧑‍💼</div>
        <div>
          <div class="stat-label">Bạn đã xử lý</div>
          <div class="stat-value"><%= myConfirmedCount %></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent orders -->
  <div class="table-card">
    <div class="table-card-header">
      <div class="table-card-title">🕐 Đơn hàng mới nhất</div>
      <a href="/staff/orders" style="font-size:13px; color:#D85A30; font-weight:600; text-decoration:none;">Xem tất cả →</a>
    </div>
    <table>
      <thead>
        <tr>
          <th>Khách hàng</th>
          <th>SĐT</th>
          <th>Tổng tiền</th>
          <th>Trạng thái</th>
          <th>Mã thanh toán</th>
          <th>Thao tác</th>
        </tr>
      </thead>
      <tbody>
        <% if (recentOrders.length === 0) { %>
          <tr><td colspan="6" style="text-align:center; color:#9ca3af; padding:32px;">Chưa có đơn hàng nào</td></tr>
        <% } else { %>
          <% recentOrders.forEach(order => { %>
            <tr>
              <td><strong style="color:#111827"><%= order.customerName %></strong></td>
              <td><%= order.phone %></td>
              <td style="color:#D85A30; font-weight:700;"><%= order.totalPrice.toLocaleString('vi-VN') %> VNĐ</td>
              <td>
                <% if (order.paymentCode) { %>
                  <span class="badge-confirmed">✅ Đã xác nhận</span>
                <% } else { %>
                  <span class="badge-pending">⏳ Đơn mới</span>
                <% } %>
              </td>
              <td style="font-family:monospace; font-size:11px; color:#9ca3af;"><%= order.paymentCode || "Chưa có" %></td>
              <td><a href="/staff/orders/<%= order._id %>" class="btn-detail">Chi tiết</a></td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  async function checkStaffNotification() {
    try {
      const res = await fetch("/staff/notifications");
      const data = await res.json();
      document.getElementById("staffBell").innerText = data.count;
    } catch (e) {}
  }
  setInterval(checkStaffNotification, 5000);
  checkStaffNotification();
</script>

</body>
</html>

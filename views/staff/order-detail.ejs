<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chi tiết đơn hàng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="d-flex">

<div class="admin-overlay" id="adminOverlay" onclick="closeSidebar()"></div>

  <!-- SIDEBAR -->
  <div class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-brand">
      <div class="sidebar-brand-icon">👨‍🍳</div>
      <div>
        <div class="sidebar-brand-text">Staff Order</div>
        <div class="sidebar-brand-sub">Nhân viên</div>
      </div>
    </div>

    <div class="sidebar-section-label">Tổng quan</div>
    <a href="/staff/dashboard" class="sidebar-link">
      <span class="icon">📊</span> Dashboard
    </a>
    <a href="/staff/orders" class="sidebar-link active">
      <span class="icon">📋</span> Đơn hàng
    </a>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="sidebar-avatar">
          <%= user ? user.fullname.charAt(0).toUpperCase() : 'N' %>
        </div>
        <div>
          <div class="sidebar-user-name"><%= user ? user.fullname : 'Nhân viên' %></div>
          <div class="sidebar-user-role">Staff</div>
        </div>
      </div>
      <a href="/logout" class="btn-logout-sidebar">
        <span class="icon">🚪</span> Đăng xuất
      </a>
    </div>
  </div>

  <!-- MAIN -->
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-2">
        <button class="admin-hamburger" onclick="openSidebar()">☰</button>
        <div>
          <div class="admin-topbar-title">Chi tiết đơn hàng</div>
          <div class="admin-topbar-sub">Mã đơn: <%= order._id %></div>
        </div>
      </div>
      <a href="/staff/orders" class="btn-go-back" style="margin-bottom:0;">← Quay lại</a>
    </div>

    <div class="admin-content">

      <div class="detail-header-card">
        <div>
          <h2>👤 <%= order.customerName %></h2>
          <div class="order-id"><%= order.phone %></div>
        </div>
        <%
          const statusBadges = {
            pending: { cls: "badge-pending", text: "⏳ Chờ xác nhận" },
            confirmed: { cls: "badge-pending", text: "💳 Chờ thanh toán" },
            payment_submitted: { cls: "badge-pending", text: "📤 Chờ xác minh" },
            preparing: { cls: "badge-confirmed", text: "👨‍🍳 Đang làm món" },
            delivering: { cls: "badge-confirmed", text: "🛵 Đang giao" },
            completed: { cls: "badge-confirmed", text: "✅ Hoàn tất" },
            cancelled: { cls: "badge-pending", text: "❌ Đã hủy" }
          };
          const badge = statusBadges[order.status] || statusBadges.pending;
        %>
        <span class="<%= badge.cls %>" style="font-size:13px; padding:8px 16px;"><%= badge.text %></span>
      </div>

      <div class="detail-grid">

        <div>
          <div class="info-card mb-3">
            <div class="card-title">👤 Thông tin khách hàng</div>
            <div class="info-row"><span class="label">Tên khách</span><span class="value"><%= order.customerName %></span></div>
            <div class="info-row"><span class="label">SĐT</span><span class="value"><%= order.phone %></span></div>
            <div class="info-row"><span class="label">Địa chỉ</span><span class="value"><%= order.address %></span></div>
          </div>

          <div class="info-card">
            <div class="card-title">🍽️ Món đã đặt</div>
            <% order.items.forEach(item => { %>
              <div class="item-row">
                <div>
                  <div class="item-name"><%= item.name %></div>
                  <% if (item.note) { %><div class="item-note">📝 <%= item.note %></div><% } %>
                  <div class="item-qty">x<%= item.quantity %></div>
                </div>
              </div>
            <% }) %>
            <div class="total-row">
              <span>Tổng cộng</span>
              <strong><%= order.totalPrice.toLocaleString('vi-VN') %> VNĐ</strong>
            </div>
          </div>
        </div>

        <div>
          <div class="action-card-box">
            <div class="card-title">⚙️ Trạng thái đơn</div>
            <div class="info-row"><span class="label">Trạng thái</span><span class="value"><%= badge.text %></span></div>
            <div class="info-row"><span class="label">Mã thanh toán</span><span class="value" style="font-family:monospace"><%= order.paymentCode || "Chưa có" %></span></div>

            <% if (order.status === "pending") { %>
              <form action="/staff/orders/confirm/<%= order._id %>" method="POST" class="mt-3">
                <button type="submit" class="btn-confirm">✅ Xác nhận đã nhận đơn</button>
              </form>

            <% } else if (order.status === "confirmed") { %>
              <div class="confirmed-alert" style="background:#fff3ee; color:#9a4a1f;">
                Đã gửi mã QR cho khách. Đang chờ khách chuyển khoản và gửi ảnh thanh toán.
              </div>

            <% } else if (order.status === "payment_submitted") { %>
              <div class="mt-3">
                <div class="card-title" style="font-size:13px; padding-bottom:8px; border-bottom:none;">📤 Ảnh chuyển khoản khách gửi</div>
                <% if (order.paymentProofImage) { %>
                  <img src="<%= order.paymentProofImage %>" alt="Ảnh chuyển khoản"
                       style="width:100%; max-width:280px; border-radius:12px; border:1px solid #f0ece8; display:block; margin:0 auto 16px;">
                <% } else { %>
                  <p style="font-size:13px; color:#9ca3af;">Không có ảnh.</p>
                <% } %>

                <form action="/staff/orders/verify-payment/<%= order._id %>" method="POST">
                  <button type="submit" class="btn-confirm">✅ Xác minh thanh toán hợp lệ</button>
                </form>
              </div>

            <% } else { %>
              <div class="confirmed-alert">
                Thanh toán đã được xác minh. Quán đang xử lý đơn này.
              </div>
            <% } %>
          </div>
        </div>

      </div>

    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function openSidebar() {
    document.getElementById('adminSidebar').classList.add('open');
    document.getElementById('adminOverlay').classList.add('show');
  }
  function closeSidebar() {
    document.getElementById('adminSidebar').classList.remove('open');
    document.getElementById('adminOverlay').classList.remove('show');
  }

  // ── Tự động cập nhật khi khách gửi ảnh thanh toán / đổi trạng thái đơn ──
  // Trang đang render sẵn (server-side), nên cách an toàn nhất khi phát hiện
  // thay đổi là tự reload lại trang để lấy đúng HTML mới nhất.
  (function() {
    const orderId = "<%= order._id %>";
    const initialStatus = "<%= order.status %>";
    const initialHasProof = !order.paymentProofImage ;

    async function checkOrderStatus() {
      try {
        const res = await fetch(`/staff/orders/${orderId}/status`);
        const data = await res.json();

        if (!data.status) return; // đơn không còn tồn tại, bỏ qua

        const changed = data.status !== initialStatus || data.hasPaymentProof !== initialHasProof;
        if (changed) {
          location.reload();
        }
      } catch (err) {
        // Lỗi mạng tạm thời, bỏ qua, thử lại ở lần poll kế tiếp
      }
    }

    setInterval(checkOrderStatus, 5000);
  })();
</script>

</body>
</html>

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chi tiết đơn hàng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="staff-header">
  <a href="/staff/orders" class="staff-brand">
    <div class="staff-brand-icon">👨‍🍳</div>
    <span>Staff Order</span>
  </a>
  <div class="d-flex align-items-center">
    <a href="/staff/dashboard" class="staff-nav-link">Dashboard</a>
    <a href="/staff/orders" class="staff-nav-link">Đơn hàng</a>
    <a href="/logout" class="btn-staff-logout">🚪 Đăng xuất</a>
  </div>
</div>

<div class="staff-content">

  <a href="/staff/orders" class="btn-go-back">← Quay lại danh sách</a>

  <div class="detail-header-card">
    <div>
      <h2>Chi tiết đơn hàng</h2>
      <div class="order-id">Mã đơn: <%= order._id %></div>
    </div>
    <% if (order.paymentCode) { %>
      <span class="badge-confirmed" style="font-size:13px; padding:8px 16px;">✅ Đã xác nhận</span>
    <% } else { %>
      <span class="badge-pending" style="font-size:13px; padding:8px 16px;">⏳ Đơn mới</span>
    <% } %>
  </div>

  <div class="detail-grid">

    <div>
      <div class="info-card mb-3">
        <div class="card-title">👤 Thông tin khách hàng</div>
        <div class="info-row"><span class="label">Tên khách</span><span class="value"><%= order.customerName %></span></div>
        <div class="info-row"><span class="label">SĐT</span><span class="value"><%= order.phone %></span></div>
        <div class="info-row"><span class="label">Địa chỉ</span><span class="value"><%= order.address %></span></div>
      </div>

      <div class="info-card">
        <div class="card-title">🍽️ Món đã đặt</div>
        <% order.items.forEach(item => { %>
          <div class="item-row">
            <div>
              <div class="item-name"><%= item.name %></div>
              <% if (item.note) { %><div class="item-note">📝 <%= item.note %></div><% } %>
              <div class="item-qty">x<%= item.quantity %></div>
            </div>
          </div>
        <% }) %>
        <div class="total-row">
          <span>Tổng cộng</span>
          <strong><%= order.totalPrice.toLocaleString('vi-VN') %> VNĐ</strong>
        </div>
      </div>
    </div>

    <div>
      <div class="action-card-box">
        <div class="card-title">⚙️ Trạng thái đơn</div>
        <div class="info-row"><span class="label">Trạng thái</span><span class="value"><%= order.status %></span></div>
        <div class="info-row"><span class="label">Mã thanh toán</span><span class="value" style="font-family:monospace"><%= order.paymentCode || "Chưa có" %></span></div>

        <% if (!order.paymentCode) { %>
          <form action="/staff/orders/confirm/<%= order._id %>" method="POST" class="mt-3">
            <button type="submit" class="btn-confirm">✅ Xác nhận đã nhận đơn</button>
          </form>
        <% } else { %>
          <div class="confirmed-alert">
            Mã thanh toán đã gửi: <strong><%= order.paymentCode %></strong>
          </div>
        <% } %>
      </div>
    </div>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Chi tiết đơn hàng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="app-header">
  <a href="/staff/orders" class="brand">👨‍🍳 Staff Order</a>
  <div class="nav-links">
    <a href="/staff/orders">Danh sách đơn</a>
    <a href="/logout" class="logout-btn">Đăng xuất</a>
  </div>
</nav>

<div class="container py-5">
  <a href="/staff/orders" class="btn btn-secondary mb-4">
    ← Quay lại danh sách
  </a>

  <div class="card p-4">
    <div class="d-flex justify-content-between mb-4">
      <div>
        <h2>Chi tiết đơn hàng</h2>
        <p class="text-muted">Mã đơn: <%= order._id %></p>
      </div>

      <% if (order.paymentCode) { %>
        <span class="badge bg-success align-self-start p-3">Đã xác nhận</span>
      <% } else { %>
        <span class="badge bg-warning text-dark align-self-start p-3">Đơn mới</span>
      <% } %>
    </div>

    <div class="row">
      <div class="col-md-6">
        <h4>Thông tin khách</h4>
        <p><strong>Tên:</strong> <%= order.customerName %></p>
        <p><strong>SĐT:</strong> <%= order.phone %></p>
        <p><strong>Địa chỉ:</strong> <%= order.address %></p>
      </div>

      <div class="col-md-6">
        <h4>Thông tin đơn</h4>
        <p><strong>Trạng thái:</strong> <%= order.status %></p>
        <p><strong>Mã thanh toán:</strong> <%= order.paymentCode || "Chưa có" %></p>
        <p><strong>Tổng tiền:</strong> <span class="price"><%= order.totalPrice.toLocaleString() %> VNĐ</span></p>
      </div>
    </div>

    <hr>

    <h4>Món đã đặt</h4>

    <% order.items.forEach(item => { %>
      <div class="bg-light rounded p-3 mb-2">
        <strong><%= item.name %></strong>
        <br>
        Số lượng: <%= item.quantity %>
        <br>
        Ghi chú: <%= item.note || "Không có" %>
      </div>
    <% }) %>

    <% if (!order.paymentCode) { %>
      <form action="/staff/orders/confirm/<%= order._id %>" method="POST" class="mt-4">
        <button class="btn btn-main w-100">
          Xác nhận đã nhận đơn
        </button>
      </form>
    <% } else { %>
      <div class="alert alert-success mt-4">
        Mã thanh toán đã gửi: <strong><%= order.paymentCode %></strong>
      </div>
    <% } %>
  </div>
</div>

</body>
</html>
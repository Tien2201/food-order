<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Nhân viên - Đơn hàng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="app-header">
  <a href="/staff/orders" class="brand">👨‍🍳 Staff Order</a>

  <div class="nav-links">
    <button class="btn btn-light position-relative" onclick="checkStaffNotification()">
      🔔
      <span id="staffBell" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
        0
      </span>
    </button>

    <a href="/logout" class="logout-btn">Đăng xuất</a>
  </div>
</nav>

<div class="container py-5">
  <h1 class="page-title">Danh sách đơn hàng</h1>

  <div class="card p-4">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>Khách hàng</th>
          <th>SĐT</th>
          <th>Tổng tiền</th>
          <th>Trạng thái</th>
          <th>Mã thanh toán</th>
          <th>Thao tác</th>
        </tr>
      </thead>

      <tbody>
        <% orders.forEach(order => { %>
          <tr>
            <td><%= order.customerName %></td>
            <td><%= order.phone %></td>
            <td class="price"><%= order.totalPrice.toLocaleString() %> VNĐ</td>
            <td>
              <% if (order.paymentCode) { %>
                <span class="badge bg-success">Đã xác nhận</span>
              <% } else { %>
                <span class="badge bg-warning text-dark">Đơn mới</span>
              <% } %>
            </td>
            <td><%= order.paymentCode || "Chưa có" %></td>
            <td>
              <a href="/staff/orders/<%= order._id %>" class="btn btn-main btn-sm">
                Xem chi tiết
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script>
async function checkStaffNotification() {
  const res = await fetch("/staff/notifications");
  const data = await res.json();
  document.getElementById("staffBell").innerText = data.count;
}

setInterval(checkStaffNotification, 5000);
checkStaffNotification();
</script>

</body>
</html>
<script src="/js/main.js"></script>
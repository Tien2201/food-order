<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nhân viên - Đơn hàng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="d-flex">

<div class="admin-overlay" id="adminOverlay" onclick="closeSidebar()"></div>

  <!-- SIDEBAR -->
  <div class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-brand">
      <div class="sidebar-brand-icon">👨‍🍳</div>
      <div>
        <div class="sidebar-brand-text">Staff Order</div>
        <div class="sidebar-brand-sub">Nhân viên</div>
      </div>
    </div>

    <div class="sidebar-section-label">Tổng quan</div>
    <a href="/staff/dashboard" class="sidebar-link">
      <span class="icon">📊</span> Dashboard
    </a>
    <a href="/staff/orders" class="sidebar-link active">
      <span class="icon">📋</span> Đơn hàng
    </a>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="sidebar-avatar">
          <%= user ? user.fullname.charAt(0).toUpperCase() : 'N' %>
        </div>
        <div>
          <div class="sidebar-user-name"><%= user ? user.fullname : 'Nhân viên' %></div>
          <div class="sidebar-user-role">Staff</div>
        </div>
      </div>
      <a href="/logout" class="btn-logout-sidebar">
        <span class="icon">🚪</span> Đăng xuất
      </a>
    </div>
  </div>

  <!-- MAIN -->
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-2">
        <button class="admin-hamburger" onclick="openSidebar()">☰</button>
        <div>
          <div class="admin-topbar-title">📋 Danh sách đơn hàng</div>
          <div class="admin-topbar-sub">Xem và xác nhận đơn hàng của khách</div>
        </div>
      </div>
      <div class="d-flex align-items-center gap-2">
        <button class="btn-bell" onclick="toggleMute()" id="muteBtn" title="Tắt/Mở âm thanh">🔊</button>
        <button class="btn-bell" onclick="checkStaffNotification()">
          🔔
          <span id="staffBell" class="bell-badge">0</span>
        </button>
      </div>
    </div>

    <div class="admin-content">

      <!-- Stat cards -->
      <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon blue">📋</div>
            <div>
              <div class="stat-label">Tổng đơn</div>
              <div class="stat-value"><%= orders.length %></div>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon orange">⏳</div>
            <div>
              <div class="stat-label">Chờ xác nhận</div>
              <div class="stat-value"><%= orders.filter(o => !o.paymentCode).length %></div>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon green">✅</div>
            <div>
              <div class="stat-label">Đã xác nhận</div>
              <div class="stat-value"><%= orders.filter(o => o.paymentCode).length %></div>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon purple">💰</div>
            <div>
              <div class="stat-label">Doanh thu</div>
              <div class="stat-value"><%= (orders.reduce((s,o) => s + o.totalPrice, 0)/1000).toFixed(0) %>K</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Search + Filter -->
      <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
        <div class="search-wrap" style="max-width:320px; flex:1;">
          <span class="search-icon" style="color:#aaa;">🔍</span>
          <input
            type="text"
            id="searchInput"
            class="search-input light"
            placeholder="Tìm theo tên khách hoặc SĐT..."
            autocomplete="off"
          >
        </div>
        <div class="d-flex gap-2">
          <button class="filter-btn active" onclick="filterOrders('all', this)">Tất cả</button>
          <button class="filter-btn" onclick="filterOrders('pending', this)">⏳ Chờ xác nhận</button>
          <button class="filter-btn" onclick="filterOrders('confirmed', this)">✅ Đã xác nhận</button>
        </div>
      </div>

      <% if (orders.length === 0) { %>
        <div class="empty-state">
          <div style="font-size:48px; margin-bottom:12px;">📋</div>
          <p>Chưa có đơn hàng nào.</p>
        </div>
      <% } else { %>
        <div class="table-card">
          <table>
            <thead>
              <tr>
                <th>Khách hàng</th>
                <th>SĐT</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Mã thanh toán</th>
                <th>Thao tác</th>
              </tr>
            </thead>
            <tbody id="orderTable">
              <% orders.forEach(order => { %>
                <tr
                  data-status="<%= order.paymentCode ? 'confirmed' : 'pending' %>"
                  data-search="<%= (order.customerName + ' ' + order.phone).toLowerCase() %>"
                >
                  <td><strong style="color:#111827"><%= order.customerName %></strong></td>
                  <td><%= order.phone %></td>
                  <td style="color:#D85A30; font-weight:700;"><%= order.totalPrice.toLocaleString('vi-VN') %> VNĐ</td>
                  <td>
                    <% if (order.paymentCode) { %>
                      <span class="badge-confirmed">✅ Đã xác nhận</span>
                    <% } else { %>
                      <span class="badge-pending">⏳ Đơn mới</span>
                    <% } %>
                  </td>
                  <td style="font-family:monospace; font-size:11px; color:#9ca3af;"><%= order.paymentCode || "Chưa có" %></td>
                  <td><a href="/staff/orders/<%= order._id %>" class="btn-detail">Xem chi tiết</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <div id="emptyFilterState" class="empty-state" style="display:none;">
            <div style="font-size:40px; margin-bottom:8px;">🔍</div>
            <p>Không tìm thấy đơn hàng phù hợp</p>
          </div>
        </div>
      <% } %>

    </div>
  </div>

</div>

<audio id="notifySound" src="/sounds/notification.mp3" preload="auto"></audio>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function openSidebar() {
    document.getElementById('adminSidebar').classList.add('open');
    document.getElementById('adminOverlay').classList.add('show');
  }
  function closeSidebar() {
    document.getElementById('adminSidebar').classList.remove('open');
    document.getElementById('adminOverlay').classList.remove('show');
  }

  // ── Filter + Search ──
  let activeFilter = 'all';

  function filterOrders(status, btn) {
    activeFilter = status;
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    applyFilters();
  }

  function applyFilters() {
    const query = (document.getElementById('searchInput').value || '').trim().toLowerCase();
    const rows = document.querySelectorAll('#orderTable tr');
    let visibleCount = 0;

    rows.forEach(row => {
      const matchStatus = activeFilter === 'all' || row.dataset.status === activeFilter;
      const matchSearch = !query || row.dataset.search.includes(query);
      const show = matchStatus && matchSearch;
      row.style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });

    const emptyState = document.getElementById('emptyFilterState');
    if (emptyState) emptyState.style.display = visibleCount === 0 ? '' : 'none';
  }

  const searchInput = document.getElementById('searchInput');
  if (searchInput) searchInput.addEventListener('input', applyFilters);

  // ── Notification sound ──
  const notifySound = document.getElementById("notifySound");
  let lastCount = parseInt(sessionStorage.getItem("lastOrderCount")) || 0;
  let isMuted = localStorage.getItem("staffSoundMuted") === "true";

  function updateMuteBtn() {
    document.getElementById("muteBtn").textContent = isMuted ? "🔇" : "🔊";
  }
  updateMuteBtn();

  function toggleMute() {
    isMuted = !isMuted;
    localStorage.setItem("staffSoundMuted", isMuted);
    updateMuteBtn();
  }

  async function checkStaffNotification() {
    try {
      const res = await fetch("/staff/notifications");
      const data = await res.json();
      document.getElementById("staffBell").innerText = data.count;

      if (data.count > lastCount && !isMuted) {
        notifySound.currentTime = 0;
        notifySound.play().catch(() => {});
      }

      lastCount = data.count;
      sessionStorage.setItem("lastOrderCount", lastCount);
    } catch (e) {}
  }

  setInterval(checkStaffNotification, 5000);
  checkStaffNotification();
</script>

</body>
</html>

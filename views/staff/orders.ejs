<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nhân viên - Đơn hàng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="d-flex">

<div class="admin-overlay" id="adminOverlay" onclick="closeSidebar()"></div>

  <!-- SIDEBAR -->
  <div class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-brand">
      <div class="sidebar-brand-icon">👨‍🍳</div>
      <div>
        <div class="sidebar-brand-text">Staff Order</div>
        <div class="sidebar-brand-sub">Nhân viên</div>
      </div>
    </div>

    <div class="sidebar-section-label">Tổng quan</div>
    <a href="/staff/dashboard" class="sidebar-link">
      <span class="icon">📊</span> Dashboard
    </a>
    <a href="/staff/orders" class="sidebar-link active">
      <span class="icon">📋</span> Đơn hàng
    </a>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="sidebar-avatar">
          <%= user ? user.fullname.charAt(0).toUpperCase() : 'N' %>
        </div>
        <div>
          <div class="sidebar-user-name"><%= user ? user.fullname : 'Nhân viên' %></div>
          <div class="sidebar-user-role">Staff</div>
        </div>
      </div>
      <a href="/logout" class="btn-logout-sidebar">
        <span class="icon">🚪</span> Đăng xuất
      </a>
    </div>
  </div>

  <!-- MAIN -->
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-2">
        <button class="admin-hamburger" onclick="openSidebar()">☰</button>
        <div>
          <div class="admin-topbar-title">📋 Danh sách đơn hàng</div>
          <div class="admin-topbar-sub">Xem và xác nhận đơn hàng của khách</div>
        </div>
      </div>
      <div class="d-flex align-items-center gap-2">
        <button class="btn-bell" onclick="toggleMute()" id="muteBtn" title="Tắt/Mở âm thanh">🔊</button>
        <button class="btn-bell" onclick="checkStaffNotification()">
          🔔
          <span id="staffBell" class="bell-badge">0</span>
        </button>
      </div>
    </div>

    <div class="admin-content">

      <div id="audioUnlockNotice" style="background:#fff3ee; border:1px solid #ffd9c2; border-radius:10px; padding:10px 14px; margin-bottom:16px; font-size:12.5px; color:#9a4a1f; display:none;">
        🔔 Chạm vào màn hình một lần để bật âm thanh thông báo đơn mới.
      </div>

      <!-- Stat cards -->
      <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon blue">📋</div>
            <div>
              <div class="stat-label">Tổng đơn</div>
              <div class="stat-value"><%= orders.length %></div>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon orange">⏳</div>
            <div>
              <div class="stat-label">Chờ xác nhận</div>
              <div class="stat-value"><%= orders.filter(o => o.status === 'pending').length %></div>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon green">✅</div>
            <div>
              <div class="stat-label">Đang xử lý</div>
              <div class="stat-value"><%= orders.filter(o => o.status !== 'pending').length %></div>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon purple">💰</div>
            <div>
              <div class="stat-label">Doanh thu</div>
              <div class="stat-value"><%= (orders.reduce((s,o) => s + o.totalPrice, 0)/1000).toFixed(0) %>K</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Search -->
      <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
        <div class="search-wrap" style="max-width:320px; flex:1;">
          <span class="search-icon" style="color:#aaa;">🔍</span>
          <input
            type="text"
            id="searchInput"
            class="search-input light"
            placeholder="Tìm theo tên khách hoặc SĐT..."
            autocomplete="off"
          >
        </div>
      </div>

      <% if (orders.length === 0) { %>
        <div class="empty-state">
          <div style="font-size:48px; margin-bottom:12px;">📋</div>
          <p>Chưa có đơn hàng nào.</p>
        </div>
      <% } else { %>

        <%
          const statusBadges = {
            pending: { cls: "badge-pending", text: "⏳ Chờ xác nhận" },
            confirmed: { cls: "badge-pending", text: "💳 Chờ thanh toán" },
            payment_submitted: { cls: "badge-pending", text: "📤 Chờ xác minh" },
            preparing: { cls: "badge-confirmed", text: "👨‍🍳 Đang làm món" },
            delivering: { cls: "badge-confirmed", text: "🛵 Đang giao" },
            completed: { cls: "badge-confirmed", text: "✅ Hoàn tất" },
            cancelled: { cls: "badge-pending", text: "❌ Đã hủy" }
          };

          // Gom đơn theo ngày (dùng createdAt), orders đã sort mới nhất trước
          const dayNames = ['Chủ nhật', 'Thứ 2', 'Thứ 3', 'Thứ 4', 'Thứ 5', 'Thứ 6', 'Thứ 7'];
          const groups = [];
          const groupMap = {};

          orders.forEach(order => {
            const d = new Date(order.createdAt);
            const dateKey = `${d.getFullYear()}-${d.getMonth()+1}-${d.getDate()}`;
            if (!groupMap[dateKey]) {
              const label = `${d.getDate().toString().padStart(2,'0')}/${(d.getMonth()+1).toString().padStart(2,'0')}/${d.getFullYear()} (${dayNames[d.getDay()]})`;
              groupMap[dateKey] = { key: dateKey, label, orders: [] };
              groups.push(groupMap[dateKey]);
            }
            groupMap[dateKey].orders.push(order);
          });
        %>

        <div id="dayGroupsContainer">
          <% groups.forEach((group, gIndex) => { %>
            <div class="day-group" data-day-key="<%= group.key %>">
              <button type="button" class="day-group-header" onclick="toggleDayGroup(this)">
                <span class="day-group-arrow">▶</span>
                <span class="day-group-label">📅 Ngày <%= group.label %></span>
                <span class="day-group-count"><%= group.orders.length %> đơn</span>
              </button>

              <div class="day-group-body" style="display:none;">
                <% group.orders.forEach(order => { %>
                  <%
                    const badge = statusBadges[order.status] || statusBadges.pending;
                  %>
                  <div class="day-order-row" data-search="<%= (order.customerName + ' ' + order.phone).toLowerCase() %>" data-order-id="<%= order._id %>">
                    <div class="day-order-info">
                      <div class="day-order-name"><%= order.customerName %></div>
                      <div class="day-order-meta">
                        <%= order.phone %> · <span style="color:#D85A30; font-weight:700;"><%= order.totalPrice.toLocaleString('vi-VN') %> VNĐ</span>
                      </div>
                    </div>
                    <span class="<%= badge.cls %>"><%= badge.text %></span>
                    <a href="/staff/orders/<%= order._id %>" class="btn-detail">Xem chi tiết</a>
                    <button type="button" class="btn-delete-order" onclick="deleteOrder('<%= order._id %>', this)" title="Xóa đơn này">🗑️</button>
                  </div>
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>

        <div id="emptyFilterState" class="empty-state" style="display:none;">
          <div style="font-size:40px; margin-bottom:8px;">🔍</div>
          <p>Không tìm thấy đơn hàng phù hợp</p>
        </div>
      <% } %>

    </div>
  </div>

</div>

<audio id="notifySound" src="/sounds/notification.mp3" preload="auto"></audio>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function openSidebar() {
    document.getElementById('adminSidebar').classList.add('open');
    document.getElementById('adminOverlay').classList.add('show');
  }
  function closeSidebar() {
    document.getElementById('adminSidebar').classList.remove('open');
    document.getElementById('adminOverlay').classList.remove('show');
  }

  // ── Mở khóa âm thanh trên mobile ──
  let audioUnlocked = false;
  const isTouchDevice = ('ontouchstart' in window) || navigator.maxTouchPoints > 0;
  const unlockNotice = document.getElementById('audioUnlockNotice');

  if (isTouchDevice && unlockNotice) {
    unlockNotice.style.display = '';
  }

  function unlockAudio() {
    if (audioUnlocked) return;
    const sound = document.getElementById("notifySound");
    sound.play().then(() => {
      sound.pause();
      sound.currentTime = 0;
      audioUnlocked = true;
      if (unlockNotice) unlockNotice.style.display = 'none';
    }).catch(() => {});
  }

  document.addEventListener('touchstart', unlockAudio, { once: true });
  document.addEventListener('click', unlockAudio, { once: true });

  // ── Accordion theo ngày ──
  function toggleDayGroup(headerBtn) {
    const group = headerBtn.closest('.day-group');
    const body = group.querySelector('.day-group-body');
    const arrow = headerBtn.querySelector('.day-group-arrow');
    const isOpen = body.style.display !== 'none';

    body.style.display = isOpen ? 'none' : '';
    arrow.textContent = isOpen ? '▶' : '▼';
  }

  // ── Search: tự mở các nhóm ngày có kết quả khớp, ẩn nhóm không có kết quả ──
  const searchInput = document.getElementById('searchInput');

  function applySearch() {
    const query = (searchInput.value || '').trim().toLowerCase();
    const groups = document.querySelectorAll('.day-group');
    let totalVisible = 0;

    groups.forEach(group => {
      const rows = group.querySelectorAll('.day-order-row');
      let groupVisibleCount = 0;

      rows.forEach(row => {
        const match = !query || row.dataset.search.includes(query);
        row.style.display = match ? '' : 'none';
        if (match) groupVisibleCount++;
      });

      group.style.display = groupVisibleCount > 0 ? '' : 'none';
      totalVisible += groupVisibleCount;

      // Khi đang tìm kiếm và có kết quả, tự mở nhóm để khách thấy ngay
      const body = group.querySelector('.day-group-body');
      const arrow = group.querySelector('.day-group-arrow');
      if (query && groupVisibleCount > 0) {
        body.style.display = '';
        arrow.textContent = '▼';
      } else if (!query) {
        body.style.display = 'none';
        arrow.textContent = '▶';
      }
    });

    const emptyState = document.getElementById('emptyFilterState');
    if (emptyState) emptyState.style.display = totalVisible === 0 ? '' : 'none';
  }

  if (searchInput) searchInput.addEventListener('input', applySearch);

  // ── Xóa 1 đơn hàng ──
  // CẢNH BÁO: không giới hạn trạng thái, có thể xóa cả đơn đang xử lý.
  async function deleteOrder(orderId, btn) {
    const confirmed = confirm('Bạn có chắc muốn xóa đơn hàng này? Hành động này không thể hoàn tác, kể cả khi đơn đang được xử lý.');
    if (!confirmed) return;

    try {
      const res = await fetch(`/staff/orders/delete/${orderId}`, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      });
      const data = await res.json();

      if (data.success) {
        const row = btn.closest('.day-order-row');
        const group = row.closest('.day-group');
        row.remove();

        // Nếu nhóm ngày này không còn đơn nào, xóa luôn cả nhóm
        if (group && group.querySelectorAll('.day-order-row').length === 0) {
          group.remove();
        } else if (group) {
          // Cập nhật lại số đơn hiển thị trên header nhóm
          const countEl = group.querySelector('.day-group-count');
          const remaining = group.querySelectorAll('.day-order-row').length;
          if (countEl) countEl.textContent = `${remaining} đơn`;
        }
      } else {
        alert(data.message || 'Có lỗi xảy ra khi xóa đơn hàng.');
      }
    } catch (err) {
      alert('Không thể kết nối tới server, vui lòng thử lại.');
    }
  }

  // ── Notification sound + Auto-update (không cần F5) ──
  const notifySound = document.getElementById("notifySound");
  let isMuted = localStorage.getItem("staffSoundMuted") === "true";

  function updateMuteBtn() {
    document.getElementById("muteBtn").textContent = isMuted ? "🔇" : "🔊";
  }
  updateMuteBtn();

  function toggleMute() {
    isMuted = !isMuted;
    localStorage.setItem("staffSoundMuted", isMuted);
    updateMuteBtn();
  }

  let knownOrderIds = new Set(
    Array.from(document.querySelectorAll('.day-order-row[data-order-id]')).map(row => row.dataset.orderId)
  );

  async function checkStaffNotification() {
    try {
      const res = await fetch("/staff/notifications");
      const data = await res.json();

      document.getElementById("staffBell").innerText = data.count;

      const newOnes = (data.orders || []).filter(o => !knownOrderIds.has(String(o._id)));

      if (newOnes.length > 0) {
        newOnes.forEach(o => knownOrderIds.add(String(o._id)));

        if (!isMuted) {
          notifySound.currentTime = 0;
          notifySound.play().catch(() => {});
        }

        // Đơn mới có thể thuộc nhóm "hôm nay" chưa từng tạo nếu đây là đơn đầu ngày,
        // hoặc nhóm hôm nay đã có sẵn. Đơn giản và an toàn nhất: tải lại trang
        // để hiển thị đúng accordion theo ngày mà không cần dựng lại DOM phức tạp.
        location.reload();
      }
    } catch (e) {}
  }

  setInterval(checkStaffNotification, 5000);
</script>

</body>
</html>

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nhân viên - Đơn hàng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="d-flex">

<div class="admin-overlay" id="adminOverlay" onclick="closeSidebar()"></div>

  <!-- SIDEBAR -->
  <div class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-brand">
      <div class="sidebar-brand-icon">👨‍🍳</div>
      <div>
        <div class="sidebar-brand-text">Staff Order</div>
        <div class="sidebar-brand-sub">Nhân viên</div>
      </div>
    </div>

    <div class="sidebar-section-label">Tổng quan</div>
    <a href="/staff/dashboard" class="sidebar-link">
      <span class="icon">📊</span> Dashboard
    </a>
    <a href="/staff/orders" class="sidebar-link active">
      <span class="icon">📋</span> Đơn hàng
    </a>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="sidebar-avatar">
          <%= user ? user.fullname.charAt(0).toUpperCase() : 'N' %>
        </div>
        <div>
          <div class="sidebar-user-name"><%= user ? user.fullname : 'Nhân viên' %></div>
          <div class="sidebar-user-role">Staff</div>
        </div>
      </div>
      <a href="/logout" class="btn-logout-sidebar">
        <span class="icon">🚪</span> Đăng xuất
      </a>
    </div>
  </div>

  <!-- MAIN -->
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-2">
        <button class="admin-hamburger" onclick="openSidebar()">☰</button>
        <div>
          <div class="admin-topbar-title">📋 Danh sách đơn hàng</div>
          <div class="admin-topbar-sub">Xem và xác nhận đơn hàng của khách</div>
        </div>
      </div>
      <div class="d-flex align-items-center gap-2">
        <button class="btn-bell" onclick="toggleMute()" id="muteBtn" title="Tắt/Mở âm thanh">🔊</button>
        <button class="btn-bell" onclick="checkStaffNotification()">
          🔔
          <span id="staffBell" class="bell-badge">0</span>
        </button>
      </div>
    </div>

    <div class="admin-content">

      <div id="audioUnlockNotice" style="background:#fff3ee; border:1px solid #ffd9c2; border-radius:10px; padding:10px 14px; margin-bottom:16px; font-size:12.5px; color:#9a4a1f; display:none;">
        🔔 Chạm vào màn hình một lần để bật âm thanh thông báo đơn mới.
      </div>

      <!-- Stat cards -->
      <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon blue">📋</div>
            <div>
              <div class="stat-label">Tổng đơn</div>
              <div class="stat-value"><%= orders.length %></div>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon orange">⏳</div>
            <div>
              <div class="stat-label">Chờ xác nhận</div>
              <div class="stat-value"><%= orders.filter(o => o.status === 'pending').length %></div>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon green">✅</div>
            <div>
              <div class="stat-label">Đang xử lý</div>
              <div class="stat-value"><%= orders.filter(o => o.status !== 'pending').length %></div>
            </div>
          </div>
        </div>
        <div class="col-md-3 col-sm-6">
          <div class="stat-card">
            <div class="stat-icon purple">💰</div>
            <div>
              <div class="stat-label">Doanh thu</div>
              <div class="stat-value"><%= (orders.reduce((s,o) => s + o.totalPrice, 0)/1000).toFixed(0) %>K</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Search + Filter -->
      <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
        <div class="search-wrap" style="max-width:320px; flex:1;">
          <span class="search-icon" style="color:#aaa;">🔍</span>
          <input
            type="text"
            id="searchInput"
            class="search-input light"
            placeholder="Tìm theo tên khách hoặc SĐT..."
            autocomplete="off"
          >
        </div>
        <div class="d-flex gap-2 flex-wrap">
          <button class="filter-btn active" onclick="filterOrders('all', this)">Tất cả</button>
          <button class="filter-btn" onclick="filterOrders('pending', this)">⏳ Chờ xác nhận</button>
          <button class="filter-btn" onclick="filterOrders('confirmed', this)">💳 Chờ thanh toán</button>
          <button class="filter-btn" onclick="filterOrders('payment_submitted', this)">📤 Chờ xác minh</button>
          <button class="filter-btn" onclick="filterOrders('preparing', this)">👨‍🍳 Đang làm món</button>
        </div>
      </div>

      <% if (orders.length === 0) { %>
        <div class="empty-state">
          <div style="font-size:48px; margin-bottom:12px;">📋</div>
          <p>Chưa có đơn hàng nào.</p>
        </div>
      <% } else { %>
        <div class="table-card">
          <table>
            <thead>
              <tr>
                <th>Khách hàng</th>
                <th>SĐT</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Mã thanh toán</th>
                <th>Thao tác</th>
              </tr>
            </thead>
            <tbody id="orderTable">
              <%
                const statusBadges = {
                  pending: { cls: "badge-pending", text: "⏳ Chờ xác nhận" },
                  confirmed: { cls: "badge-pending", text: "💳 Chờ thanh toán" },
                  payment_submitted: { cls: "badge-pending", text: "📤 Chờ xác minh" },
                  preparing: { cls: "badge-confirmed", text: "👨‍🍳 Đang làm món" },
                  delivering: { cls: "badge-confirmed", text: "🛵 Đang giao" },
                  completed: { cls: "badge-confirmed", text: "✅ Hoàn tất" },
                  cancelled: { cls: "badge-pending", text: "❌ Đã hủy" }
                };
              %>
              <% orders.forEach(order => { %>
                <%
                  const badge = statusBadges[order.status] || statusBadges.pending;
                %>
                <tr
                  data-status="<%= order.status %>"
                  data-search="<%= (order.customerName + ' ' + order.phone).toLowerCase() %>"
                  data-order-id="<%= order._id %>"
                >
                  <td><strong style="color:#111827"><%= order.customerName %></strong></td>
                  <td><%= order.phone %></td>
                  <td style="color:#D85A30; font-weight:700;"><%= order.totalPrice.toLocaleString('vi-VN') %> VNĐ</td>
                  <td><span class="<%= badge.cls %>"><%= badge.text %></span></td>
                  <td style="font-family:monospace; font-size:11px; color:#9ca3af;"><%= order.paymentCode || "Chưa có" %></td>
                  <td><a href="/staff/orders/<%= order._id %>" class="btn-detail">Xem chi tiết</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <div id="emptyFilterState" class="empty-state" style="display:none;">
            <div style="font-size:40px; margin-bottom:8px;">🔍</div>
            <p>Không tìm thấy đơn hàng phù hợp</p>
          </div>
        </div>
      <% } %>

    </div>
  </div>

</div>

<audio id="notifySound" src="/sounds/notification.mp3" preload="auto"></audio>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function openSidebar() {
    document.getElementById('adminSidebar').classList.add('open');
    document.getElementById('adminOverlay').classList.add('show');
  }
  function closeSidebar() {
    document.getElementById('adminSidebar').classList.remove('open');
    document.getElementById('adminOverlay').classList.remove('show');
  }

  // ── Mở khóa âm thanh trên mobile ──
  // Trình duyệt mobile chặn audio tự động phát nếu chưa có tương tác người dùng.
  // Lần chạm/click đầu tiên trên trang sẽ "mở khóa" để các lần phát tự động sau hoạt động.
  let audioUnlocked = false;
  const isTouchDevice = ('ontouchstart' in window) || navigator.maxTouchPoints > 0;
  const unlockNotice = document.getElementById('audioUnlockNotice');

  if (isTouchDevice && unlockNotice) {
    unlockNotice.style.display = '';
  }

  function unlockAudio() {
    if (audioUnlocked) return;
    const sound = document.getElementById("notifySound");
    sound.play().then(() => {
      sound.pause();
      sound.currentTime = 0;
      audioUnlocked = true;
      if (unlockNotice) unlockNotice.style.display = 'none';
    }).catch(() => {});
  }

  document.addEventListener('touchstart', unlockAudio, { once: true });
  document.addEventListener('click', unlockAudio, { once: true });

  // ── Filter + Search ──
  let activeFilter = 'all';

  function filterOrders(status, btn) {
    activeFilter = status;
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    applyFilters();
  }

  function applyFilters() {
    const query = (document.getElementById('searchInput').value || '').trim().toLowerCase();
    const rows = document.querySelectorAll('#orderTable tr');
    let visibleCount = 0;

    rows.forEach(row => {
      const matchStatus = activeFilter === 'all' || row.dataset.status === activeFilter;
      const matchSearch = !query || row.dataset.search.includes(query);
      const show = matchStatus && matchSearch;
      row.style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });

    const emptyState = document.getElementById('emptyFilterState');
    if (emptyState) emptyState.style.display = visibleCount === 0 ? '' : 'none';
  }

  const searchInput = document.getElementById('searchInput');
  if (searchInput) searchInput.addEventListener('input', applyFilters);

  // ── Notification sound + Auto-update table (không cần F5) ──
  const notifySound = document.getElementById("notifySound");
  let isMuted = localStorage.getItem("staffSoundMuted") === "true";

  function updateMuteBtn() {
    document.getElementById("muteBtn").textContent = isMuted ? "🔇" : "🔊";
  }
  updateMuteBtn();

  function toggleMute() {
    isMuted = !isMuted;
    localStorage.setItem("staffSoundMuted", isMuted);
    updateMuteBtn();
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function buildOrderRow(order) {
    // Đơn mới phát hiện qua polling luôn ở trạng thái "pending" (chưa xác nhận)
    const status = '<span class="badge-pending">⏳ Chờ xác nhận</span>';

    const payCode = order.paymentCode
      ? escapeHtml(order.paymentCode)
      : 'Chưa có';

    const searchKey = (order.customerName + ' ' + order.phone).toLowerCase();

    const tr = document.createElement('tr');
    tr.dataset.status = order.status || 'pending';
    tr.dataset.search = searchKey;
    tr.dataset.orderId = order._id;
    tr.innerHTML = `
      <td><strong style="color:#111827">${escapeHtml(order.customerName)}</strong></td>
      <td>${escapeHtml(order.phone)}</td>
      <td style="color:#D85A30; font-weight:700;">${Number(order.totalPrice).toLocaleString('vi-VN')} VNĐ</td>
      <td>${status}</td>
      <td style="font-family:monospace; font-size:11px; color:#9ca3af;">${escapeHtml(payCode)}</td>
      <td><a href="/staff/orders/${order._id}" class="btn-detail">Xem chi tiết</a></td>
    `;
    return tr;
  }

  async function checkStaffNotification() {
    try {
      const res = await fetch("/staff/notifications");
      const data = await res.json();

      document.getElementById("staffBell").innerText = data.count;

      const tableBody = document.getElementById('orderTable');
      if (!tableBody) return;

      // Lấy danh sách ID đơn hiện đang hiển thị trên bảng
      const existingIds = new Set(
        Array.from(tableBody.querySelectorAll('tr[data-order-id]')).map(tr => tr.dataset.orderId)
      );

      // Lọc ra các đơn mới (chưa từng xuất hiện trên bảng)
      const newOnes = (data.orders || []).filter(o => !existingIds.has(String(o._id)));

      if (newOnes.length > 0) {
        // Chèn đơn mới nhất lên đầu bảng
        newOnes.forEach(order => {
          const row = buildOrderRow(order);
          tableBody.prepend(row);
        });

        applyFilters();

        if (!isMuted) {
          notifySound.currentTime = 0;
          notifySound.play().catch(() => {});
        }
      }
    } catch (e) {}
  }

  setInterval(checkStaffNotification, 5000);
  checkStaffNotification();
</script>

</body>
</html>

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Giới thiệu - Đậu Hủ Thúi Nhà Họ La</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Noto+Serif:wght@700&display=swap" rel="stylesheet">
</head>
<body>

<%- include("partials/header", { user: user }) %>

<!-- Hero -->
<div class="menu-hero">
  <div class="container">
    <h1>Câu chuyện của chúng tôi 🍜</h1>
    <p>Hương vị đậu hủ thúi truyền thống, gìn giữ qua nhiều thế hệ</p>
  </div>
</div>

<div class="container py-5">

  <!-- Câu chuyện thương hiệu -->
  <div class="about-story-section">
    <div class="row g-4 align-items-center">
      <div class="col-md-6">
        <% if (setting && setting.aboutStoryImage) { %>
          <img src="<%= setting.aboutStoryImage %>" alt="Đậu Hủ Thúi Nhà Họ La" class="about-img-real">
        <% } else { %>
          <div class="about-img-placeholder">
            <span class="about-img-placeholder-icon">📷</span>
            <span class="about-img-placeholder-text">Ảnh quán sẽ được cập nhật tại đây</span>
          </div>
        <% } %>
      </div>
      <div class="col-md-6">
        <div class="section-label">Về chúng tôi</div>
        <h2 class="about-heading">Đậu Hủ Thúi Nhà Họ La</h2>
        <p class="about-text">
          Bắt nguồn từ ẩm thực đường phố Hồ Nam và Đài Loan, đậu hủ thúi từ lâu
          đã là món ăn gây "ám ảnh" với người lần đầu thử nhưng lại khiến biết
          bao người mê mẩn ngay từ miếng cắn đầu tiên.
        </p>
        <p class="about-text">
          Nhà Họ La mang công thức lên men truyền thống, kết hợp cùng nước sốt
          được pha chế riêng để phù hợp với khẩu vị người Việt — giữ trọn vị
          đặc trưng nhưng không quá gắt, ăn cùng các loại rau củ ngâm chua giúp
          cân bằng hương vị.
        </p>
        <p class="about-text">
          Mỗi miếng đậu hủ được chiên giòn ngoài, mềm tan trong, ăn kèm nước sốt
          đậm đà — đó là trải nghiệm chúng tôi muốn mang đến cho từng thực khách.
        </p>
      </div>
    </div>
  </div>

  <!-- 3 điểm nổi bật -->
  <div class="row g-4 my-5">
    <div class="col-md-4">
      <div class="about-highlight-card">
        <div class="about-highlight-icon">🔥</div>
        <h4>Lên men truyền thống</h4>
        <p>Công thức ủ đậu hủ được giữ nguyên bản, đảm bảo đúng vị đặc trưng của ẩm thực Hồ Nam.</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="about-highlight-card">
        <div class="about-highlight-icon">🌶️</div>
        <h4>Đa dạng hương vị</h4>
        <p>Từ sốt chao, sốt tương, muối Tân Cương đến phô mai mặn — nhiều lựa chọn cho mọi khẩu vị.</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="about-highlight-card">
        <div class="about-highlight-icon">🛵</div>
        <h4>Đặt món dễ dàng</h4>
        <p>Chọn món, tùy chỉnh gia vị theo ý muốn, đặt hàng và theo dõi đơn ngay trên website.</p>
      </div>
    </div>
  </div>

  <!-- Ảnh món ăn -->
  <div class="about-gallery-section">
    <div class="section-label">Một vài món đặc trưng</div>
    <div class="row g-3">
      <div class="col-md-4">
        <% if (setting && setting.aboutGalleryImage1) { %>
          <img src="<%= setting.aboutGalleryImage1 %>" alt="Món ăn" class="about-img-real about-img-real-sm">
        <% } else { %>
          <div class="about-img-placeholder about-img-placeholder-sm">
            <span class="about-img-placeholder-icon">📷</span>
            <span class="about-img-placeholder-text">Ảnh món ăn</span>
          </div>
        <% } %>
      </div>
      <div class="col-md-4">
        <% if (setting && setting.aboutGalleryImage2) { %>
          <img src="<%= setting.aboutGalleryImage2 %>" alt="Món ăn" class="about-img-real about-img-real-sm">
        <% } else { %>
          <div class="about-img-placeholder about-img-placeholder-sm">
            <span class="about-img-placeholder-icon">📷</span>
            <span class="about-img-placeholder-text">Ảnh món ăn</span>
          </div>
        <% } %>
      </div>
      <div class="col-md-4">
        <% if (setting && setting.aboutGalleryImage3) { %>
          <img src="<%= setting.aboutGalleryImage3 %>" alt="Món ăn" class="about-img-real about-img-real-sm">
        <% } else { %>
          <div class="about-img-placeholder about-img-placeholder-sm">
            <span class="about-img-placeholder-icon">📷</span>
            <span class="about-img-placeholder-text">Ảnh món ăn</span>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Thông tin liên hệ -->
  <div class="about-contact-section">
    <div class="row g-4">
      <div class="col-md-4">
        <div class="about-contact-card">
          <div class="about-contact-icon">📍</div>
          <h5>Địa chỉ</h5>
          <p>Hồ Chí Minh<br><span style="color:#b0a89e; font-size:12px;">(cập nhật địa chỉ cụ thể)</span></p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="about-contact-card">
          <div class="about-contact-icon">🕐</div>
          <h5>Giờ mở cửa</h5>
          <p>14:30 - 21:40<br>Thứ 3 - Chủ nhật hàng tuần</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="about-contact-card">
          <div class="about-contact-icon">📞</div>
          <h5>Liên hệ</h5>
          <p>090xxxxxxx<br>foodorder@gmail.com</p>
        </div>
      </div>
    </div>
  </div>

</div>

<%- include("partials/footer") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<style>
    .custom-navbar {
        background: #fff;
        border-bottom: 1px solid #e3d8bf;
        box-shadow: 0 2px 12px rgba(26,20,16,0.05);
        padding: 12px 0;
        transition: box-shadow 0.25s, padding 0.25s;
    }

    .custom-navbar.navbar-scrolled {
        padding: 7px 0;
        box-shadow: 0 6px 24px rgba(26,20,16,0.1);
    }

    .site-logo {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #e3d8bf;
        transition: width 0.25s, height 0.25s;
    }

    .navbar-scrolled .site-logo {
        width: 36px;
        height: 36px;
    }

    .logo-title {
        font-family: 'Noto Serif', Georgia, serif;
        font-size: 16px;
        font-weight: 700;
        color: #1a1410;
        line-height: 1.3;
        letter-spacing: 0.2px;
    }

    .logo-sub {
        font-size: 11px;
        color: #9e9484;
        letter-spacing: 0.3px;
    }

    .custom-navbar .nav-link {
        font-size: 14px;
        color: #5a4f3f;
        font-weight: 500;
        padding: 6px 14px !important;
        border-radius: 8px;
        transition: background 0.15s, color 0.15s;
    }

    .custom-navbar .nav-link:hover,
    .custom-navbar .nav-link.active {
        color: #D85A30;
        background: #fdf2ee;
    }

    .btn-cart {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: #D85A30;
        color: #fff !important;
        border: none;
        border-radius: 10px;
        padding: 9px 16px;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.15s;
        position: relative;
    }

    .btn-cart:hover {
        background: #c44e26;
        color: #fff !important;
    }

    .btn-cart .cart-badge {
        position: absolute;
        top: -6px;
        right: -6px;
        background: #1a1410;
        color: #fff;
        font-size: 10px;
        font-weight: 600;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #fff;
    }

    .navbar-nav-actions {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    @media (max-width: 991px) {
        .navbar-nav-actions {
            margin-top: 12px;
            flex-wrap: wrap;
        }
    }

    /* ── Menu tài khoản dạng hamburger/dropdown ── */
    .btn-account-menu {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: transparent;
        color: #5a4f3f;
        border: 1px solid #d9cfb8;
        border-radius: 10px;
        padding: 8px 14px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: border-color 0.15s, background 0.15s, color 0.15s;
    }

    .btn-account-menu:hover,
    .btn-account-menu:focus {
        border-color: #D85A30;
        color: #D85A30;
        background: #fdf2ee;
    }

    .header-avatar-img {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }

    .header-avatar-fallback {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #e8693f 0%, #D85A30 100%);
        color: #fff;
        font-size: 11px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .account-dropdown-menu {
        border: 1px solid #e3d8bf;
        border-radius: 12px;
        box-shadow: 0 16px 40px rgba(26,20,16,0.18);
        padding: 10px;
        min-width: 220px;
        z-index: 1050;
        margin-top: 8px !important;
        font-family: 'Poppins', sans-serif;
    }

    .account-dropdown-menu .dropdown-item {
        display: flex;
        align-items: center;
        gap: 10px;
        border-radius: 8px;
        padding: 10px 12px;
        font-size: 14px;
        color: #333;
        font-weight: 500;
        line-height: 1.3;
    }

    .account-dropdown-menu .dropdown-item:hover,
    .account-dropdown-menu .dropdown-item:focus {
        background: #fdf2ee;
        color: #D85A30;
    }

    .account-dropdown-menu .dropdown-item.text-danger {
        color: #c0392b;
    }

    .account-dropdown-menu .dropdown-item.text-danger:hover {
        background: #fdf2ee;
        color: #c0392b;
    }

    .account-dropdown-menu hr {
        margin: 8px 6px;
        border: none;
        border-top: 1px solid #e3d8bf;
        opacity: 1;
    }

    /* ── Mobile menu (collapse) nâng cấp ── */
    @media (max-width: 991px) {
        .navbar-collapse {
            border-top: 1px solid #e3d8bf;
            margin-top: 12px;
            padding-top: 14px;
        }

        .navbar-nav {
            margin-bottom: 4px;
        }

        .custom-navbar .nav-link {
            padding: 11px 14px !important;
            border-radius: 10px;
        }

        .navbar-nav .nav-item + .nav-item {
            margin-top: 2px;
        }
    }

    .navbar-toggler {
        border: 1px solid #d9cfb8 !important;
        border-radius: 8px !important;
        padding: 6px 10px !important;
    }

    .navbar-toggler:focus {
        box-shadow: 0 0 0 3px rgba(216,90,48,0.15) !important;
    }
</style>

<nav class="navbar navbar-expand-lg custom-navbar sticky-top" id="mainNavbar">
    <div class="container-fluid px-4">

        <a class="navbar-brand d-flex align-items-center gap-3" href="/">
            <img src="/images/logo.jpg" class="site-logo" alt="Logo">
            <div>
                <div class="logo-title">Đậu Hủ Thúi Nhà Họ La</div>
                <div class="logo-sub">Traditional Chinese Street Food</div>
            </div>
        </a>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">

            <ul class="navbar-nav mx-auto gap-1">
                <li class="nav-item">
                    <a class="nav-link" href="/">Thực đơn</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/about">Giới thiệu</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/discussion">Diễn đàn</a>
                </li>
            </ul>

            <div class="navbar-nav-actions">

                <a href="/cart" class="btn-cart">
                    🛒 Giỏ hàng
                    <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
                        <span class="cart-badge"><%= cartCount %></span>
                    <% } %>
                </a>

                <% if (user) { %>
                    <div class="dropdown">
                        <button class="btn-account-menu dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <% if (user.avatar && user.avatar !== "/images/default-avatar.png") { %>
                                <img src="<%= user.avatar %>" class="header-avatar-img" alt="Avatar">
                            <% } else { %>
                                <span class="header-avatar-fallback"><%= (user.fullname || '?').charAt(0).toUpperCase() %></span>
                            <% } %>
                            <%= user.fullname || 'Tài khoản' %>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end account-dropdown-menu">
                            <li><a class="dropdown-item" href="/my-orders">📦 Đơn hàng</a></li>
                            <li><a class="dropdown-item" href="/profile">👤 Tài khoản</a></li>
                            <li><hr></li>
                            <li><a class="dropdown-item text-danger" href="/logout">🚪 Đăng xuất</a></li>
                        </ul>
                    </div>
                <% } else { %>
                    <div class="dropdown">
                        <button class="btn-account-menu dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="hamburger-icon">☰</span> Tài khoản
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end account-dropdown-menu">
                            <li><a class="dropdown-item" href="/track-order">🔍 Tra cứu đơn hàng</a></li>
                            <li><hr></li>
                            <li><a class="dropdown-item" href="/login">Đăng nhập</a></li>
                            <li><a class="dropdown-item" href="/register">Đăng ký</a></li>
                        </ul>
                    </div>
                <% } %>

            </div>

        </div>

    </div>
</nav>

<!-- ── Chặn double-tap-to-zoom trên mobile (toàn trang) ──
     Khách bấm nhanh 2 lần liên tiếp vào bất kỳ đâu sẽ không bị trình duyệt
     tự động zoom vào. Vẫn cho phép pinch-zoom bằng 2 ngón tay nếu khách
     cần đọc chữ nhỏ hoặc xem ảnh kỹ hơn (không dùng user-scalable=no vì
     cách đó chặn luôn cả pinch-zoom, ảnh hưởng khả năng tiếp cận). -->
<script>
  (function() {
    let lastTouchEnd = 0;
    document.addEventListener('touchend', function(e) {
      const now = Date.now();
      if (now - lastTouchEnd <= 350) {
        e.preventDefault();
      }
      lastTouchEnd = now;
    }, { passive: false });
  })();
</script>

<!-- ── Hiệu ứng cuộn cho navbar: thu nhỏ logo + tăng shadow khi cuộn xuống ── -->
<script>
  (function() {
    const navbar = document.getElementById('mainNavbar');
    if (!navbar) return;

    const SCROLL_THRESHOLD = 20;

    function handleScroll() {
      const scrollY = window.scrollY || window.pageYOffset || document.documentElement.scrollTop || 0;
      navbar.classList.toggle('navbar-scrolled', scrollY > SCROLL_THRESHOLD);
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    document.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
  })();
</script>

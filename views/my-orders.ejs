<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đơn hàng của tôi - Đậu Hũ Thúi Nhà Họ La</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<%- include("partials/header", { user: user }) %>

<div class="cart-hero">
  <div class="container">
    <h1>📦 Đơn hàng của tôi</h1>
    <p>Theo dõi đơn hàng và đánh giá món ăn bạn đã thưởng thức</p>
  </div>
</div>

<div class="container py-5">

  <% if (orders.length === 0) { %>
    <div class="empty-cart-card">
      <div style="font-size:56px; margin-bottom:16px;">📦</div>
      <h3 style="font-size:20px; font-weight:600; color:#1a1a1a; margin-bottom:8px;">Bạn chưa có đơn hàng nào</h3>
      <p style="color:#9ca3af; font-size:14px;">Hãy quay lại menu và đặt món yêu thích!</p>
      <a href="/" class="btn-menu mt-3" style="display:inline-flex; align-items:center; gap:6px; background:#1a1a1a; color:#fff; border-radius:10px; padding:9px 18px; font-size:13px; font-weight:500; text-decoration:none;">🍜 Xem menu</a>
    </div>
  <% } else { %>

    <% orders.forEach(order => { %>
      <div class="cart-item-card" style="flex-direction:column; align-items:stretch; gap:12px;">

        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
          <div>
            <div style="font-size:13px; color:#9ca3af;">Mã đơn: <span style="font-family:monospace"><%= order._id %></span></div>
            <div style="font-size:13px; color:#9ca3af;">Ngày đặt: <%= order.createdAt.toLocaleDateString('vi-VN') %></div>
          </div>
          <div>
            <% if (order.paymentCode) { %>
              <span class="badge-confirmed">✅ <%= order.status %></span>
            <% } else { %>
              <span class="badge-pending">⏳ <%= order.status %></span>
            <% } %>
          </div>
        </div>

        <div style="border-top:1px solid #f0ece8; padding-top:12px;">
          <% order.items.forEach(item => { %>
            <%
              const reviewKey = order._id + "_" + item.foodId;
              const alreadyReviewed = reviewedKeys.includes(reviewKey);
            %>
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
              <div>
                <span style="font-weight:600; color:#1a1a1a;"><%= item.name %></span>
                <span style="color:#9ca3af; font-size:12px;"> x<%= item.quantity %></span>
              </div>

              <% if (order.paymentCode && item.foodId) { %>
                <% if (alreadyReviewed) { %>
                  <span style="font-size:12px; color:#16a34a; font-weight:600;">✅ Đã đánh giá</span>
                <% } else { %>
                  <button
                    type="button"
                    class="btn-review-open"
                    data-order="<%= order._id %>"
                    data-food="<%= item.foodId %>"
                    data-name="<%= item.name %>"
                    style="background:#fff3ee; color:#D85A30; border:1px solid #ffd9c2; border-radius:8px; padding:5px 12px; font-size:12px; font-weight:600; cursor:pointer;"
                  >
                    ⭐ Đánh giá món
                  </button>
                <% } %>
              <% } %>
            </div>
          <% }) %>
        </div>

        <div style="text-align:right; font-weight:700; color:#D85A30; font-size:15px;">
          Tổng: <%= order.totalPrice.toLocaleString('vi-VN') %> VNĐ
        </div>

      </div>
    <% }) %>

  <% } %>

</div>

<!-- Review Modal -->
<div id="reviewModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:999; align-items:center; justify-content:center;">
  <div style="background:#fff; border-radius:16px; padding:24px; width:90%; max-width:420px;">
    <h3 style="font-size:16px; font-weight:700; color:#1a1a1a; margin-bottom:4px;">Đánh giá: <span id="reviewFoodName"></span></h3>
    <p style="font-size:12px; color:#9ca3af; margin-bottom:16px;">Chia sẻ cảm nhận của bạn về món ăn này</p>

    <form id="reviewForm" method="POST" action="">
      <div style="display:flex; gap:6px; margin-bottom:16px; font-size:32px;" id="starPicker">
        <span class="star-pick" data-val="1" style="cursor:pointer; color:#ddd;">★</span>
        <span class="star-pick" data-val="2" style="cursor:pointer; color:#ddd;">★</span>
        <span class="star-pick" data-val="3" style="cursor:pointer; color:#ddd;">★</span>
        <span class="star-pick" data-val="4" style="cursor:pointer; color:#ddd;">★</span>
        <span class="star-pick" data-val="5" style="cursor:pointer; color:#ddd;">★</span>
      </div>
      <input type="hidden" name="rating" id="ratingInput" value="0" required>

      <textarea name="comment" class="form-input-custom" placeholder="Nhận xét của bạn (không bắt buộc)..." rows="3" style="resize:none;"></textarea>

      <div class="d-flex gap-2 mt-2">
        <button type="submit" class="btn-order" style="flex:1;">Gửi đánh giá</button>
        <button type="button" id="closeModalBtn" style="background:#f9f6f3; color:#374151; border:1px solid #e8e2dc; border-radius:10px; padding:0 18px; font-weight:600; font-size:13px;">Hủy</button>
      </div>
    </form>
  </div>
</div>

<%- include("partials/footer") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const modal = document.getElementById('reviewModal');
  const form = document.getElementById('reviewForm');
  const foodNameEl = document.getElementById('reviewFoodName');
  const ratingInput = document.getElementById('ratingInput');
  const stars = document.querySelectorAll('.star-pick');

  document.querySelectorAll('.btn-review-open').forEach(btn => {
    btn.addEventListener('click', () => {
      const orderId = btn.dataset.order;
      const foodId = btn.dataset.food;
      const name = btn.dataset.name;

      foodNameEl.textContent = name;
      form.action = '/review/' + orderId + '/' + foodId;
      ratingInput.value = 0;
      stars.forEach(s => s.style.color = '#ddd');

      modal.style.display = 'flex';
    });
  });

  stars.forEach(star => {
    star.addEventListener('click', () => {
      const val = parseInt(star.dataset.val);
      ratingInput.value = val;
      stars.forEach(s => {
        s.style.color = parseInt(s.dataset.val) <= val ? '#D85A30' : '#ddd';
      });
    });
  });

  document.getElementById('closeModalBtn').addEventListener('click', () => {
    modal.style.display = 'none';
  });

  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.style.display = 'none';
  });

  form.addEventListener('submit', (e) => {
    if (parseInt(ratingInput.value) < 1) {
      e.preventDefault();
      alert('Vui lòng chọn số sao đánh giá!');
    }
  });
</script>

</body>
</html>

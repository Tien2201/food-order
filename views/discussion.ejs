<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Thảo luận - Đậu Hủ Thúi Nhà Họ La</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Noto+Serif:wght@700&display=swap" rel="stylesheet">
</head>
<body>

<%- include("partials/header", { user: user }) %>

<!-- Hero -->
<div class="menu-hero">
  <div class="container">
    <h1>Thảo luận & Feedback 💬</h1>
    <p>Chia sẻ trải nghiệm của bạn về món ăn tại quán</p>
  </div>
</div>

<div class="container py-5" style="max-width:720px;">

  <% if (error) { %>
    <div class="alert alert-danger" id="discussionAlert" style="border-radius:10px; font-size:13px;"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="alert alert-success" id="discussionAlert" style="border-radius:10px; font-size:13px;"><%= success %></div>
  <% } %>

  <!-- Form đăng bài - chỉ hiện nếu đã đăng nhập -->
  <% if (user) { %>
    <div class="discussion-form-card">
      <form action="/discussion" method="POST" enctype="multipart/form-data" id="postForm">
        <textarea name="content" class="form-input-custom discussion-textarea" rows="2" placeholder="Chia sẻ cảm nhận của bạn về món ăn..." required></textarea>

        <input type="file" name="images" id="postImagesInput" accept="image/jpeg,image/jpg,image/png,image/webp" multiple hidden>
        <div id="postImagePreview" class="discussion-image-preview"></div>

        <div class="discussion-form-actions">
          <label for="postImagesInput" class="discussion-add-photo-btn" title="Thêm ảnh (tối đa 4)">
            📷 Thêm ảnh
          </label>
          <button type="submit" class="discussion-submit-btn">Đăng bài</button>
        </div>
        <p class="discussion-form-hint">Bài đăng sẽ hiện công khai sau khi được admin duyệt.</p>
      </form>
    </div>
  <% } else { %>
    <div class="discussion-login-prompt">
      <p style="margin-bottom:10px;">Đăng nhập để chia sẻ cảm nhận của bạn về món ăn</p>
      <a href="/login" class="btn-auth" style="display:inline-block; width:auto; padding:10px 28px;">Đăng nhập</a>
    </div>
  <% } %>

  <!-- Danh sách bài đã duyệt -->
  <div class="discussion-section-label">Bài viết từ khách hàng</div>

  <% if (posts.length === 0) { %>
    <div class="empty-state">
      <div style="font-size:40px; margin-bottom:8px;">💬</div>
      <p>Chưa có bài viết nào. Hãy là người chia sẻ đầu tiên!</p>
    </div>
  <% } else { %>
    <div class="discussion-feed">
      <% posts.forEach(post => { %>
        <div class="discussion-post-card">
          <div class="discussion-post-header">
            <% if (post.user && post.user.avatar && post.user.avatar !== "/images/default-avatar.png") { %>
              <img src="<%= post.user.avatar %>" class="discussion-post-avatar" alt="Avatar">
            <% } else { %>
              <div class="discussion-post-avatar-fallback"><%= (post.user && post.user.fullname || '?').charAt(0).toUpperCase() %></div>
            <% } %>
            <div>
              <div class="discussion-post-name"><%= post.user ? post.user.fullname : 'Khách' %></div>
              <div class="discussion-post-time"><%= new Date(post.createdAt).toLocaleDateString('vi-VN') %></div>
            </div>
          </div>

          <div class="discussion-post-content"><%= post.content %></div>

          <% if (post.images && post.images.length > 0) { %>
            <div class="discussion-post-images">
              <% post.images.forEach(img => { %>
                <img src="<%= img %>" alt="Ảnh feedback" onclick="openImageLightbox(this.src)">
              <% }) %>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>

</div>

<!-- Lightbox xem ảnh phóng to khi bấm vào ảnh trong bài đăng -->
<div class="discussion-lightbox-overlay" id="discussionLightbox" onclick="if(event.target===this) closeImageLightbox()">
  <button type="button" class="discussion-lightbox-close" onclick="closeImageLightbox()">✕</button>
  <img id="discussionLightboxImg" src="" alt="Ảnh phóng to">
</div>

<%- include("partials/footer") %>

<!-- ── Nút quay lại đầu trang ──
     Góc dưới-trái. Ẩn khi ở đầu trang, tự hiện khi cuộn xuống quá 300px. -->
<button type="button" id="scrollToTopBtn" class="scroll-to-top-btn" aria-label="Quay lại đầu trang">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 19V5"></path>
    <path d="M5 12l7-7 7 7"></path>
  </svg>
</button>

<script>
  (function() {
    const btn = document.getElementById('scrollToTopBtn');
    const SHOW_AFTER_PX = 300;

    function getScrollY() {
      return window.scrollY
        || window.pageYOffset
        || document.documentElement.scrollTop
        || document.body.scrollTop
        || 0;
    }

    function toggleScrollBtn() {
      btn.classList.toggle('show', getScrollY() > SHOW_AFTER_PX);
    }

    window.addEventListener('scroll', toggleScrollBtn, { passive: true });
    document.addEventListener('scroll', toggleScrollBtn, { passive: true });
    toggleScrollBtn();

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
      document.documentElement.scrollTop = 0;
      document.body.scrollTop = 0;
    });
  })();
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  setTimeout(() => {
    const box = document.getElementById('discussionAlert');
    if (box) box.style.display = 'none';
  }, 4000);

  // ── Lightbox xem ảnh phóng to ──
  function openImageLightbox(src) {
    document.getElementById('discussionLightboxImg').src = src;
    document.getElementById('discussionLightbox').classList.add('show');
    document.body.style.overflow = 'hidden';
  }

  function closeImageLightbox() {
    document.getElementById('discussionLightbox').classList.remove('show');
    document.body.style.overflow = '';
  }

  // ── Xem trước ảnh đã chọn, cộng dồn qua nhiều lần bấm "Choose Files" ──
  // Hành vi mặc định của <input type="file" multiple> là THAY THẾ hoàn toàn
  // danh sách file mỗi lần chọn lại, không cộng dồn — đây là lý do khách chỉ
  // giữ được ảnh chọn ở lần cuối. Cách sửa: tự quản lý 1 mảng "selectedFiles"
  // riêng trong JS, mỗi lần chọn thêm sẽ gộp vào mảng đó, rồi dùng DataTransfer
  // để gán lại đúng danh sách đầy đủ vào input trước khi submit form.
  const postImagesInput = document.getElementById('postImagesInput');
  const postImagePreview = document.getElementById('postImagePreview');
  const MAX_IMAGES = 4;
  let selectedFiles = [];

  function renderImagePreview() {
    postImagePreview.innerHTML = '';

    selectedFiles.forEach((file, index) => {
      const reader = new FileReader();
      reader.onload = (e) => {
        const wrap = document.createElement('div');
        wrap.className = 'discussion-preview-item';

        const img = document.createElement('img');
        img.src = e.target.result;

        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'discussion-preview-remove';
        removeBtn.textContent = '✕';
        removeBtn.addEventListener('click', () => {
          selectedFiles.splice(index, 1);
          syncFilesToInput();
          renderImagePreview();
        });

        wrap.appendChild(img);
        wrap.appendChild(removeBtn);
        postImagePreview.appendChild(wrap);
      };
      reader.readAsDataURL(file);
    });
  }

  // Gán lại đúng danh sách selectedFiles vào input thật, để form submit đủ ảnh
  function syncFilesToInput() {
    const dataTransfer = new DataTransfer();
    selectedFiles.forEach(file => dataTransfer.items.add(file));
    postImagesInput.files = dataTransfer.files;
  }

  if (postImagesInput) {
    postImagesInput.addEventListener('change', () => {
      const newFiles = Array.from(postImagesInput.files);

      // Cộng dồn với ảnh đã chọn trước đó, không thay thế
      selectedFiles = selectedFiles.concat(newFiles);

      if (selectedFiles.length > MAX_IMAGES) {
        alert(`Chỉ được chọn tối đa ${MAX_IMAGES} ảnh. Hệ thống sẽ chỉ giữ ${MAX_IMAGES} ảnh đầu tiên.`);
        selectedFiles = selectedFiles.slice(0, MAX_IMAGES);
      }

      syncFilesToInput();
      renderImagePreview();
    });
  }
</script>
</body>
</html>

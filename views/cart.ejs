<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Giỏ hàng - Đậu Hũ Thúi Nhà Họ La</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.jpg">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  
</head>
<body>

<%- include("partials/header", { user: user }) %>

<!-- Hero -->
<div class="cart-hero">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <h1>🛒 Giỏ hàng của bạn</h1>
        <p>Kiểm tra món ăn và điền thông tin giao hàng trước khi đặt</p>
      </div>
      <a href="/" class="btn-back">🍜 Tiếp tục chọn món</a>
    </div>
  </div>
</div>

<div class="container py-5">

  <% if (cart.length === 0) { %>

    <div class="empty-cart-card">
      <div class="empty-icon">🛒</div>
      <h3>Giỏ hàng đang trống</h3>
      <p>Hãy quay lại menu và thêm món bạn yêu thích nhé!</p>
      <a href="/" class="btn-menu mt-3">🍜 Xem menu</a>
    </div>

  <% } else { %>

    <div class="row g-4">

      <!-- Danh sách món -->
      <div class="col-lg-7">
        <div class="cart-section-title">Món đã chọn (<%= cart.length %> món)</div>

        <% cart.forEach((item, index) => { %>
          <div class="cart-item-card">
            <img
              src="<%= item.image || '/images/background.jpg' %>"
              class="cart-item-img"
              alt="<%= item.name %>"
              onerror="this.src='/images/background.jpg'"
            >
            <div class="cart-item-info">
              <div class="cart-item-name"><%= item.name %></div>
              <div class="cart-item-note">
                <% if (item.note) { %>
                  📝 <%= item.note %>
                <% } else { %>
                  Không có ghi chú
                <% } %>
              </div>
              <div class="cart-item-meta">
                <span class="cart-item-qty">x<%= item.quantity %></span>
                <span class="cart-item-price"><%= (item.price * item.quantity).toLocaleString('vi-VN') %> VNĐ</span>
              </div>
            </div>
            <form action="/cart/remove/<%= index %>" method="POST">
              <button type="submit" class="btn-remove" title="Xóa món">🗑</button>
            </form>
          </div>
        <% }) %>
      </div>

      <!-- Order summary -->
      <div class="col-lg-5">
        <div class="summary-card">
          <h3>📋 Thông tin đặt món</h3>

          <div class="summary-row">
            <span>Số món</span>
            <span><%= cart.length %> món</span>
          </div>
          <div class="summary-row">
            <span>Tổng số lượng</span>
            <span><%= cart.reduce((sum, i) => sum + i.quantity, 0) %> phần</span>
          </div>

          <div class="summary-total">
            <span>Tổng tiền</span>
            <strong><%= totalPrice.toLocaleString('vi-VN') %> VNĐ</strong>
          </div>

          <form action="/checkout" method="POST">
            <label class="form-label-custom">Tên khách hàng</label>
            <input
              name="customerName"
              class="form-input-custom"
              placeholder="Nguyễn Văn A"
              value="<%= user && user.name ? user.name : '' %>"
              required
            >

            <label class="form-label-custom">Số điện thoại</label>
            <input
              name="phone"
              class="form-input-custom"
              placeholder="0901 234 567"
              type="tel"
              value="<%= user && user.phone ? user.phone : '' %>"
              required
            >

            <label class="form-label-custom">Địa chỉ giao hàng</label>
            <input
              name="address"
              class="form-input-custom"
              placeholder="123 Đường ABC, Quận 1, TP.HCM"
              required
            >

            <button type="submit" class="btn-order">
              🎉 Đặt món ngay — <%= totalPrice.toLocaleString('vi-VN') %> VNĐ
            </button>
          </form>
        </div>
      </div>

    </div>

  <% } %>

</div>

<%- include("partials/footer") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
